 7064:     const sL = Math.sin(lambda), cL = Math.cos(lambda);
 7065:     sSig = Math.sqrt((cU2*sL)*(cU2*sL) + (cU1*sU2 - sU1*cU2*cL)*(cU1*sU2 - sU1*cU2*cL));
