13500: /**
13501:  * Mouse/touch pan on a tile map. Translates the .tile-layer live during the
13502:  * gesture (cheap CSS transform, no re-render), then on release converts the
13503:  * pixel delta into a new view center (lat/lon) and redraws the tiles.
13504:  *
13505:  * Clicks on controls (.tz-btn, .ts-btn, .tl-btn, attribution, recenter) are
13506:  * ignored so they keep behaving as normal buttons. A small dead-zone (<3 px)
13507:  * also prevents accidental map moves when the user just clicks.
13508:  */
13509: function attachPanHandlers(root, lat, lon, zoom){
13510:   const tileMap   = root.querySelector(".tile-map");
13511:   const tileLayer = root.querySelector(".tile-layer");
13512:   if (!tileMap || !tileLayer) return;
13513: 
13514:   const CTRL_SEL = ".tz-btn, .ts-btn, .tl-btn, .tg-btn, .tcov-btn, .tmeas-btn, .tile-ctrls, .tile-layers, .tile-attrib, .tile-recenter, .tile-pick, .tile-bottom-left, .tile-bl-row, .tile-readout, .trp, .tile-measure-box, .mm-handle";
13515: 
13516:   const getPt = (ev) => {
13517:     const src = (ev.touches && ev.touches.length) ? ev.touches[0] : ev;
13518:     return { x: src.clientX, y: src.clientY };
13519:   };
13520: 
13521:   const onDown = (ev) => {
13522:     if (ev.target.closest(CTRL_SEL)) return; // don't hijack button clicks
13523:     if (ev.button !== undefined && ev.button !== 0) return; // only left-click
13524:     // Yield to bbox selection / handle drag. While .bbox-selecting is set
13525:     // on .tile-map, the bbox draw handlers own the pointer. Also bail out
13526:     // if the user clicked directly on an overlay handle or remove button.
13527:     if (state._bboxSelecting) return;
13528:     if (ev.target.closest(".bbox-handle, .bbox-remove")) return;
13529:     const pt = getPt(ev);
13530:     const drag = { sx: pt.x, sy: pt.y, dx: 0, dy: 0, moved: false };
13531: 
13532:     const onMove = (e) => {
13533:       const p = getPt(e);
13534:       drag.dx = p.x - drag.sx;
13535:       drag.dy = p.y - drag.sy;
13536:       if (!drag.moved && Math.hypot(drag.dx, drag.dy) > 3){
13537:         drag.moved = true;
13538:         tileMap.classList.add("dragging");
13539:       }
13540:       if (drag.moved){
13541:         tileLayer.style.transform = `translate3d(${drag.dx}px, ${drag.dy}px, 0)`;
13542:         if (e.cancelable) e.preventDefault();
13543:       }
13544:     };
13545: 
13546:     const onUp = (ev) => {
13547:       window.removeEventListener("mousemove", onMove);
13548:       window.removeEventListener("mouseup", onUp);
13549:       window.removeEventListener("touchmove", onMove);
13550:       window.removeEventListener("touchend", onUp);
13551:       window.removeEventListener("touchcancel", onUp);
13552: 
13553:       tileMap.classList.remove("dragging");
13554:       const cx = (ev && ev.clientX != null) ? ev.clientX : (ev && ev.changedTouches && ev.changedTouches[0] ? ev.changedTouches[0].clientX : null);
13555:       const cy = (ev && ev.clientY != null) ? ev.clientY : (ev && ev.changedTouches && ev.changedTouches[0] ? ev.changedTouches[0].clientY : null);
13556:       // Track pick mode: every click adds a point, mode stays active so
13557:       // the user can place many in a row. ESC or re-clicking the button exits.
13558:       if (state.track && state.track.pickMode && !drag.moved && cx != null && cy != null){
13559:         const zPick = state.mapZoom || zoom;
13560:         const pick = mapClientToLatLonMap(root, lat, lon, zPick, cx, cy);
13561:         if (pick && Number.isFinite(pick.lat) && Number.isFinite(pick.lon)){
13562:           trackAddPoint(pick.lat, pick.lon, "", { from: "map-click" });
13563:         }
13564:         return;
13565:       }
13566:       if (state.mapPickMode && !drag.moved && cx != null && cy != null){
13567:         const zPick = state.mapZoom || zoom;
13568:         const pick = mapClientToLatLonMap(root, lat, lon, zPick, cx, cy);
13569:         if (pick && Number.isFinite(pick.lat) && Number.isFinite(pick.lon)){
13570:           state.mapPickMode = false;
13571:           root.classList.remove("map-pick-mode");
13572:           renderResults(pick.lat, pick.lon, { type: "LatLon", raw: t("map.pickRaw") + " " + pick.lat.toFixed(5) + ", " + pick.lon.toFixed(5) });
13573:         }
13574:         return;
13575:       }
13576:       // On-map measure mode: click two points and compute distance + azimuth.
13577:       if (state.mapMeasureMode && !drag.moved && cx != null && cy != null){
13578:         const zPick = state.mapZoom || zoom;
13579:         const pick = mapClientToLatLonMap(root, lat, lon, zPick, cx, cy);
13580:         if (pick && Number.isFinite(pick.lat) && Number.isFinite(pick.lon)){
13581:           const kind = (state.mapMeasureKind || "line");
13582:           if (kind === "poly"){
13583:             const a = Array.isArray(state.mapPolyPts) ? state.mapPolyPts.slice() : [];
13584:             a.push({ lat: pick.lat, lon: pick.lon });
13585:             state.mapPolyPts = a;
13586:           } else {
13587:             const pts = Array.isArray(state.mapMeasurePts) ? state.mapMeasurePts.slice() : [];
13588:             if (pts.length >= 2) pts.length = 0; // start new segment
13589:             pts.push({ lat: pick.lat, lon: pick.lon });
13590:             state.mapMeasurePts = pts;
13591:           }
13592:           renderMapMeasureOverlay(root, lat, lon, zPick);
13593:           updateMeasureReadouts(root);
13594:         }
13595:         return;
13596:       }
13597:       if (!drag.moved) return;
13598: 
13599:       // Convert pixel drag into tile-space delta and then into lat/lon.
13600:       const z = state.mapZoom || zoom;
13601:       const vc = state.viewCenter || { lat, lon };
13602:       const vLat = Math.max(-85.05, Math.min(85.05, vc.lat));
13603:       const vLon = normalizeLon(vc.lon);
13604:       const newVtx = lonToTileX(vLon, z) - drag.dx / 256;
13605:       const newVty = latToTileY(vLat, z) - drag.dy / 256;
13606:       const newLon = normalizeLon(tileX2Lon(newVtx, z));
13607:       let newLat   = tileY2Lat(newVty, z);
13608:       newLat = Math.max(-85.05, Math.min(85.05, newLat));
13609:       state.viewCenter = { lat: newLat, lon: newLon };
13610:       saveStore();
13611:       renderTileMap(lat, lon, z);
13612:     };
13613: 
13614:     window.addEventListener("mousemove", onMove);
13615:     window.addEventListener("mouseup", onUp);
13616:     window.addEventListener("touchmove", onMove, { passive: false });
13617:     window.addEventListener("touchend", onUp);
13618:     window.addEventListener("touchcancel", onUp);
13619:     if (ev.cancelable) ev.preventDefault();
13620:   };
13621: 
13622:   tileMap.addEventListener("mousedown", onDown);
13623:   tileMap.addEventListener("touchstart", onDown, { passive: false });
13624: }
