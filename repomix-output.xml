14068:   const notes = (window.prompt(t("fav.notesPrompt"), "") || "").trim().slice(0, 500);
14069:   const createdAt = Date.now();
14070:   state.favorites.unshift({
14071:     id: uid(),
14072:     name,
14073:     notes: notes || "",
14074:     lat: r.lat, lon: r.lon,
14075:     createdAt,
