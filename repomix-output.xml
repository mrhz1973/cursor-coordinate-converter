11513: /** Count how many tiles are covered by a bbox {n,s,e,w} over a zoom range.
11514:  *  (Different signature from the earlier countBboxTiles(n,s,e,w,z0,z1) used
11515:  *  by the pre-cache engine — kept distinct to avoid accidental shadowing.) */
11516: function countTilesInBbox(b, z0, z1){
11517:   if (!b) return 0;
11518:   let tot = 0;
11519:   for (let z = z0; z <= z1; z++){
11520:     const xw = Math.floor(lonToTileX(b.w, z));
11521:     const xe = Math.floor(lonToTileX(b.e, z));
11522:     const yn = Math.floor(latToTileY(Math.min(85.05, b.n), z));
11523:     const ys = Math.floor(latToTileY(Math.max(-85.05, b.s), z));
11524:     const cx = Math.max(0, xe - xw + 1);
11525:     const cy = Math.max(0, ys - yn + 1);
11526:     tot += cx * cy;
11527:   }
11528:   return tot;
11529: }
