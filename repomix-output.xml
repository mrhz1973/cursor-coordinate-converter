10036: /**
10037:  * Make the offline tile panel draggable when the map is in "half" or
10038:  * "full" mode. The drag handle is the <summary> element. Clicking without
10039:  * moving still toggles the <details> open/close (native behavior); the
10040:  * drag only activates after ~4px of movement. Inline left/top on the
10041:  * panel wins over CSS defaults, so we clear them in setMapSize when the
10042:  * user leaves "full" mode (see above).
10043:  *
10044:  * The listener is idempotent: a `_draggableInstalled` flag prevents
10045:  * accumulating handlers across re-binds.
10046:  */
10047: function makeOfflinePanelDraggable(panel){
10048:   if (!panel || panel._draggableInstalled) return;
10049:   const handle = panel.querySelector(":scope > summary");
10050:   if (!handle) return;
10051: 
10052:   const DRAG_THRESHOLD = 4;
10053:   let down = null;   // { sx, sy, startL, startT }
10054:   let moved = false;
10055: 
10056:   const isEnlarged = () => document.body.classList.contains("mm-enlarged");
10057: 
10058:   const onDown = (ev) => {
10059:     if (!isEnlarged()) return;
10060:     const touch = ev.touches ? ev.touches[0] : ev;
10061:     const r = panel.getBoundingClientRect();
10062:     down = {
10063:       sx: touch.clientX, sy: touch.clientY,
10064:       startL: r.left, startT: r.top
10065:     };
10066:     moved = false;
10067:     window.addEventListener("mousemove", onMove);
10068:     window.addEventListener("mouseup", onUp);
10069:     window.addEventListener("touchmove", onMove, { passive: false });
10070:     window.addEventListener("touchend", onUp);
10071:     window.addEventListener("touchcancel", onUp);
10072:   };
10073: 
10074:   const onMove = (ev) => {
10075:     if (!down) return;
10076:     const touch = ev.touches ? ev.touches[0] : ev;
10077:     const dx = touch.clientX - down.sx;
10078:     const dy = touch.clientY - down.sy;
10079:     if (!moved && Math.hypot(dx, dy) < DRAG_THRESHOLD) return;
10080:     if (!moved){
10081:       moved = true;
10082:       panel.classList.add("dragging");
10083:     }
10084:     if (ev.cancelable) ev.preventDefault();
10085:     let L = down.startL + dx;
10086:     let T = down.startT + dy;
10087:     // Clamp so the handle always stays reachable on screen.
10088:     const pw = panel.offsetWidth  || 320;
10089:     const ph = Math.min(panel.offsetHeight || 200, 200);
10090:     L = Math.max(0, Math.min(window.innerWidth  - Math.min(pw, 120), L));
10091:     T = Math.max(0, Math.min(window.innerHeight - 40, T));
10092:     panel.style.left = L + "px";
10093:     panel.style.top  = T + "px";
10094:     panel.style.right  = "auto";
10095:     panel.style.bottom = "auto";
10096:   };
10097: 
10098:   const onUp = () => {
10099:     window.removeEventListener("mousemove", onMove);
10100:     window.removeEventListener("mouseup", onUp);
10101:     window.removeEventListener("touchmove", onMove);
10102:     window.removeEventListener("touchend", onUp);
10103:     window.removeEventListener("touchcancel", onUp);
10104:     if (moved){
10105:       panel.classList.remove("dragging");
10106:       // Swallow the click that would normally toggle <details>. We attach
10107:       // a capturing one-shot handler on the summary; if no click comes
10108:       // within a tick, clear it to avoid stale state.
10109:       const swallow = (ev2) => {
10110:         ev2.preventDefault();
10111:         ev2.stopPropagation();
10112:         handle.removeEventListener("click", swallow, true);
10113:       };
10114:       handle.addEventListener("click", swallow, true);
10115:       setTimeout(() => handle.removeEventListener("click", swallow, true), 250);
10116:     }
10117:     down = null;
10118:     moved = false;
10119:   };
10120: 
10121:   handle.addEventListener("mousedown", onDown);
10122:   handle.addEventListener("touchstart", onDown, { passive: true });
10123:   panel._draggableInstalled = true;
10124: }
