  826: /* ========= OFFLINE TILE PANEL — enlarged map modes =========
  827:  * When the map is promoted to "half" or "full", its original sidebar
  828:  * container is hidden behind a backdrop. We reposition the panel so the
  829:  * user can still reach it:
  830:  *   - "half": docked on the LEFT (the free half of the viewport);
  831:  *   - "full": FLOATING over the map, draggable via its <summary> bar.
  832:  *
  833:  * In full-mode the panel defaults to the top-left and the user can drag
  834:  * it anywhere; inline styles set by the JS drag take precedence over the
  835:  * default rule below. Leaving full-mode clears those inline styles. */
  836: body.mm-half #offlineTilePanel,
  837: body.mm-full #offlineTilePanel{
  838:   position:fixed; z-index:9100;
  839:   background:var(--panel);
  840:   border:1px solid var(--border);
  841:   border-radius:10px;
  842:   box-shadow:0 16px 40px rgba(0,0,0,.55);
  843:   margin:0; padding:10px 14px;
  844:   overflow:auto;
  845:   -webkit-overflow-scrolling:touch;
  846: }
  847: body.mm-half #offlineTilePanel{
  848:   left:16px; top:16px;
  849:   width:min(380px, calc(100vw - 50vw - 40px));
  850:   max-height:calc(100vh - 32px);
  851: }
  852: body.mm-full #offlineTilePanel{
  853:   left:16px; top:62px;
  854:   width:min(380px, calc(100vw - 32px));
  855:   max-height:calc(100vh - 32px);
  856: }
