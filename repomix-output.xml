 6560: // --- CH1903 (LV03/LV95) — swisstopo polynomial (works directly from WGS84) ---
 6561: function wgs84ToSwissLV03(lat, lon){
 6562:   // https://www.swisstopo.admin.ch/ (approx formulas)
 6563:   const latSex = (lat * 3600);
 6564:   const lonSex = (lon * 3600);
 6565:   const latAux = (latSex - 169028.66) / 10000;
 6566:   const lonAux = (lonSex - 26782.5) / 10000;
 6567:   const Y = 600072.37
 6568:           + 211455.93 * lonAux
 6569:           - 10938.51  * lonAux * latAux
 6570:           - 0.36      * lonAux * latAux * latAux
 6571:           - 44.54     * lonAux * lonAux * lonAux;
 6572:   const X = 200147.07
 6573:           + 308807.95 * latAux
 6574:           + 3745.25   * lonAux * lonAux
 6575:           + 76.63     * latAux * latAux
 6576:           - 194.56    * lonAux * lonAux * latAux
 6577:           + 119.79    * latAux * latAux * latAux;
 6578:   return { Y, X };
 6579: }
 6580: function wgs84ToSwissLV95(lat, lon){
 6581:   const lv03 = wgs84ToSwissLV03(lat, lon);
