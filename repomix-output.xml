11457: /** Write 4 numbers to the bbox fields; switches the preset to "custom". */
11458: function writeBboxFields(b){
11459:   const i = id => document.getElementById(id);
11460:   if (!b) return;
11461:   const nn = Math.max(b.n, b.s), ss = Math.min(b.n, b.s);
11462:   const ee = Math.max(b.e, b.w), ww = Math.min(b.e, b.w);
11463:   if (i("pcN")) i("pcN").value = nn.toFixed(4);
11464:   if (i("pcS")) i("pcS").value = ss.toFixed(4);
11465:   if (i("pcE")) i("pcE").value = ee.toFixed(4);
11466:   if (i("pcW")) i("pcW").value = ww.toFixed(4);
