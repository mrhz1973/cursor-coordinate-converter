13626: /**
13627:  * Render a schematic offline mini-map showing:
13628:  *   - 30° graticule + equator + prime meridian
13629:  *   - every UTM zone boundary (6°), with the current zone highlighted
13630:  *   - MGRS latitude band boundaries, with the current band highlighted
13631:  *   - a marker at the point
13632:  * Works fully offline (no map tiles). Equirectangular projection, 360×180.
13633:  */
13634: function renderOfflineMiniMap(lat, lon){
13635:   const root = document.getElementById("miniMap");
13636:   if (!root) return;
13637: 
13638:   const W = 360, H = 180;              // 1 unit = 1 degree
13639:   const px = lon + 180;                // plate carrée x
13640:   const py = 90 - lat;                 // plate carrée y (top = +90, bottom = -90)
13641: 
13642:   let utm = null;
13643:   try { utm = latLonToUTM(lat, lon); } catch(_){}
13644:   const band = latitudeBand(lat);
13645:   const bandStart = band ? MGRS_BAND_LAT[band] : null;
13646:   const bandH = band === "X" ? 12 : 8;
13647: 
13648:   // Layers
13649:   let s = "";
13650:   s += `<rect width="${W}" height="${H}" fill="var(--mm-sea,#0e2640)"/>`;
13651: 
13652:   // Graticule 30°
13653:   for (let ln = -150; ln <= 150; ln += 30){
13654:     const x = ln + 180;
13655:     s += `<line x1="${x}" y1="0" x2="${x}" y2="${H}" stroke="var(--mm-grat,#1d3a5c)" stroke-width="0.3"/>`;
13656:   }
13657:   for (let lt = -60; lt <= 60; lt += 30){
13658:     const y = 90 - lt;
13659:     s += `<line x1="0" y1="${y}" x2="${W}" y2="${y}" stroke="var(--mm-grat,#1d3a5c)" stroke-width="0.3"/>`;
13660:   }
13661: 
13662:   // Equator + prime meridian (bolder)
13663:   s += `<line x1="0" y1="90" x2="${W}" y2="90" stroke="var(--mm-axis,#3f6a9a)" stroke-width="0.6"/>`;
13664:   s += `<line x1="180" y1="0" x2="180" y2="${H}" stroke="var(--mm-axis,#3f6a9a)" stroke-width="0.6"/>`;
13665: 
13666:   // UTM zone boundaries (every 6°) — very thin
13667:   for (let z = 1; z < 60; z++){
13668:     const x = (z - 1) * 6 + 6; // right edge of zone z = x where lon = -180 + 6*z
13669:     s += `<line x1="${x}" y1="10" x2="${x}" y2="${H - 10}" stroke="var(--mm-zone,#234a72)" stroke-width="0.25" stroke-dasharray="1 1"/>`;
13670:   }
13671: 
13672:   // MGRS band boundaries (horizontal, every 8°) between -80 and +84
13673:   const bandEdges = [-80, -72, -64, -56, -48, -40, -32, -24, -16, -8, 0, 8, 16, 24, 32, 40, 48, 56, 64, 72, 84];
13674:   for (const b of bandEdges){
13675:     const y = 90 - b;
13676:     s += `<line x1="10" y1="${y}" x2="${W - 10}" y2="${y}" stroke="var(--mm-zone,#234a72)" stroke-width="0.25" stroke-dasharray="1 1"/>`;
13677:   }
13678: 
13679:   // UTM validity envelope (80°S..84°N) — faint rectangle
13680:   s += `<rect x="0" y="${90 - 84}" width="${W}" height="${84 + 80}" fill="none" stroke="var(--mm-envelope,#2c5282)" stroke-width="0.5" stroke-dasharray="2 2"/>`;
13681: 
13682:   // Current UTM zone highlight
13683:   if (utm){
13684:     const zx = (utm.zone - 1) * 6; // left edge (in units)
13685:     s += `<rect x="${zx}" y="6" width="6" height="${H - 12}" fill="var(--mm-accent,#f59e0b)" opacity="0.22"/>`;
13686:     s += `<line x1="${zx}" y1="6" x2="${zx}" y2="${H - 6}" stroke="var(--mm-accent,#f59e0b)" stroke-width="0.6"/>`;
13687:     s += `<line x1="${zx + 6}" y1="6" x2="${zx + 6}" y2="${H - 6}" stroke="var(--mm-accent,#f59e0b)" stroke-width="0.6"/>`;
13688:   }
13689: 
13690:   // Current MGRS band highlight
13691:   if (bandStart !== null){
13692:     const y0 = 90 - (bandStart + bandH);
13693:     s += `<rect x="6" y="${y0}" width="${W - 12}" height="${bandH}" fill="var(--mm-accent2,#10b981)" opacity="0.22"/>`;
13694:   }
13695: 
13696:   // Marker: outer halo (white + red ring) + teardrop pin pointing to the
13697:   // exact point. Sized in SVG units (1 unit = 1° on this viewBox = ~0.8-3 px
13698:   // on screen depending on container width), so it's comfortably visible
13699:   // on phone screens while staying proportional on larger layouts.
13700:   s += `<circle cx="${px}" cy="${py}" r="7"   fill="#ffffff" opacity="0.85"/>`;
13701:   s += `<circle cx="${px}" cy="${py}" r="5.2" fill="#ef4444" opacity="0.28"/>`;
13702:   // Teardrop pin: 8-unit-wide shape whose tip sits exactly at (px, py).
13703:   // Path starts at the tip and runs up-left / over the top / down to tip.
13704:   s += `<path d="M ${px} ${py} `
13705:     + `C ${px - 3.8} ${py - 5.5}, ${px - 5.5} ${py - 9}, ${px - 3.5} ${py - 11.5} `
13706:     + `C ${px - 1.3} ${py - 14.2}, ${px + 1.3} ${py - 14.2}, ${px + 3.5} ${py - 11.5} `
13707:     + `C ${px + 5.5} ${py - 9}, ${px + 3.8} ${py - 5.5}, ${px} ${py} Z" `
13708:     + `fill="#ef4444" stroke="#ffffff" stroke-width="0.9" stroke-linejoin="round"/>`;
13709:   // White core dot on the pin head for an extra contrast accent.
13710:   s += `<circle cx="${px}" cy="${py - 10}" r="1.8" fill="#ffffff"/>`;
13711: 
13712:   // Corner labels
13713:   const zoneLbl = utm ? `${utm.zone}${band || ""}` : (band || "—");
13714:   s += `<text x="5" y="11" font-size="7" font-family="ui-monospace,monospace" fill="#c7d8ee">${esc(zoneLbl)}</text>`;
13715:   const ddStr = `${lat.toFixed(4)}, ${lon.toFixed(4)}`;
13716:   s += `<text x="${W - 5}" y="${H - 4}" font-size="6" font-family="ui-monospace,monospace" fill="#c7d8ee" text-anchor="end">${esc(ddStr)}</text>`;
13717: 
13718:   const size = state.mapSize || "small";
13719:   root.innerHTML =
13720:     `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" role="img" aria-label="${esc(t("res.miniMap"))}">${s}</svg>` +
13721:     `<span class="mini-map-offline-banner">${esc(t("net.offline"))}</span>` +
13722:     `<div class="tile-size mm-offline-size">
13723:        <button class="ts-btn ${size === "small" ? "active" : ""}" type="button" data-size="small" aria-label="${esc(t("map.sizeSmall"))}" data-tip="${esc(t("map.sizeSmall"))}">⚬</button>
13724:        <button class="ts-btn ${size === "half"  ? "active" : ""}" type="button" data-size="half"  aria-label="${esc(t("map.sizeHalf"))}"  data-tip="${esc(t("map.sizeHalf"))}">◧</button>
13725:        <button class="ts-btn ${size === "full"  ? "active" : ""}" type="button" data-size="full"  aria-label="${esc(t("map.sizeFull"))}"  data-tip="${esc(t("map.sizeFull"))}">⛶</button>
13726:      </div>`;
13727:   root.querySelectorAll(".ts-btn").forEach(b => {
13728:     b.addEventListener("click", () => setMapSize(b.dataset.size));
13729:   });
13730: }
