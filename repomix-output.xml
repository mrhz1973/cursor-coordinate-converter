16261:   const url = `https://www.google.com/maps?q=${round(r.lat,6)},${round(r.lon,6)}`;
16262:   const modal = document.getElementById("qrModal");
16263:   const svgWrap = document.getElementById("qrSvg");
16264:   const urlEl = document.getElementById("qrUrl");
