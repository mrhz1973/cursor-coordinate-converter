12295: /** Format a metric distance as "X m" or "Y.YY km". */
12296: function fmtDistMetric(meters){
12297:   if (!Number.isFinite(meters)) return "—";
12298:   if (meters < 1000) return Math.round(meters) + " m";
12299:   return (meters / 1000).toFixed(meters < 10000 ? 2 : 1) + " km";
12300: }
12301: 
12302: /** Format an ETA duration (seconds) as "H h M min" or "M min". */
12303: function fmtEta(seconds){
12304:   if (!Number.isFinite(seconds) || seconds <= 0) return "—";
12305:   const h = Math.floor(seconds / 3600);
12306:   const m = Math.round((seconds % 3600) / 60);
12307:   if (h > 0) return h + " h " + (m < 10 ? "0" : "") + m + " min";
12308:   return m + " min";
12309: }
