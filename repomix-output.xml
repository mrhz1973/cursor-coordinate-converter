11259: async function hydrateMapTiles(mapRoot, layerId, layer, zoom, lat, lon){
11260:   if (!mapRoot || !layer) return;
11261:   const online  = isEffectivelyOnline();
11262:   const hints   = state.tilePackHints !== false;
11263:   const tm = mapRoot.querySelector(".tile-map");
11264:   if (tm){
11265:     tm.classList.toggle("tile-hints-on", hints);
11266:   }
11267:   const wraps = [...mapRoot.querySelectorAll(".tile-wrap")];
11268:   const load1 = async (wrap) => {
11269:     const xw = +wrap.dataset.xw, y = +wrap.dataset.y, z = +wrap.dataset.z;
11270:     const tkey  = wrap.dataset.tkey;
11271:     const img   = wrap.querySelector("img.tile");
11272:     const voidE = wrap.querySelector(".tile-void");
11273:     if (!img) return;
11274:     const cleanBlobAttr = () => {
11275:       const u = img.getAttribute("data-blob-url");
11276:       if (u){ try { URL.revokeObjectURL(u); } catch(_){} img.removeAttribute("data-blob-url"); }
11277:     };
11278:     try {
11279:       const blob = await getTileBlobByKey(tkey);
11280:       if (blob){
11281:         cleanBlobAttr();
11282:         const u = URL.createObjectURL(blob);
11283:         img.setAttribute("data-blob-url", u);
11284:         img.src = u;
11285:         wrap.classList.remove("tile-missing", "tile-network", "tile-pending");
11286:         wrap.classList.add("tile-mission");
11287:         if (voidE) voidE.style.display = "none";
11288:         return;
11289:       }
11290:       if (online && !state.forceOffline){
11291:         const url = layer.url(z, xw, y);
11292:         const r   = await fetch(url, { mode: "cors" });
11293:         if (!r.ok) throw 0;
11294:         const b  = await r.blob();
11295:         cleanBlobAttr();
11296:         const u  = URL.createObjectURL(b);
11297:         img.setAttribute("data-blob-url", u);
11298:         img.src = u;
11299:         wrap.classList.remove("tile-missing", "tile-mission", "tile-pending");
11300:         wrap.classList.add("tile-network");
11301:         if (voidE) voidE.style.display = "none";
11302:         return;
11303:       }
11304:     } catch(_){}
11305:     // Offline miss or error
11306:     wrap.classList.add("tile-missing");
11307:     wrap.classList.remove("tile-mission", "tile-network", "tile-pending");
11308:     if (voidE) voidE.style.display = "flex";
11309:   };
11310:   await Promise.all(wraps.map(w => load1(w)));
11311:   monitorTileLoading(mapRoot, lat, lon);
11312: }
