 9067: /** Cap Map size to GEOCODE_CACHE_MAX by dropping oldest entries on overflow. */
 9068: function _cacheSetLimited(map, key, val){
 9069:   if (map.size >= GEOCODE_CACHE_MAX){
 9070:     const firstKey = map.keys().next().value;
 9071:     map.delete(firstKey);
