 6003: /* ========================= SECTION 7: UTM FREE PARSER ========================= */
 6004: function parseUTMFree(str){
 6005:   let s = String(str || "").trim().toUpperCase();
 6006:   if (!s) return null;
 6007:   // Strip leading "UTM" label and verbose keywords
 6008:   s = s.replace(/^UTM[:=\s-]*/,"")
 6009:        .replace(/\b(ZONE|ZONA|EASTING|NORTHING|HEMISPHERE|HEM)\b/g," ")
 6010:        .replace(/\b([ENSW])\s*[:=]\s*/g," ")
 6011:        .replace(/[:=]/g," ")
 6012:        .replace(/,/g," ");
 6013: 
 6014:   // 1) COMPACT form (no spaces): "33T2919524640699"  →  zone 33, band T, E=291952, N=4640699
 6015:   //    We require zone(1-2 digits) + exactly 1 letter + 10..14 digits.
 6016:   //    Easting is always assumed 6 digits (UTM within MGRS grid: 100k–900k);
 6017:   //    the rest is northing. MGRS would have 3 letters so it never matches here.
 6018:   const compact = s.replace(/\s+/g,"").match(/^(\d{1,2})([A-Z])(\d{10,14})$/);
 6019:   if (compact){
 6020:     const zone = parseInt(compact[1],10);
 6021:     const letter = compact[2];
 6022:     const digits = compact[3];
 6023:     const easting  = parseInt(digits.substring(0,6),10);
 6024:     const northing = parseInt(digits.substring(6), 10);
 6025:     const res = makeUTM(zone, letter, easting, northing);
 6026:     if (res) return res;
 6027:   }
 6028: 
 6029:   // 2) TOKEN form with whitespace separators
 6030:   const tokens = s.split(/\s+/).filter(Boolean);
 6031:   if (tokens.length < 3) return null;
 6032: 
 6033:   let zone, letter, eIdx;
 6034:   if (/^\d{1,2}[A-Z]$/.test(tokens[0])){                    // "33T 291952 4640699"
 6035:     zone = parseInt(tokens[0].slice(0,-1),10);
 6036:     letter = tokens[0].slice(-1);
 6037:     eIdx = 1;
 6038:   } else if (/^\d{1,2}$/.test(tokens[0]) && /^[A-Z]$/.test(tokens[1])){  // "33 T 291952 4640699"
 6039:     zone = parseInt(tokens[0],10);
 6040:     letter = tokens[1];
 6041:     eIdx = 2;
 6042:   } else if (/^\d{1,2}[A-Z]\d+$/.test(tokens[0])){          // "33T291952 4640699"
 6043:     const m = tokens[0].match(/^(\d{1,2})([A-Z])(\d+)$/);
 6044:     zone = parseInt(m[1],10);
 6045:     letter = m[2];
 6046:     // First token already contains easting digits; use remaining as northing (or take token[1])
 6047:     if (tokens.length >= 2 && /^\d+(\.\d+)?$/.test(tokens[1])){
 6048:       return makeUTM(zone, letter, parseFloat(m[3]), parseFloatStrict(tokens[1]));
 6049:     }
 6050:     return null;
 6051:   } else {
 6052:     return null;
 6053:   }
 6054:   if (!(zone >= 1 && zone <= 60)) return null;
 6055:   if (tokens.length < eIdx + 2) return null;
 6056: 
 6057:   const easting  = parseFloatStrict(tokens[eIdx]);
 6058:   const northing = parseFloatStrict(tokens[eIdx+1]);
 6059:   return makeUTM(zone, letter, easting, northing);
 6060: }
 6061: 
 6062: // Helper: build UTM object from raw components, null if invalid
 6063: function makeUTM(zone, letter, easting, northing){
 6064:   if (!(zone >= 1 && zone <= 60)) return null;
 6065:   if (!Number.isFinite(easting) || !Number.isFinite(northing)) return null;
 6066:   let hemisphere;
 6067:   if (letter === "N" || letter === "S") hemisphere = letter;
 6068:   else if (LAT_BANDS.includes(letter))  hemisphere = (letter >= "N") ? "N" : "S";
 6069:   else return null;
 6070:   return { zone, hemisphere, band: LAT_BANDS.includes(letter) ? letter : null, easting, northing };
 6071: }
