11676:   function onMove(ev){
11677:     if (!draft || !startPx) return;
11678:     ev.preventDefault();
11679:     const p = getPoint(ev);
11680:     const x1 = Math.min(startPx.x, p.x);
11681:     const y1 = Math.min(startPx.y, p.y);
11682:     const x2 = Math.max(startPx.x, p.x);
11683:     const y2 = Math.max(startPx.y, p.y);
11684:     // Clamp inside tileMap
11685:     const tmW = tileMap.clientWidth, tmH = tileMap.clientHeight;
11686:     const X1 = Math.max(0, Math.min(tmW, x1));
11687:     const Y1 = Math.max(0, Math.min(tmH, y1));
11688:     const X2 = Math.max(0, Math.min(tmW, x2));
11689:     const Y2 = Math.max(0, Math.min(tmH, y2));
11690:     draft.style.left = X1 + "px";
11691:     draft.style.top  = Y1 + "px";
11692:     draft.style.width  = Math.max(0, X2 - X1) + "px";
11693:     draft.style.height = Math.max(0, Y2 - Y1) + "px";
11694: 
11695:     // Compute lat/lon bbox live for the tooltip
11696:     const nw = tileMapPxToLatLon(root, X1, Y1);
11697:     const se = tileMapPxToLatLon(root, X2, Y2);
11698:     const b = {
11699:       n: Math.max(nw.lat, se.lat),
11700:       s: Math.min(nw.lat, se.lat),
11701:       e: Math.max(nw.lon, se.lon),
11702:       w: Math.min(nw.lon, se.lon)
11703:     };
11704:     const info = computeBboxTip(b);
11705:     if (info){
11706:       tip.className = "bbox-live-tip " + info.cls;
11707:       tip.innerHTML = `<span class="tip-line">${info.line1}</span>` +
11708:                       `<span class="tip-line">${info.line2}</span>` +
11709:                       (info.tooBig ? `<span class="tip-line">⚠ ${esc(t("offcache.tipTooBig"))}</span>` : "") +
11710:                       (info.tooSmall ? `<span class="tip-line">⚠ ${esc(t("offcache.tipTooSmall"))}</span>` : "");
11711:       tip.style.left = (p.clientX) + "px";
11712:       tip.style.top  = (p.clientY) + "px";
11713:     }
11714:   }
11715: 
11716:   function onUp(ev){
11717:     if (typeof tileMap._bboxCleanup === "function"){
11718:       try { tileMap._bboxCleanup(); } catch(_){}
11719:       tileMap._bboxCleanup = null;
11720:     } else {
11721:       window.removeEventListener("mousemove", onMove);
11722:       window.removeEventListener("mouseup", onUp);
11723:       window.removeEventListener("touchmove", onMove);
11724:       window.removeEventListener("touchend",  onUp);
11725:       window.removeEventListener("touchcancel", onUp);
11726:     }
11727:     if (!startPx || !draft){ endBboxSelection(); return; }
11728:     const rect = {
11729:       x1: parseFloat(draft.style.left) || 0,
11730:       y1: parseFloat(draft.style.top)  || 0,
11731:       w:  parseFloat(draft.style.width)  || 0,
11732:       h:  parseFloat(draft.style.height) || 0
11733:     };
11734:     // Only commit if rectangle is at least 10px on each side
11735:     if (rect.w >= 10 && rect.h >= 10){
11736:       const nw = tileMapPxToLatLon(root, rect.x1, rect.y1);
11737:       const se = tileMapPxToLatLon(root, rect.x1 + rect.w, rect.y1 + rect.h);
11738:       const b = {
11739:         n: Math.max(nw.lat, se.lat),
11740:         s: Math.min(nw.lat, se.lat),
11741:         e: Math.max(nw.lon, se.lon),
11742:         w: Math.min(nw.lon, se.lon)
11743:       };
11744:       state.bboxSelection = b;
11745:       writeBboxFields(b);
11746:     }
11747:     endBboxSelection();
11748:     // Re-render map so the persistent overlay appears in .tile-layer
11749:     if (state.lastPoint){
11750:       renderTileMap(state.lastPoint.lat, state.lastPoint.lon, state.mapZoom || 11);
11751:     }
11752:   }
11753: 
11754:   tileMap.addEventListener("mousedown", onDown);
11755:   tileMap.addEventListener("touchstart", onDown, { passive: false });
11756: }
