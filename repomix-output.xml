12588: function buildCsvFromTrack(){
12589:   ensureTrackState();
12590:   const pts = state.track.points;
12591:   if (!pts.length) return null;
12592:   // Leading comment lines carry the export DTG / ISO timestamp. Popular
12593:   // CSV tools (LibreOffice, Excel with Text Import Wizard, pandas with
12594:   // comment="#") ignore lines starting with "#", so the header remains
12595:   // machine-readable without manual cleanup.
12596:   const nowDate = new Date();
12597:   const dtg = formatDTG(nowDate, "Z", { short: false });
12598:   const iso = nowDate.toISOString();
12599:   const rows = [
12600:     `# generated: ${iso}`,
12601:     `# dtg: ${dtg}`,
12602:     `# creator: Convertitore Coordinate`,
12603:     "idx,name,lat,lon,mgrs"
12604:   ];
12605:   pts.forEach((p, i) => {
12606:     let mgrs = "";
12607:     try { mgrs = latLonToMGRS(p.lat, p.lon, 5); } catch(_){}
12608:     const nm = (p.name || "").replace(/"/g, '""');
12609:     rows.push(`${i+1},"${nm}",${round(p.lat,7)},${round(p.lon,7)},"${mgrs}"`);
12610:   });
12611:   return rows.join("\n");
12612: }
