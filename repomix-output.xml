 6288: function utmToMGRS(utm, lat, precision){
 6289:   precision = Math.max(0, Math.min(5, precision == null ? 5 : precision));
 6290:   const band = latitudeBand(lat);
 6291:   if (!band) throw new ErrI18n("err.outRange");
 6292:   const setIdx = (utm.zone - 1) % 3;
 6293:   const colIdx = Math.floor(utm.easting / 100000) - 1;
 6294:   if (colIdx < 0 || colIdx > 7) throw new ErrI18n("err.outRange");
 6295:   const colLetter = MGRS_COL_SETS[setIdx][colIdx];
 6296:   const rowSet = (utm.zone % 2 === 1) ? MGRS_ROW_ODD : MGRS_ROW_EVEN;
 6297:   const rowIdx = Math.floor(utm.northing / 100000) % 20;
 6298:   const rowLetter = rowSet[rowIdx];
 6299:   const eRel = Math.floor(utm.easting  % 100000);
 6300:   const nRel = Math.floor(utm.northing % 100000);
 6301:   if (precision === 0){
 6302:     return utm.zone + band + " " + colLetter + rowLetter;
 6303:   }
 6304:   const div = Math.pow(10, 5 - precision);
 6305:   const eStr = pad(Math.floor(eRel / div), precision);
 6306:   const nStr = pad(Math.floor(nRel / div), precision);
 6307:   return utm.zone + band + " " + colLetter + rowLetter + " " + eStr + " " + nStr;
 6308: }
