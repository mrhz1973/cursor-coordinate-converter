15562: /**
15563:  * Watches the #miniMap container and re-renders the current point when the
15564:  * width changes by more than a trivial amount. Uses a short debounce so that
15565:  * intermediate sizes during orientation animations don't cause a render storm.
15566:  * Falls back to "do nothing" on browsers without ResizeObserver (very old).
15567:  */
15568: let _miniMapResizeObserver = null;
15569: function installMiniMapResizeObserver(){
15570:   if (_miniMapResizeObserver || typeof ResizeObserver === "undefined") return;
15571:   const root = document.getElementById("miniMap");
15572:   if (!root) return;
15573:   let lastW = root.clientWidth;
15574:   let deb = null;
15575:   _miniMapResizeObserver = new ResizeObserver(() => {
15576:     if (!state.lastPoint) return;
15577:     const w = root.clientWidth;
15578:     if (!w || Math.abs(w - lastW) < 16) return;
15579:     clearTimeout(deb);
15580:     deb = setTimeout(() => {
15581:       lastW = w;
15582:       // Preserve the current pan/zoom/layer so the user doesn't lose their view.
15583:       renderMiniMap(state.lastPoint.lat, state.lastPoint.lon, false);
15584:     }, 140);
15585:   });
15586:   _miniMapResizeObserver.observe(root);
15587:   // Orientation changes on iOS sometimes don't trigger ResizeObserver
15588:   // reliably, so also listen for the explicit event as a belt-and-braces.
15589:   window.addEventListener("orientationchange", () => {
15590:     setTimeout(() => {
15591:       if (state.lastPoint) renderMiniMap(state.lastPoint.lat, state.lastPoint.lon, false);
15592:     }, 250);
15593:   });
15594: }
