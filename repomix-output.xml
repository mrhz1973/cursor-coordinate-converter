  869: }
  870: body.mm-enlarged #offlineTilePanel.dragging{ cursor:grabbing; box-shadow:0 20px 50px rgba(0,0,0,.65) }
  871: body.mm-enlarged #offlineTilePanel.dragging > summary{ cursor:grabbing }
