10126: /**
10127:  * Wire up the DTG card: populate the TZ dropdown, start a once-per-second
10128:  * tick that refreshes the live display and the inline summary chip, parse
10129:  * the user input on every keystroke (with live red/green border), and bind
10130:  * the "use now" + "copy" buttons.
10131:  *
10132:  * The tick is idempotent: calling bindDTG twice will clear and reinstall
10133:  * the interval instead of running two timers.
10134:  */
10135: function bindDTG(){
10136:   const tzSel   = document.getElementById("dtgNowTz");
10137:   const disp    = document.getElementById("dtgNowDisplay");
10138:   const inline  = document.getElementById("dtgNowInline");
10139:   const shortCb = document.getElementById("dtgShortToggle");
10140:   const input   = document.getElementById("dtgInput");
10141:   const parseEl = document.getElementById("dtgParseResult");
10142:   const btnCopy = document.getElementById("btnDtgCopy");
10143:   const btnFill = document.getElementById("btnDtgNowFill");
10144:   if (!tzSel || !disp || !input || !parseEl) return;
10145: 
10146:   // --- Populate the TZ dropdown (once) ---
10147:   if (!tzSel._populated){
10148:     // Order: Zulu first (most common), then positive offsets A..M, then negative N..Y.
10149:     const ordered = [DTG_TZ_MAP.Z]
10150:       .concat(DTG_TZ.filter(e => e.offset > 0).sort((a,b) => a.offset - b.offset))
10151:       .concat(DTG_TZ.filter(e => e.offset < 0).sort((a,b) => b.offset - a.offset));
10152:     const frag = document.createDocumentFragment();
10153:     ordered.forEach(e => {
10154:       const opt = document.createElement("option");
10155:       opt.value = e.l;
10156:       opt.textContent = e.l + " — " + e.name + " (UTC" + dtgOffsetPretty(e.offset) + ")";
10157:       frag.appendChild(opt);
10158:     });
10159:     tzSel.appendChild(frag);
10160:     tzSel.value = state.dtgTz || "Z";
10161:     tzSel._populated = true;
10162:   }
10163: 
10164:   // --- Initial state restoration ---
10165:   if (shortCb) shortCb.checked = !!state.dtgShort;
10166: 
10167:   // --- Live tick (1s) ---
10168:   if (window._dtgTickId) clearInterval(window._dtgTickId);
10169:   const refreshNow = () => {
10170:     const tz = tzSel.value || "Z";
10171:     const short = !!(shortCb && shortCb.checked);
10172:     const s = getCurrentDTG(tz, { short });
10173:     disp.textContent = s || "—";
10174:     // Minimal inline chip in the summary (always Zulu for consistency)
10175:     if (inline) inline.textContent = getCurrentDTG("Z", { short: false });
10176:   };
10177:   refreshNow();
10178:   window._dtgTickId = setInterval(refreshNow, 1000);
10179: 
10180:   // --- TZ change / short toggle: persist + refresh + re-parse input ---
10181:   const onTzOrShortChange = () => {
10182:     state.dtgTz = tzSel.value || "Z";
10183:     state.dtgShort = !!(shortCb && shortCb.checked);
10184:     saveStore();
10185:     refreshNow();
10186:     // If there's a parsed DTG, re-render the derived times because they
10187:     // depend on the currently selected TZ (for "local to tz" display).
10188:     renderDTGParse(input.value);
10189:   };
10190:   tzSel.addEventListener("change", onTzOrShortChange);
10191:   if (shortCb) shortCb.addEventListener("change", onTzOrShortChange);
10192: 
10193:   // --- Parse input (live) ---
10194:   const renderDTGParse = (val) => {
10195:     const s = String(val || "").trim();
10196:     if (!s){
10197:       input.classList.remove("dtg-valid", "dtg-invalid");
10198:       parseEl.hidden = true;
10199:       parseEl.innerHTML = "";
10200:       return;
10201:     }
10202:     const p = parseDTG(s);
10203:     if (!p){
10204:       input.classList.add("dtg-invalid");
10205:       input.classList.remove("dtg-valid");
10206:       parseEl.hidden = false;
10207:       parseEl.innerHTML = `<dt>${esc(t("dtg.invalid"))}</dt><dd>—</dd>`;
10208:       return;
10209:     }
10210:     input.classList.add("dtg-valid");
10211:     input.classList.remove("dtg-invalid");
10212:     const d = p.date;
10213:     // Canonical full + short re-render
10214:     const canonicalFull  = formatDTG(d, p.tzLetter, { short: false });
10215:     const canonicalShort = formatDTG(d, p.tzLetter, { short: true  });
10216:     // Local wall clock (user's browser tz)
10217:     const localStr = d.toLocaleString();
10218:     // Pure UTC ISO (…Z)
10219:     const utcStr   = d.toISOString().replace(/\.\d{3}Z$/, "Z");
10220:     // Day of week in user's locale (long)
10221:     const dow      = d.toLocaleDateString(undefined, { weekday: "long" });
10222:     // Delta from now, in human-readable form
10223:     const deltaMs  = d.getTime() - Date.now();
10224:     const deltaStr = dtgDeltaHuman(deltaMs);
10225:     // Unix ts (seconds)
10226:     const unix     = Math.floor(d.getTime() / 1000);
10227:     parseEl.hidden = false;
10228:     parseEl.innerHTML = `
10229:       <dt>${esc(t("dtg.out.canonical"))}</dt><dd>${esc(canonicalFull)}</dd>
10230:       <dt>${esc(t("dtg.out.shortFmt"))}</dt><dd>${esc(canonicalShort)}</dd>
10231:       <dt>${esc(t("dtg.out.tz"))}</dt><dd>${esc(p.tzLetter + " — " + dtgTzName(p.tzLetter) + " (UTC" + dtgOffsetPretty(dtgTzOffset(p.tzLetter)) + ")")}</dd>
10232:       <dt>${esc(t("dtg.out.utc"))}</dt><dd>${esc(utcStr)}</dd>
10233:       <dt>${esc(t("dtg.out.local"))}</dt><dd>${esc(localStr)}</dd>
10234:       <dt>${esc(t("dtg.out.dow"))}</dt><dd>${esc(dow)}</dd>
10235:       <dt>${esc(t("dtg.out.delta"))}</dt><dd>${esc(deltaStr)}</dd>
10236:       <dt>${esc(t("dtg.out.unix"))}</dt><dd>${esc(String(unix))}</dd>
10237:     `;
10238:   };
10239:   // Expose the renderer so onTzOrShortChange can reuse it via closure.
10240:   const renderer = renderDTGParse;
10241:   // eslint-disable-next-line no-func-assign
10242:   bindDTG._renderParse = renderer;
10243: 
10244:   input.addEventListener("input", (ev) => {
10245:     // Auto-uppercase without moving caret off the end
10246:     const up = ev.target.value.toUpperCase();
10247:     if (up !== ev.target.value) ev.target.value = up;
10248:     renderer(ev.target.value);
10249:   });
10250: 
10251:   // --- Copy current DTG ---
10252:   if (btnCopy){
10253:     btnCopy.addEventListener("click", () => {
10254:       const s = disp.textContent || "";
10255:       if (!s || s === "—") return;
10256:       copyText(s, btnCopy);
10257:     });
10258:   }
10259: 
10260:   // --- Fill input with current DTG in the selected TZ ---
10261:   if (btnFill){
10262:     btnFill.addEventListener("click", () => {
10263:       const tz = tzSel.value || "Z";
10264:       const short = !!(shortCb && shortCb.checked);
10265:       input.value = getCurrentDTG(tz, { short });
10266:       renderer(input.value);
10267:       input.focus();
10268:       input.select();
10269:     });
10270:   }
10271: }
