176: ### Named areas (pre-cache + zoom range)
177: 
178: ```javascript
179: function saveNamedArea(name){
180:   const b = state.bboxSelection || readBboxFields();
181:   const z0raw = parseInt(document.getElementById("pcZ0")?.value, 10);
182:   const z1raw = parseInt(document.getElementById("pcZ1")?.value, 10);
183:   const z0 = Number.isFinite(z0raw) ? Math.max(0, Math.min(19, z0raw)) : null;
184:   const z1 = Number.isFinite(z1raw) ? Math.max(0, Math.min(19, z1raw)) : null;
185:   state.namedAreas.unshift({
186:     id: uidNamed(), name: name.trim().slice(0, 40),
187:     n: b.n, s: b.s, e: b.e, w: b.w,
188:     z0, z1, createdAt: Date.now()
189:   });
190:   if (state.namedAreas.length > 30) state.namedAreas.length = 30;
191:   saveStore();
192: }
193: ```
