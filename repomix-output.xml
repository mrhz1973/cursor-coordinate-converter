14600: function fmtArea(km2, m2, ha){
14601:   // Pick the most human-readable unit depending on size.
14602:   if (km2 >= 1)   return `${km2.toFixed(4)} km² <span class="sub">(${ha.toFixed(2)} ha)</span>`;
14603:   if (ha  >= 1)   return `${ha.toFixed(2)} ha <span class="sub">(${Math.round(m2).toLocaleString()} m²)</span>`;
14604:   return `${Math.round(m2).toLocaleString()} m²`;
14605: }
