 6881:   if (lat < -OLC_LAT_MAX) lat = -OLC_LAT_MAX;
 6882:   if (lat >  OLC_LAT_MAX) lat =  OLC_LAT_MAX;
 6883:   if (lat === OLC_LAT_MAX){
