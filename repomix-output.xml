12614: /** Export the current track as one of: gpx / kml / geojson / csv. */
12615: function exportTrack(kind){
12616:   ensureTrackState();
12617:   const pts = state.track.points;
12618:   if (pts.length < 2 && kind !== "csv"){
12619:     setBadge("error", t("track.noExport"));
12620:     return;
12621:   }
12622:   const ts = new Date().toISOString().replace(/[:.]/g, "-").slice(0, 19);
12623:   if (kind === "gpx"){
12624:     const x = buildGpxTrackFromTrack();
12625:     if (x) downloadBlob(x, "track-" + ts + ".gpx", "application/gpx+xml");
12626:   } else if (kind === "kml"){
12627:     const x = buildKmlFromTrack();
12628:     if (x) downloadBlob(x, "track-" + ts + ".kml", "application/vnd.google-earth.kml+xml");
12629:   } else if (kind === "geojson"){
12630:     const x = buildGeoJSONRoute(pts, !!state.track.closed, "Track");
12631:     if (x) downloadBlob(x, "track-" + ts + ".geojson", "application/geo+json");
12632:   } else if (kind === "csv"){
12633:     const x = buildCsvFromTrack();
12634:     if (x) downloadBlob(x, "track-" + ts + ".csv", "text/csv;charset=utf-8");
12635:   }
12636: }
