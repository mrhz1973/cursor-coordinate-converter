 8384: function encodePermalink(lat, lon, opts){
 8385:   // Always include an explicit DTG (Zulu, full form) in permalinks so a
 8386:   // link shared/pasted elsewhere carries the time it was created.
 8387:   const dtg = (opts && typeof opts.dtg === "string" && opts.dtg)
 8388:     ? opts.dtg
 8389:     : getCurrentDTG("Z", { short: false });
 8390:   return "#ll=" + round(lat,6) + "," + round(lon,6) + "&dtg=" + encodeURIComponent(dtg);
 8391: }
 8392: function readPermalink(){
 8393:   const h = location.hash || "";
 8394:   let m;
 8395:   // Pull an optional DTG from the fragment (shared by both #ll= and #mgrs= links).
 8396:   let dtg = null;
 8397:   const mdtg = h.match(/[#&]dtg=([^&]+)/);
 8398:   if (mdtg){
 8399:     try {
 8400:       const raw = decodeURIComponent(mdtg[1]);
 8401:       const p   = parseDTG(raw);
 8402:       if (p) dtg = { raw, date: p.date, tzLetter: p.tzLetter };
 8403:     } catch(_){}
 8404:   }
 8405:   if ((m = h.match(/[#&]ll=(-?\d+(?:\.\d+)?)[,;](-?\d+(?:\.\d+)?)/)))
 8406:     return { lat: parseFloat(m[1]), lon: parseFloat(m[2]), dtg };
 8407:   if ((m = h.match(/[#&]mgrs=([^&]+)/))){
 8408:     try {
 8409:       const decoded = decodeURIComponent(m[1]);
 8410:       const mg = mgrsToLatLonExt(decoded);
 8411:       return { lat: mg.lat, lon: mg.lon, source: "MGRS", raw: decoded, dtg };
 8412:     } catch(_){}
 8413:   }
 8414:   return null;
 8415: }
 8416: function copyPermalink(){
