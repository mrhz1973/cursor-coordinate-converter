 6743: function sk42GaussKrugerToWgs84(zone, easting, northing){
 6744:   // Inverse Gauss-Krüger (TM, k0=1). Input easting includes zone*1e6 + 500000.
 6745:   const FE = zone*1000000 + 500000;
 6746:   const x = northing;
 6747:   const y = easting - FE;
 6748:   const a = ELL_KRASS1940.a;
 6749:   const e2 = ELL_KRASS1940.e2;
 6750:   const ep2 = e2/(1-e2);
 6751:   const lam0 = (6*(zone-1)) * DEG;
 6752: 
 6753:   // Footpoint latitude
 6754:   const e4 = e2*e2, e6 = e4*e2;
 6755:   const A0 = 1 - e2/4 - 3*e4/64 - 5*e6/256;
 6756:   const B0 = 3*e2/8 + 3*e4/32 + 45*e6/1024;
 6757:   const C0 = 15*e4/256 + 45*e6/1024;
 6758:   const D0 = 35*e6/3072;
 6759:   let mu = x / (a*A0);
 6760:   // series for phi1
 6761:   const e1 = (1 - Math.sqrt(1-e2)) / (1 + Math.sqrt(1-e2));
 6762:   let phi1 = mu
 6763:     + (3*e1/2 - 27*Math.pow(e1,3)/32) * Math.sin(2*mu)
 6764:     + (21*e1*e1/16 - 55*Math.pow(e1,4)/32) * Math.sin(4*mu)
 6765:     + (151*Math.pow(e1,3)/96) * Math.sin(6*mu)
 6766:     + (1097*Math.pow(e1,4)/512) * Math.sin(8*mu);
 6767: 
 6768:   const sin1 = Math.sin(phi1), cos1 = Math.cos(phi1), tan1 = Math.tan(phi1);
 6769:   const N1 = a / Math.sqrt(1 - e2*sin1*sin1);
 6770:   const R1 = a*(1-e2) / Math.pow(1 - e2*sin1*sin1, 1.5);
 6771:   const T1 = tan1*tan1;
 6772:   const C1 = ep2*cos1*cos1;
 6773:   const D = y / N1;
 6774: 
 6775:   const lat = phi1 - (N1*tan1/R1) * (D*D/2 - (5 + 3*T1 + 10*C1 - 4*C1*C1 - 9*ep2)*Math.pow(D,4)/24
 6776:               + (61 + 90*T1 + 298*C1 + 45*T1*T1 - 252*ep2 - 3*C1*C1)*Math.pow(D,6)/720);
 6777:   const lon = lam0 + (D - (1 + 2*T1 + C1)*Math.pow(D,3)/6
 6778:               + (5 - 2*C1 + 28*T1 - 3*C1*C1 + 8*ep2 + 24*T1*T1)*Math.pow(D,5)/120) / cos1;
