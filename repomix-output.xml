 8428: function bindDragDrop(){
 8429:   const sec = document.getElementById("pasteSection");
 8430:   if (!sec) return;
 8431:   let depth = 0;
 8432:   const stop = (ev) => { ev.preventDefault(); ev.stopPropagation(); };
 8433:   sec.addEventListener("dragenter", (ev) => { stop(ev); depth++; sec.classList.add("dragover"); });
 8434:   sec.addEventListener("dragover",  stop);
 8435:   sec.addEventListener("dragleave", (ev) => { stop(ev); depth--; if (depth <= 0){ depth = 0; sec.classList.remove("dragover"); } });
 8436:   sec.addEventListener("drop", (ev) => {
 8437:     stop(ev); depth = 0; sec.classList.remove("dragover");
 8438:     const files = ev.dataTransfer && ev.dataTransfer.files;
 8439:     if (files && files.length){
 8440:       const f = files[0];
 8441:       if (/\.(gpx|kml|geojson|json|csv|txt)$/i.test(f.name)){
 8442:         importFileIntoBatch(f);
 8443:       } else {
 8444:         const reader = new FileReader();
 8445:         reader.onload = () => {
 8446:           document.getElementById("pasteInput").value = String(reader.result || "").trim().slice(0, 10000);
 8447:           doPasteDetect();
 8448:         };
 8449:         reader.readAsText(f);
 8450:       }
 8451:     } else if (ev.dataTransfer && ev.dataTransfer.getData("text")){
 8452:       document.getElementById("pasteInput").value = ev.dataTransfer.getData("text");
 8453:       doPasteDetect();
 8454:     }
 8455:   });
 8456:   // Prevent the browser from opening files dropped outside of the section
 8457:   window.addEventListener("dragover", (e) => e.preventDefault(), false);
 8458:   window.addEventListener("drop",     (e) => e.preventDefault(), false);
 8459: }
