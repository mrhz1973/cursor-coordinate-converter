 6450: /**
 6451:  * WGS84 lat/lon → Gauss-Boaga (ROMA40).
 6452:  * Seleziona Fuso Ovest (CM 9°, FE 1500000) se la longitudine ROMA40 < 12°,
 6453:  * altrimenti Fuso Est (CM 15°, FE 2520000). Ritorna anche lat/lon Roma40
 6454:  * per uso in altri formati.
 6455:  */
 6456: function wgs84ToGaussBoaga(lat, lon){
 6457:   const r = wgs84ToRoma40(lat, lon);
 6458:   const fuso = r.lon < 12 ? "W" : "E";
 6459:   const cm   = fuso === "W" ? 9  : 15;
 6460:   const fe   = fuso === "W" ? 1500000 : 2520000;
 6461:   const p = tmForwardGeneric(r.lat, r.lon, ELL_HAYFORD, 0.9996, cm, fe, 0);
 6462:   return {
 6463:     fuso,
 6464:     easting:  p.easting,
 6465:     northing: p.northing,
 6466:     latRoma40: r.lat,
 6467:     lonRoma40: r.lon,
 6468:     cm, fe
 6469:   };
 6470: }
