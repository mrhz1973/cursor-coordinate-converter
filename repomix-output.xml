11624: /** Install mousedown/move/up (+ touch equivalents) handlers that draw the
11625:  *  draft rectangle and, on release, commit the selection to state. */
11626: function attachBboxDrawHandlers(tileMap){
11627:   if (tileMap._bboxHandlersInstalled) return;
11628:   tileMap._bboxHandlersInstalled = true;
11629:   const root = document.getElementById("miniMap");
11630:   let startPx = null, draft = null, tip = null;
11631: 
11632:   function getPoint(ev){
11633:     const r = tileMap.getBoundingClientRect();
11634:     const tch = ev.touches && ev.touches[0];
11635:     const cx = tch ? tch.clientX : ev.clientX;
11636:     const cy = tch ? tch.clientY : ev.clientY;
11637:     return { x: cx - r.left, y: cy - r.top, clientX: cx, clientY: cy };
11638:   }
11639: 
11640:   function onDown(ev){
11641:     if (!state._bboxSelecting) return;
11642:     ev.preventDefault();
11643:     ev.stopPropagation();
11644:     // Clean up any dangling listeners from a previous interrupted session.
11645:     if (typeof tileMap._bboxCleanup === "function"){
11646:       try { tileMap._bboxCleanup(); } catch(_){}
11647:       tileMap._bboxCleanup = null;
11648:     }
11649:     const p = getPoint(ev);
11650:     startPx = p;
11651:     draft = document.createElement("div");
11652:     draft.className = "bbox-draft";
11653:     draft.style.left = p.x + "px";
11654:     draft.style.top  = p.y + "px";
11655:     draft.style.width = "0px";
11656:     draft.style.height = "0px";
11657:     tileMap.appendChild(draft);
11658:     tip = document.createElement("div");
11659:     tip.className = "bbox-live-tip";
11660:     document.body.appendChild(tip);
11661:     window.addEventListener("mousemove", onMove, { passive: false });
11662:     window.addEventListener("mouseup", onUp, { passive: false });
11663:     window.addEventListener("touchmove", onMove, { passive: false });
11664:     window.addEventListener("touchend",  onUp,   { passive: false });
11665:     window.addEventListener("touchcancel", onUp, { passive: false });
11666:     tileMap._bboxCleanup = () => {
11667:       window.removeEventListener("mousemove", onMove);
11668:       window.removeEventListener("mouseup", onUp);
11669:       window.removeEventListener("touchmove", onMove);
11670:       window.removeEventListener("touchend", onUp);
11671:       window.removeEventListener("touchcancel", onUp);
11672:       startPx = null;
11673:     };
