 8419:   // Build URL without the existing hash; falls back gracefully when opened via file://
 8420:   const base = (location.href || "").split("#")[0];
 8421:   const hash = encodePermalink(r.lat, r.lon);
 8422:   const url  = base + hash;
 8423:   copyText(url, document.getElementById("btnCopyLink"));
 8424:   try { history.replaceState(null, "", hash); } catch(_){}
 8425: }
