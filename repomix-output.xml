 7135: function haversine(lat1, lon1, lat2, lon2){
 7136:   const R = 6371008.8;
 7137:   const p1 = lat1 * DEG, p2 = lat2 * DEG;
 7138:   const dp = (lat2 - lat1) * DEG, dl = (lon2 - lon1) * DEG;
 7139:   const h = Math.sin(dp/2)**2 + Math.cos(p1)*Math.cos(p2)*Math.sin(dl/2)**2;
 7140:   const distance = 2*R*Math.asin(Math.sqrt(h));
 7141:   const y = Math.sin(dl)*Math.cos(p2);
 7142:   const x = Math.cos(p1)*Math.sin(p2) - Math.sin(p1)*Math.cos(p2)*Math.cos(dl);
 7143:   const br = Math.atan2(y, x) * RAD;
 7144:   return {
 7145:     distance,
 7146:     initialBearing: (br + 360) % 360,
 7147:     finalBearing: (br + 360) % 360,
 7148:     method: "Haversine (fallback)"
 7149:   };
 7150: }
