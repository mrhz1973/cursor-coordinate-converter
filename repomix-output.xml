 7100: function routeDistance(pts, closed){
 7101:   if (!pts || pts.length < 2) return 0;
 7102:   let total = 0;
 7103:   const n = pts.length;
 7104:   const end = closed ? n : n - 1;
 7105:   for (let i = 0; i < end; i++){
 7106:     const p1 = pts[i];
 7107:     const p2 = pts[(i + 1) % n];
 7108:     total += vincentyInverse(p1.lat, p1.lon, p2.lat, p2.lon).distance;
 7109:   }
 7110:   return total;
 7111: }
