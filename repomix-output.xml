10930: async function fetchEsriWorldImageryDate(lat, lon, zoom){
10931:   const key = `${lat.toFixed(4)},${lon.toFixed(4)}:z${zoom}`;
10932:   if (imageryDateCache.has(key)) return imageryDateCache.get(key);
10933: 
10934:   const base = "https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/identify";
10935:   const delta = 0.02; // mapExtent hint for identify; not strict
10936:   const mapExtent = `${(lon-delta).toFixed(6)},${(lat-delta).toFixed(6)},${(lon+delta).toFixed(6)},${(lat+delta).toFixed(6)}`;
10937:   const params = new URLSearchParams({
10938:     f: "json",
10939:     geometry: `${lon.toFixed(6)},${lat.toFixed(6)}`,
10940:     geometryType: "esriGeometryPoint",
10941:     sr: "4326",
10942:     layers: "all",
10943:     tolerance: "2",
10944:     mapExtent,
10945:     imageDisplay: "800,600,96",
10946:     returnGeometry: "false"
10947:   });
10948:   const url = `${base}?${params.toString()}`;
10949: 
10950:   if (_imageryDateCtl) _imageryDateCtl.abort();
10951:   _imageryDateCtl = new AbortController();
10952:   const to = setTimeout(() => _imageryDateCtl.abort(), 6000);
10953:   try {
10954:     const r = await fetch(url, { mode:"cors", signal: _imageryDateCtl.signal });
10955:     if (!r.ok) { imageryDateCache.set(key, null); return null; }
10956:     const j = await r.json();
10957:     const res = Array.isArray(j && j.results) ? j.results : [];
10958:     const first = res[0];
10959:     const d = pickEsriDateAttr(first && first.attributes);
10960:     const out = d ? fmtISODateUTC(d) : null;
10961:     imageryDateCache.set(key, out);
10962:     return out;
10963:   } catch(_){
10964:     imageryDateCache.set(key, null);
10965:     return null;
10966:   } finally {
10967:     clearTimeout(to);
10968:   }
10969: }
