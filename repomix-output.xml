 7980: function buildDatumExtras(lat, lon){
 7981:   try {
 7982:     const nad27 = wgs84ToNAD27(lat, lon);
 7983:     const nad83 = wgs84ToNAD83(lat, lon);
 7984:     const osgb  = wgs84ToOSGB36(lat, lon);
 7985:     const bng   = wgs84ToBNG(lat, lon).grid;
 7986:     const lv03  = wgs84ToSwissLV03(lat, lon);
 7987:     const lv95  = wgs84ToSwissLV95(lat, lon);
 7988:     const sk42  = wgs84ToSK42(lat, lon);
 7989:     const gk    = wgs84ToSK42GaussKruger(lat, lon);
 7990:     return {
 7991:       NAD27: fmtDD(nad27.lat, nad27.lon).cardinal,
 7992:       NAD83: fmtDD(nad83.lat, nad83.lon).cardinal,
 7993:       OSGB36: fmtDD(osgb.lat, osgb.lon).cardinal,
 7994:       BNG: bng || null,
 7995:       CH1903_LV03: `Y ${Math.round(lv03.Y)} X ${Math.round(lv03.X)}`,
 7996:       CH1903_LV95: `Y ${Math.round(lv95.Y)} X ${Math.round(lv95.X)}`,
 7997:       SK42: fmtDD(sk42.lat, sk42.lon).cardinal,
 7998:       SK42_GK: `Z${gk.zone} E ${Math.round(gk.easting)} N ${Math.round(gk.northing)}`
 7999:     };
 8000:   } catch(_){
 8001:     return null;
 8002:   }
 8003: }
 8004: function gpxDatumExtensions(p){
 8005:   if (!p || !p.datumExtras) return "";
 8006:   const d = p.datumExtras;
 8007:   const lines = [];
 8008:   for (const k of Object.keys(d)){
 8009:     if (d[k] == null) continue;
 8010:     lines.push(`      <${k}>${xmlEsc(d[k])}</${k}>`);
 8011:   }
 8012:   if (!lines.length) return "";
 8013:   return `    <extensions>\n${lines.join("\n")}\n    </extensions>\n`;
 8014: }
 8015: function kmlExtendedData(p){
 8016:   if (!p || !p.datumExtras) return "";
 8017:   const d = p.datumExtras;
 8018:   const items = [];
 8019:   for (const k of Object.keys(d)){
 8020:     if (d[k] == null) continue;
 8021:     items.push(`      <Data name="${xmlEsc(k)}"><value>${xmlEsc(d[k])}</value></Data>`);
 8022:   }
 8023:   if (!items.length) return "";
 8024:   return `    <ExtendedData>\n${items.join("\n")}\n    </ExtendedData>\n`;
