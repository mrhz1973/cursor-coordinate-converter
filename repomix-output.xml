 7153: /**
 7154:  * Vincenty "diretto": dato un punto di partenza (lat1,lon1), una distanza in metri
 7155:  * e un azimuth iniziale in gradi, calcola la destinazione (lat2,lon2) e l'azimuth finale.
 7156:  * Formule di Vincenty 1975 per l'ellissoide WGS84.
 7157:  */
 7158: function vincentyDirect(lat1, lon1, distance, bearing){
 7159:   const a = WGS84.a, f = WGS84.f, b = WGS84.b;
 7160:   const alpha1 = bearing * DEG;
 7161:   const sA = Math.sin(alpha1), cA = Math.cos(alpha1);
 7162:   const tanU1 = (1-f) * Math.tan(lat1 * DEG);
 7163:   const cU1 = 1 / Math.sqrt(1 + tanU1*tanU1);
 7164:   const sU1 = tanU1 * cU1;
 7165:   const sigma1 = Math.atan2(tanU1, cA);
 7166:   const sinAlpha = cU1 * sA;
 7167:   const cosSqAlpha = 1 - sinAlpha*sinAlpha;
 7168:   const uSq = cosSqAlpha * (a*a - b*b) / (b*b);
 7169:   const A = 1 + uSq/16384 * (4096 + uSq*(-768 + uSq*(320 - 175*uSq)));
 7170:   const B = uSq/1024 * (256 + uSq*(-128 + uSq*(74 - 47*uSq)));
 7171: 
 7172:   let sigma = distance / (b * A);
 7173:   let sigmaP, cos2SigM, sSig, cSig, dSig;
 7174:   let iter = 200;
 7175:   do {
 7176:     cos2SigM = Math.cos(2*sigma1 + sigma);
 7177:     sSig = Math.sin(sigma); cSig = Math.cos(sigma);
 7178:     dSig = B*sSig*(cos2SigM + B/4*(cSig*(-1+2*cos2SigM*cos2SigM)
 7179:            - B/6*cos2SigM*(-3+4*sSig*sSig)*(-3+4*cos2SigM*cos2SigM)));
 7180:     sigmaP = sigma;
 7181:     sigma = distance / (b*A) + dSig;
 7182:   } while (Math.abs(sigma - sigmaP) > 1e-12 && --iter > 0);
 7183: 
 7184:   const tmp = sU1*sSig - cU1*cSig*cA;
 7185:   const lat2 = Math.atan2(sU1*cSig + cU1*sSig*cA, (1-f)*Math.sqrt(sinAlpha*sinAlpha + tmp*tmp));
 7186:   const lambda = Math.atan2(sSig*sA, cU1*cSig - sU1*sSig*cA);
 7187:   const C = f/16 * cosSqAlpha * (4 + f*(4 - 3*cosSqAlpha));
 7188:   const L = lambda - (1-C)*f*sinAlpha*(sigma + C*sSig*(cos2SigM + C*cSig*(-1 + 2*cos2SigM*cos2SigM)));
 7189:   const lon2 = lon1 * DEG + L;
 7190:   const finalBearing = Math.atan2(sinAlpha, -tmp);
 7191:   return {
 7192:     lat: lat2 * RAD,
 7193:     lon: ((lon2 * RAD + 540) % 360) - 180,
 7194:     finalBearing: ((finalBearing * RAD) + 360) % 360
 7195:   };
 7196: }
