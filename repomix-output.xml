12538: /** Build an extended-XML GPX <trk> from the current track. */
12539: function buildGpxTrackFromTrack(){
12540:   ensureTrackState();
12541:   const pts = state.track.points;
12542:   if (pts.length < 2) return null;
12543:   const nowDate = new Date();
12544:   const now     = nowDate.toISOString();
12545:   const dtg     = formatDTG(nowDate, "Z", { short: false });
12546:   const seg = pts.map(p => {
12547:     const ext = p.name ? `<name>${esc(p.name)}</name>` : "";
12548:     return `    <trkpt lat="${round(p.lat,7)}" lon="${round(p.lon,7)}">${ext}</trkpt>`;
12549:   }).join("\n");
12550:   const closing = (state.track.closed && pts.length >= 3)
12551:     ? `\n    <trkpt lat="${round(pts[0].lat,7)}" lon="${round(pts[0].lon,7)}"></trkpt>`
12552:     : "";
12553:   return `<?xml version="1.0" encoding="UTF-8"?>
12554: <gpx version="1.1" creator="Convertitore Coordinate" xmlns="http://www.topografix.com/GPX/1/1">
12555: <metadata><time>${now}</time><desc>DTG: ${xmlEsc(dtg)}</desc></metadata>
12556: <trk>
12557:   <name>Track</name>
12558:   <trkseg>
12559: ${seg}${closing}
12560:   </trkseg>
12561: </trk>
12562: </gpx>`;
12563: }
