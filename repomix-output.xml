 8182: function downloadBlob(content, filename, mime){
 8183:   const blob = new Blob([content], { type: mime || "text/plain;charset=utf-8" });
 8184:   const url = URL.createObjectURL(blob);
 8185:   const a = document.createElement("a");
 8186:   a.href = url; a.download = filename;
 8187:   document.body.appendChild(a); a.click();
 8188:   setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);
 8189: }
 8190: function buildSinglePointFromResult(){
 8191:   const r = state.lastResult;
 8192:   if (!r) return null;
 8193:   const desc = [];
 8194:   desc.push("DD: " + fmtDD(r.lat, r.lon).cardinal);
 8195:   try { desc.push("UTM: " + fmtUTM(latLonToUTM(r.lat, r.lon))); } catch(_){}
 8196:   try { desc.push("MGRS: " + latLonToMGRS(r.lat, r.lon, 5)); } catch(_){}
 8197:   return {
 8198:     lat: r.lat, lon: r.lon,
 8199:     name: (r.meta && r.meta.raw) ? String(r.meta.raw).slice(0, 80) : `Point ${round(r.lat,6)}, ${round(r.lon,6)}`,
 8200:     desc: desc.join(" | "),
 8201:     datumExtras: state.exportDatumExtras ? buildDatumExtras(r.lat, r.lon) : null
 8202:   };
 8203: }
 8204: function exportSingle(kind){
