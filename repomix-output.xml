 9320:     mgrsTab = {
 9321:       kind: "MGRS", label: t("res.mgrs"), copyText: "",
 9322:       body: `<div class="line sub">${esc(t("res.outOfRange"))}</div>`
 9323:     };
 9324:   }
 9325:   try {
 9326:     const u = latLonToUTM(lat, lon);
 9327:     utmTab = {
 9328:       kind: "UTM",
 9329:       label: t("res.utm"),
