 8664: /* ========================= SECTION 14K: DTG (Date-Time Group NATO) =========================
 8665:  *
 8666:  * DTG format:   DDHHMMZMMMYY   (e.g. 211630ZAPR26)
 8667:  *   DD  = day of month (01-31)
 8668:  *   HH  = hour         (00-23)
 8669:  *   MM  = minute       (00-59)
 8670:  *   Z   = single letter time zone, NATO table (Z=UTC, J skipped)
 8671:  *   MMM = 3-letter English month name (JAN..DEC)
 8672:  *   YY  = last two digits of year
 8673:  *
 8674:  * The time zone letter determines how the wall-clock part of the DTG maps
 8675:  * to an absolute instant (Date): a DTG is a wall-clock time inside the tz,
 8676:  * so the absolute UTC instant = Date.UTC(wallClock) - offsetHours * 3600e3.
 8677:  *
 8678:  * We also support a "short" form (no month/year): DDHHMMZ, useful inside
 8679:  * a single mission when the month/year are implicit.
 8680:  *
 8681:  * Everything is local-only (no external deps, no network).
 8682:  */
 8683: const DTG_MONTHS = ["JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC"];
 8684: const DTG_TZ = (() => {
 8685:   // NATO phonetic names for each letter (J intentionally missing).
 8686:   const names = {
 8687:     A:"Alfa", B:"Bravo", C:"Charlie", D:"Delta", E:"Echo", F:"Foxtrot",
 8688:     G:"Golf", H:"Hotel", I:"India", K:"Kilo", L:"Lima", M:"Mike",
 8689:     N:"November", O:"Oscar", P:"Papa", Q:"Quebec", R:"Romeo", S:"Sierra",
 8690:     T:"Tango", U:"Uniform", V:"Victor", W:"Whiskey", X:"X-ray", Y:"Yankee",
 8691:     Z:"Zulu"
 8692:   };
 8693:   const out = [];
 8694:   // +1..+9 → A..I (chars 65..73)
 8695:   for (let i = 1; i <= 9; i++)  out.push({ l:String.fromCharCode(64 + i),     offset:i,  name:names[String.fromCharCode(64+i)] });
 8696:   // +10..+12 → K..M (skip J at 74)
 8697:   for (let i = 10; i <= 12; i++) out.push({ l:String.fromCharCode(64 + i + 1), offset:i,  name:names[String.fromCharCode(64+i+1)] });
 8698:   // -1..-12 → N..Y (chars 78..89)
 8699:   for (let i = 1; i <= 12; i++) out.push({ l:String.fromCharCode(77 + i),     offset:-i, name:names[String.fromCharCode(77+i)] });
 8700:   // Zulu = UTC
 8701:   out.push({ l:"Z", offset:0, name:"Zulu" });
 8702:   return out;
 8703: })();
 8704: const DTG_TZ_MAP = DTG_TZ.reduce((m, e) => (m[e.l] = e, m), {});
 8705: 
 8706: /** Offset in hours for a NATO tz letter, or null if unknown (e.g. "J"). */
 8707: function dtgTzOffset(letter){
 8708:   const e = DTG_TZ_MAP[String(letter || "").toUpperCase()];
 8709:   return e ? e.offset : null;
 8710: }
 8711: 
 8712: /** Phonetic name for a NATO tz letter ("A" → "Alfa"), or "" if unknown. */
 8713: function dtgTzName(letter){
 8714:   const e = DTG_TZ_MAP[String(letter || "").toUpperCase()];
 8715:   return e ? e.name : "";
 8716: }
 8717: 
 8718: /** Pretty UTC-offset string like "+02:00" / "-05:00" / "+00:00". */
 8719: function dtgOffsetPretty(offsetHours){
 8720:   if (!Number.isFinite(offsetHours)) return "";
 8721:   const sign = offsetHours >= 0 ? "+" : "-";
 8722:   const h = Math.abs(offsetHours) | 0;
 8723:   return sign + String(h).padStart(2,"0") + ":00";
 8724: }
 8725: 
 8726: /**
 8727:  * Format a Date as a DTG string in the given tz letter.
 8728:  * @param {Date}    date     JS Date (absolute instant in UTC time).
 8729:  * @param {string}  tzLetter NATO letter (e.g. "Z", "B"). Default "Z".
 8730:  * @param {object}  [opts]   { short: true } for the no-month-no-year variant.
 8731:  * @returns {string}         DTG, or "" if inputs are invalid.
 8732:  */
 8733: function formatDTG(date, tzLetter, opts){
 8734:   if (!(date instanceof Date) || Number.isNaN(date.getTime())) return "";
 8735:   const L = String(tzLetter || "Z").toUpperCase();
 8736:   const off = dtgTzOffset(L);
 8737:   if (off === null) return "";
 8738:   const short = !!(opts && opts.short);
 8739:   // Shift the absolute UTC instant by the tz offset so that getUTC* on the
 8740:   // shifted date returns the wall-clock components in that tz.
 8741:   const shifted = new Date(date.getTime() + off * 3600000);
 8742:   const DD  = String(shifted.getUTCDate()).padStart(2, "0");
 8743:   const HH  = String(shifted.getUTCHours()).padStart(2, "0");
 8744:   const MM  = String(shifted.getUTCMinutes()).padStart(2, "0");
 8745:   const MON = DTG_MONTHS[shifted.getUTCMonth()];
 8746:   const YY  = String(shifted.getUTCFullYear() % 100).padStart(2, "0");
 8747:   return short ? (DD + HH + MM + L) : (DD + HH + MM + L + MON + YY);
 8748: }
 8749: 
 8750: /**
 8751:  * Parse a DTG string into { date, tzLetter, short, raw }.
 8752:  * Tolerant of spaces between groups: "21 1630Z APR 26" / "211630Z APR 26"
 8753:  * are normalized to "211630ZAPR26". Returns null when the input doesn't
 8754:  * match the expected shape.
 8755:  *
 8756:  * Two shapes accepted:
 8757:  *   full  : DDHHMMZMMMYY   (e.g. 211630ZAPR26)
 8758:  *   short : DDHHMMZ        (no month/year — uses current month/year in UTC)
 8759:  */
 8760: function parseDTG(str){
 8761:   if (str == null) return null;
 8762:   const raw = String(str);
 8763:   const s = raw.toUpperCase().replace(/\s+/g, "");
 8764:   const reFull  = /^(\d{2})(\d{2})(\d{2})([A-Z])([A-Z]{3})(\d{2})$/;
 8765:   const reShort = /^(\d{2})(\d{2})(\d{2})([A-Z])$/;
 8766:   let m = s.match(reFull);
 8767:   let short = false;
 8768:   let DD, HH, MM, L, MON, YY;
 8769:   if (m){
 8770:     DD = m[1]; HH = m[2]; MM = m[3]; L = m[4]; MON = m[5]; YY = m[6];
 8771:   } else if ((m = s.match(reShort))){
 8772:     DD = m[1]; HH = m[2]; MM = m[3]; L = m[4];
 8773:     const now = new Date();
 8774:     MON = DTG_MONTHS[now.getUTCMonth()];
 8775:     YY  = String(now.getUTCFullYear() % 100).padStart(2, "0");
 8776:     short = true;
 8777:   } else {
 8778:     return null;
 8779:   }
 8780:   if (L === "J") return null;            // J is reserved / ambiguous
 8781:   const off = dtgTzOffset(L);
 8782:   if (off === null) return null;
 8783:   const monIdx = DTG_MONTHS.indexOf(MON);
 8784:   if (monIdx < 0) return null;
 8785:   const day = +DD, hr = +HH, mi = +MM;
 8786:   if (day < 1 || day > 31 || hr > 23 || mi > 59) return null;
 8787:   // 2-digit year policy: 00–69 → 2000–2069, 70–99 → 1970–1999.
 8788:   const yy = +YY;
 8789:   const year = yy >= 70 ? 1900 + yy : 2000 + yy;
 8790:   // Absolute instant: wall-clock in tz → shift back to UTC by offset.
 8791:   const utcMs = Date.UTC(year, monIdx, day, hr, mi, 0) - off * 3600000;
 8792:   const d = new Date(utcMs);
 8793:   if (Number.isNaN(d.getTime())) return null;
 8794:   // Sanity: month/day must round-trip (catches inputs like 31 FEB).
 8795:   const roundTripShifted = new Date(d.getTime() + off * 3600000);
 8796:   if (roundTripShifted.getUTCDate()  !== day ||
 8797:       roundTripShifted.getUTCMonth() !== monIdx){
 8798:     return null;
 8799:   }
 8800:   return { date: d, tzLetter: L, short, raw };
 8801: }
 8802: 
 8803: /** DTG for "now" in the given tz letter (default Zulu). */
 8804: function getCurrentDTG(tzLetter, opts){
 8805:   return formatDTG(new Date(), tzLetter || "Z", opts);
 8806: }
 8807: 
 8808: /** Convenience wrappers. */
 8809: function dtgToUTC(dtgStr){
 8810:   const p = parseDTG(dtgStr);
 8811:   return p ? p.date : null;
 8812: }
 8813: function dtgToLocalTime(dtgStr){
 8814:   const d = dtgToUTC(dtgStr);
 8815:   if (!d) return null;
 8816:   // Return a Date that, when formatted with LOCAL getters, prints the
 8817:   // local wall-clock of the original absolute instant.
 8818:   return d;
 8819: }
