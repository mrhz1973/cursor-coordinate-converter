 8526: function bindHotkeys(){
 8527:   document.addEventListener("keydown", (ev) => {
 8528:     // Esc: priority to closing modal; otherwise blur/clear
 8529:     if (ev.key === "Escape"){
 8530:       // Exit track pick-map mode if active
 8531:       if (state.track && state.track.pickMode){ trackExitPickMode(); ev.preventDefault(); return; }
 8532:       // Close the tools drawer if open
 8533:       const td = document.getElementById("toolsDrawer");
 8534:       if (td && td.classList.contains("open")){ closeToolsDrawer(); ev.preventDefault(); return; }
 8535:       // Cancel an in-progress bbox selection first — it has no visible
 8536:       // modal but does have a sticky banner on the map.
 8537:       if (state._bboxSelecting){ cancelBboxSelection(); ev.preventDefault(); return; }
 8538:       if (state.mapSize && state.mapSize !== "small"){ setMapSize("small"); ev.preventDefault(); return; }
 8539:       const qr = document.getElementById("qrModal");
 8540:       if (qr && qr.classList.contains("open")){ closeQrModal(); ev.preventDefault(); return; }
 8541:       const ov = document.getElementById("helpOverlay");
 8542:       if (ov && ov.classList.contains("open")){ closeHelp(); ev.preventDefault(); return; }
 8543:       if (isTypingInField()){ document.activeElement.blur(); return; }
 8544:       clearForm();
 8545:       return;
 8546:     }
 8547:     if (isTypingInField()) return;
 8548:     const k = ev.key;
 8549:     if (k === "?" || (ev.shiftKey && k === "/")){ ev.preventDefault(); openHelp(); return; }
 8550:     if ((ev.ctrlKey || ev.metaKey) && (k === "l" || k === "L")){
 8551:       ev.preventDefault();
 8552:       const pi = document.getElementById("pasteInput");
 8553:       if (pi){ pi.focus(); pi.select(); }
 8554:       return;
 8555:     }
 8556:     if ((ev.ctrlKey || ev.metaKey) && (k === "g" || k === "G")){
 8557:       ev.preventDefault();
 8558:       if (typeof requestCurrentLocation === "function") requestCurrentLocation();
 8559:       return;
 8560:     }
 8561:     // Ctrl+F: open the geocoding card and focus its input. Most browsers
 8562:     // reserve Ctrl+F for "find in page", so we also honor Alt+F as a
 8563:     // reliable alternative. isTypingInField() already guarded the global
 8564:     // path; inside our own input this hotkey simply re-focuses the field.
 8565:     if ((k === "f" || k === "F") && (ev.ctrlKey || ev.metaKey || ev.altKey) && !ev.shiftKey){
 8566:       ev.preventDefault();
 8567:       focusGeocodeCard();
 8568:       return;
 8569:     }
 8570:     if ((ev.ctrlKey || ev.metaKey) && (k === "k" || k === "K")){
 8571:       ev.preventDefault();
 8572:       const td = document.getElementById("toolsDrawer");
 8573:       if (td && td.classList.contains("open")) closeToolsDrawer();
 8574:       else openToolsDrawer();
 8575:       return;
 8576:     }
 8577:     // DTG shortcuts.
 8578:     //   Ctrl+Shift+T / Alt+Shift+T : insert current DTG into the parser
 8579:     //   Ctrl+T       / Alt+T       : open / focus the DTG card
 8580:     //
 8581:     // Note: most browsers eat Ctrl+T ("new tab") and Ctrl+Shift+T
 8582:     // ("reopen closed tab") before the page sees them, so the Alt
 8583:     // variants are the reliable ones. We still wire Ctrl+… so that
 8584:     // keyboard-remapping users / Linux with the browser shortcuts
 8585:     // disabled still get them.
 8586:     const isT = (k === "t" || k === "T");
