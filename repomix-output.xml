 5633: // Precompute Krüger coefficients (α forward, β inverse) to order 6
 5634: (function(){
 5635:   const n = WGS84.n, n2=n*n, n3=n2*n, n4=n3*n, n5=n4*n, n6=n5*n;
 5636:   WGS84.A = WGS84.a/(1+n) * (1 + n2/4 + n4/64 + n6/256);
 5637:   WGS84.alpha = [
 5638:     n/2 - 2*n2/3 + 5*n3/16 + 41*n4/180 - 127*n5/288 + 7891*n6/37800,
 5639:     13*n2/48 - 3*n3/5 + 557*n4/1440 + 281*n5/630 - 1983433*n6/1935360,
