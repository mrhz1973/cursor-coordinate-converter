 5886: /* ========================= SECTION 6: FREE TEXT PARSER ========================= */
 5887: /**
 5888:  * Parser robusto per Lat/Lon incollato in forma libera.
 5889:  * Accetta:  5°15'34.0"N 4°02'38.1"W  ·  5 15 34 N, 4 02 38 W  ·
 5890:  *           5.259444, -4.043909  ·  N 5 15 34 / W 4 02 38.1  ·
 5891:  *           5°15.5666'N 4°02.635'W  (DDM)  ·  41.9N 12.5E ecc.
 5892:  * Strategia: normalizza simboli → tokenizza → raccoglie emisferi →
 5893:  * determina split lat/lon (pos. emisferi o virgola o metà) →
 5894:  * ogni lato (1 numero = DD, 2 = DDM, 3 = DMS) → applica segno.
 5895:  */
 5896: function parseFreeTextLatLon(input){
 5897:   let s = String(input || "").trim().toUpperCase();
 5898:   if (!s) throw new ErrI18n("err.empty");
 5899: 
 5900:   // Accept Plus Codes (Open Location Code) here too — they're lat/lon at heart.
 5901:   // A full OLC always contains "+" at position 8 and uses a 20-char alphabet,
 5902:   // so it can't be mistaken for a DMS/DDM/DD text.
 5903:   if (looksLikePlusCode(s)){
 5904:     const p = decodePlusCode(s);
 5905:     return { lat: p.lat, lon: p.lon };
 5906:   }
 5907: 
 5908:   // Strip leading textual labels ("LAT", "LATLON", "COORD(S)", "LL", "DD", "DMS", "DDM", "POS")
 5909:   s = s.replace(/^(LAT\/?LON|LATLON|LAT|LONG|LON|COORDS?|COORDINATES?|POS|POSITION|LL|DD|DDM|DMS)[:=\s-]*/,"");
 5910: 
 5911:   // Normalize decorative symbols to spaces
 5912:   s = s.replace(/[°º]/g," ")
 5913:        .replace(/['\u2019\u2032`´]/g," ")
 5914:        .replace(/["\u201C\u201D\u2033]/g," ")
 5915:        .replace(/[;|\\\/]/g," ")
 5916:        .replace(/,/g," , ");
 5917: 
 5918:   // Split attached letters from digits: "5N"→"5 N", "N5"→"N 5"
 5919:   s = s.replace(/([A-Z])(-?\d)/g,"$1 $2").replace(/(\d)([A-Z])/g,"$1 $2");
 5920: 
 5921:   const tokens = s.split(/\s+/).filter(Boolean);
 5922: 
 5923:   // Walk through and separate: numbers, NS marker, EW marker, commas
 5924:   const numbers = [];
 5925:   let nsChar = null, nsPos = -1;
 5926:   let ewChar = null, ewPos = -1;
 5927:   let commaPos = -1;
 5928:   for (const tok of tokens){
 5929:     if (tok === ",") { if (commaPos < 0) commaPos = numbers.length; continue; }
 5930:     if (/^[NS]$/.test(tok)){
 5931:       if (nsChar === null){ nsChar = tok; nsPos = numbers.length; }
 5932:       continue;
 5933:     }
 5934:     if (/^[EW]$/.test(tok)){
 5935:       if (ewChar === null){ ewChar = tok; ewPos = numbers.length; }
 5936:       continue;
 5937:     }
 5938:     if (/^-?\d+(\.\d+)?$/.test(tok)){
 5939:       numbers.push(parseFloat(tok));
 5940:       continue;
 5941:     }
 5942:     // unknown token: ignore
 5943:   }
 5944: 
 5945:   if (numbers.length === 0) throw new ErrI18n("err.parseFailed");
 5946: 
 5947:   // Determine split between lat numbers and lon numbers
 5948:   let split;
 5949:   if (nsPos > 0){
 5950:     // N/S used as suffix after lat numbers
 5951:     split = nsPos;
 5952:   } else if (nsPos === 0 && ewPos > 0){
 5953:     // N/S prefix, E/W appears between lat and lon
 5954:     split = ewPos;
 5955:   } else if (nsPos === 0 && commaPos > 0){
 5956:     split = commaPos;
 5957:   } else if (commaPos > 0){
 5958:     split = commaPos;
 5959:   } else if (ewPos > 0 && ewPos < numbers.length){
 5960:     split = ewPos;
 5961:   } else if (numbers.length % 2 === 0){
 5962:     split = numbers.length / 2;
 5963:   } else {
 5964:     throw new ErrI18n("err.parseFailed");
 5965:   }
 5966: 
 5967:   const latNums = numbers.slice(0, split);
 5968:   const lonNums = numbers.slice(split);
 5969: 
 5970:   if (!latNums.length || !lonNums.length || latNums.length > 3 || lonNums.length > 3)
 5971:     throw new ErrI18n("err.parseFailed");
 5972: 
 5973:   let lat = combineComponents(latNums);
 5974:   let lon = combineComponents(lonNums);
 5975: 
 5976:   if (nsChar === "N") lat = Math.abs(lat);
 5977:   else if (nsChar === "S") lat = -Math.abs(lat);
 5978:   if (ewChar === "E") lon = Math.abs(lon);
 5979:   else if (ewChar === "W") lon = -Math.abs(lon);
 5980: 
 5981:   validateLatLon(lat, lon);
 5982:   return { lat, lon };
 5983: }
 5984: 
 5985: function combineComponents(nums){
 5986:   // nums: [d], [d,m], or [d,m,s]
 5987:   // Sign preserved from first component only
 5988:   const sign = nums[0] < 0 ? -1 : 1;
 5989:   const a = nums.map(Math.abs);
 5990:   let dec;
 5991:   if (a.length === 1) dec = a[0];
 5992:   else if (a.length === 2){
 5993:     if (a[1] < 0 || a[1] >= 60) throw new ErrI18n("err.minutes");
 5994:     dec = a[0] + a[1]/60;
 5995:   } else {
 5996:     if (a[1] < 0 || a[1] >= 60) throw new ErrI18n("err.minutes");
 5997:     if (a[2] < 0 || a[2] >= 60) throw new ErrI18n("err.seconds");
 5998:     dec = a[0] + a[1]/60 + a[2]/3600;
 5999:   }
 6000:   return sign * dec;
 6001: }
