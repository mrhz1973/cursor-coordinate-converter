 8213: function buildBatchPoints(){
 8214:   const root = document.getElementById("batch-results");
 8215:   const rows = root && root.dataset.rows ? JSON.parse(root.dataset.rows) : [];
 8216:   return rows.filter(r => r.ok).map((r, i) => {
 8217:     // Prefer explicit lat/lon stored on the row; fall back to parsing DD string or re-running autoDetect.
 8218:     let lat = (typeof r.lat === "number") ? r.lat : null;
 8219:     let lon = (typeof r.lon === "number") ? r.lon : null;
 8220:     if (lat == null || lon == null){
 8221:       const m = String(r.dd || "").match(/(-?\d+(?:\.\d+)?)°\s*([NS])\s+(-?\d+(?:\.\d+)?)°\s*([EW])/);
 8222:       if (m){
 8223:         lat = parseFloat(m[1]) * (m[2] === "S" ? -1 : 1);
 8224:         lon = parseFloat(m[3]) * (m[4] === "W" ? -1 : 1);
 8225:       } else {
 8226:         try { const d = autoDetect(r.input); lat = d.lat; lon = d.lon; } catch(_){}
 8227:       }
 8228:     }
 8229:     if (lat == null || lon == null) return null;
 8230:     // When a locality is available, use it as the primary name so exported
 8231:     // waypoints in GPX/KML/GeoJSON carry a human-friendly label instead of
 8232:     // the raw index/input string.
 8233:     const name = r.loc ? String(r.loc).slice(0, 80) : `P${i+1}: ${String(r.input).slice(0, 60)}`;
 8234:     const descBits = [`UTM: ${r.utm} | MGRS: ${r.mgrs}`];
 8235:     if (r.loc) descBits.push("📍 " + r.loc);
 8236:     return {
 8237:       lat, lon,
 8238:       name,
 8239:       desc: descBits.join(" · "),
 8240:       datumExtras: state.exportDatumExtras ? buildDatumExtras(lat, lon) : null
 8241:     };
 8242:   }).filter(Boolean);
 8243: }
 8244: function exportBatch(kind){
