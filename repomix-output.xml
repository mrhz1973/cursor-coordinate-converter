 6433: /** Apply a 3-parameter Helmert shift to an ECEF coordinate. */
 6434: function helmertShift(p, s){ return { X: p.X + s.dX, Y: p.Y + s.dY, Z: p.Z + s.dZ }; }
 6435: 
 6436: /** WGS84 lat/lon → ROMA40 (Monte Mario) lat/lon on Hayford. */
 6437: function wgs84ToRoma40(lat, lon){
 6438:   const ecef = geoToECEF(lat, lon, ELL_WGS84);
 6439:   const sh   = helmertShift(ecef, SHIFT_WGS84_TO_ROMA40);
 6440:   return ecefToGeo(sh.X, sh.Y, sh.Z, ELL_HAYFORD);
 6441: }
 6442: 
 6443: /** WGS84 lat/lon → ED50 lat/lon on Hayford. */
 6444: function wgs84ToED50(lat, lon){
 6445:   const ecef = geoToECEF(lat, lon, ELL_WGS84);
 6446:   const sh   = helmertShift(ecef, SHIFT_WGS84_TO_ED50);
 6447:   return ecefToGeo(sh.X, sh.Y, sh.Z, ELL_HAYFORD);
 6448: }
