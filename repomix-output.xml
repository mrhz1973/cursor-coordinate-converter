10995: /**
10996:  * Fetch elevation (in meters above sea level) for a single point using the
10997:  * Open-Meteo elevation endpoint. It's CORS-enabled, free, no key required,
10998:  * and backed by the Copernicus GLO-90 DEM — good enough for a point readout.
10999:  *
11000:  * Returns a number on success, null on any failure. Respects a 6s timeout
11001:  * so a slow network doesn't leave the pill stuck on "…" forever.
11002:  */
11003: async function fetchElevation(lat, lon){
11004:   const key = `${lat.toFixed(4)},${lon.toFixed(4)}`;
11005:   if (elevCache.has(key)) return elevCache.get(key);
11006:   const url = `https://api.open-meteo.com/v1/elevation?latitude=${lat.toFixed(6)}&longitude=${lon.toFixed(6)}`;
11007:   const ctl = new AbortController();
11008:   const to  = setTimeout(() => ctl.abort(), 6000);
11009:   try {
11010:     const r = await fetch(url, { signal: ctl.signal, mode: "cors" });
11011:     if (!r.ok) return null;
11012:     const j = await r.json();
11013:     const arr = j && j.elevation;
11014:     const elev = Array.isArray(arr) ? arr[0] : (typeof arr === "number" ? arr : null);
11015:     if (typeof elev !== "number" || !Number.isFinite(elev)) return null;
11016:     elevCache.set(key, elev);
11017:     return elev;
11018:   } catch(_){
11019:     return null;
11020:   } finally {
11021:     clearTimeout(to);
11022:   }
11023: }
