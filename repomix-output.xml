13820: function markPrimary(){
13821:   // A composite card is "primary" when the user's preferred format matches
13822:   // any of its sub-tabs. In that case the matching tab is also activated
13823:   // so the primary value is visible without an extra click.
13824:   const LATLON_KINDS = ["DD","DDM","DMS"];
13825:   const GRID_KINDS   = ["MGRS","UTM"];
13826:   document.querySelectorAll("#results .result-card").forEach(c => {
13827:     const kind = c.dataset.kind;
13828:     let isPrimary;
13829:     if (kind === "LATLON") isPrimary = LATLON_KINDS.includes(state.primary);
13830:     else if (kind === "GRID") isPrimary = GRID_KINDS.includes(state.primary);
13831:     else isPrimary = (kind === state.primary);
13832:     c.classList.toggle("primary", isPrimary);
13833:     if (isPrimary && (kind === "LATLON" || kind === "GRID")){
13834:       const targetBtn = c.querySelector(`.tab-btn[data-tab="${state.primary}"]`);
13835:       // Only synthesize a click if the tab isn't already active — avoids
13836:       // resaving storage on every render.
13837:       if (targetBtn && !targetBtn.classList.contains("active")) targetBtn.click();
13838:     }
13839:   });
13840: }
