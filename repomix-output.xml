 7113: /**
 7114:  * Signed spherical polygon area using Bevis–Cambareri formula on a sphere
 7115:  * of radius = WGS84 mean radius. Accurate to ~0.3% for typical polygons.
 7116:  * Polygon is implicitly closed (first = last).
 7117:  * @param {Array<{lat:number,lon:number}>} pts at least 3 points
 7118:  * @returns {number} area in m² (always ≥ 0)
 7119:  */
 7120: function sphericalPolygonArea(pts){
 7121:   if (!pts || pts.length < 3) return 0;
 7122:   const R = 6371008.8; // WGS84 mean radius
 7123:   const toRad = Math.PI / 180;
 7124:   let sum = 0;
 7125:   const n = pts.length;
 7126:   for (let i = 0; i < n; i++){
 7127:     const p1 = pts[i];
 7128:     const p2 = pts[(i + 1) % n];
 7129:     sum += (p2.lon - p1.lon) * toRad *
 7130:            (2 + Math.sin(p1.lat * toRad) + Math.sin(p2.lat * toRad));
 7131:   }
 7132:   return Math.abs(sum * R * R / 2);
 7133: }
