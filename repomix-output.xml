11229: async function startPrecacheDownload(opts){
11230:   const { n, s, e, w, z0, z1, layerId, onProgress } = opts;
11231:   const layer = TILE_LAYERS[layerId] || TILE_LAYERS.osm;
11232:   const tiles = collectBboxTiles(n, s, e, w, z0, z1);
11233:   const total = tiles.length;
11234:   if (total > MAX_PRECACHE_TILES) throw new Error("tooMany");
11235:   const ac = new AbortController();
11236:   _precacheAbort = ac;
11237:   const conc   = 6;
11238:   let nextIdx = 0, completed = 0, errs = 0;
11239:   const work = async () => {
11240:     while (!ac.signal.aborted){
11241:       const j = nextIdx++;
11242:       if (j >= tiles.length) return;
11243:       const T = tiles[j];
11244:       try {
11245:         await fetchAndStoreTile(layerId, T.z, T.x, T.y, layer, ac.signal);
11246:       } catch(_){ errs++; }
11247:       completed++;
11248:       onProgress && onProgress({ done: completed, total, err: errs, aborted: ac.signal.aborted });
11249:     }
11250:   };
11251:   const workers = Array.from({ length: conc }, () => work());
11252:   await Promise.all(workers);
11253:   onProgress && onProgress({ done: completed, total, err: errs, aborted: ac.signal.aborted });
11254:   const aborted = ac.signal.aborted;
11255:   _precacheAbort = null;
11256:   return { aborted, done: completed, total, err: errs };
11257: }
