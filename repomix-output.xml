 6276: /* ========================= SECTION 11: MGRS FORWARD / REVERSE ========================= */
 6277: function latitudeBand(lat){
 6278:   if (lat < -80 || lat > 84) return null;
 6279:   if (lat >= 72) return "X";
 6280:   return LAT_BANDS[Math.floor((lat + 80) / 8)];
