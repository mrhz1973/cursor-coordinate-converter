 6472: /* ========================= SECTION 11c: EXTRA DATUMS (NAD27/NAD83/OSGB36/CH1903/SK42) ========================= *
 6473:  * Tutte le funzioni sono offline e deterministic. Accuratezza attesa:
 6474:  *  - NAD27: 3-param (CONUS average) → ~5–25 m tipico (varia per area; non è NTv2)
 6475:  *  - NAD83: 7-param piccolo shift → ~1–2 m (dipende dall'epoca/realizzazione)
 6476:  *  - OSGB36: 7-param Helmert → ~2–10 m (OSGB36<->WGS84 senza OSTN15 grid)
 6477:  *  - CH1903: formula swisstopo (LV03/LV95) → ~1–3 m tipico
 6478:  *  - SK42: 7-param Helmert (appross.) → decine di metri tipico (non griglie locali)
 6479:  *
 6480:  * NOTA: per accuratezza centimetri/metro in UK/CH/USA servono griglie (OSTN/NTv2),
 6481:  * che qui evitiamo per rimanere single-file e zero dipendenze.
 6482:  */
 6483: 
 6484: function ellipsoid(a, invF){
 6485:   const f = 1/invF;
 6486:   const e2 = 2*f - f*f;
 6487:   return { a, f, e2, e: Math.sqrt(e2) };
 6488: }
 6489: const ELL_CLARKE1866 = ellipsoid(6378206.4, 294.9786982);
 6490: const ELL_GRS80      = ellipsoid(6378137.0, 298.257222101);
 6491: const ELL_AIRY1830   = ellipsoid(6377563.396, 299.3249646);
 6492: const ELL_BESSEL1841 = ellipsoid(6377397.155, 299.1528128);
 6493: const ELL_KRASS1940  = ellipsoid(6378245.0, 298.3);
 6494: 
 6495: function arcsecToRad(a){ return (a / 3600) * DEG; }
 6496: 
 6497: /** 7-parameter Helmert (Bursa-Wolf), rotations in arcseconds, scale in ppm.
 6498:  *  Convention: apply to go from source→target ECEF:
 6499:  *    X2 = tx + (1+s)*X1 + (-rz)*Y1 + ( ry)*Z1
 6500:  *    Y2 = ty + ( rz)*X1 + (1+s)*Y1 + (-rx)*Z1
 6501:  *    Z2 = tz + (-ry)*X1 + ( rx)*Y1 + (1+s)*Z1
 6502:  */
 6503: function helmert7ECEF(p, prm){
 6504:   const s = (prm.s || 0) * 1e-6;
 6505:   const rx = arcsecToRad(prm.rX || 0);
 6506:   const ry = arcsecToRad(prm.rY || 0);
 6507:   const rz = arcsecToRad(prm.rZ || 0);
 6508:   const x = p.X, y = p.Y, z = p.Z;
 6509:   return {
 6510:     X: (prm.dX || 0) + (1+s)*x + (-rz)*y + ( ry)*z,
 6511:     Y: (prm.dY || 0) + ( rz)*x + (1+s)*y + (-rx)*z,
 6512:     Z: (prm.dZ || 0) + (-ry)*x + ( rx)*y + (1+s)*z
 6513:   };
 6514: }
 6515: function invertHelmert7(prm){
 6516:   // Small-parameter inverse (good for ppm/arcsec magnitudes).
 6517:   return {
 6518:     dX: -(prm.dX || 0),
 6519:     dY: -(prm.dY || 0),
 6520:     dZ: -(prm.dZ || 0),
 6521:     rX: -(prm.rX || 0),
 6522:     rY: -(prm.rY || 0),
 6523:     rZ: -(prm.rZ || 0),
 6524:     s:  -(prm.s  || 0)
 6525:   };
 6526: }
