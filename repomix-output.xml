 6592: // British National Grid (OSGB36 / TM) → stringa tipo "TQ 12345 67890"
 6593: function osgb36LatLonToEN(latDeg, lonDeg){
 6594:   // Based on OS formulas (Transverse Mercator) for Airy 1830 / OSGB36.
 6595:   const a = ELL_AIRY1830.a, b = a * (1 - ELL_AIRY1830.f);
 6596:   const F0 = 0.9996012717;
 6597:   const lat0 = 49 * DEG, lon0 = -2 * DEG;
 6598:   const N0 = -100000, E0 = 400000;
 6599:   const e2 = ELL_AIRY1830.e2;
 6600:   const n = (a - b) / (a + b);
 6601: 
 6602:   const lat = latDeg * DEG, lon = lonDeg * DEG;
 6603:   const sinLat = Math.sin(lat), cosLat = Math.cos(lat), tanLat = Math.tan(lat);
 6604:   const nu = a * F0 / Math.sqrt(1 - e2 * sinLat*sinLat);
 6605:   const rho = a * F0 * (1 - e2) / Math.pow(1 - e2 * sinLat*sinLat, 1.5);
 6606:   const eta2 = nu / rho - 1;
 6607: 
 6608:   const Ma = (1 + n + (5/4)*n*n + (5/4)*n*n*n) * (lat - lat0);
 6609:   const Mb = (3*n + 3*n*n + (21/8)*n*n*n) * Math.sin(lat - lat0) * Math.cos(lat + lat0);
 6610:   const Mc = ((15/8)*n*n + (15/8)*n*n*n) * Math.sin(2*(lat - lat0)) * Math.cos(2*(lat + lat0));
 6611:   const Md = (35/24)*n*n*n * Math.sin(3*(lat - lat0)) * Math.cos(3*(lat + lat0));
 6612:   const M = b * F0 * (Ma - Mb + Mc - Md);
 6613: 
 6614:   const dLon = lon - lon0;
 6615:   const I = M + N0;
 6616:   const II = (nu/2) * sinLat * cosLat;
 6617:   const III = (nu/24) * sinLat * Math.pow(cosLat,3) * (5 - tanLat*tanLat + 9*eta2);
 6618:   const IIIA = (nu/720) * sinLat * Math.pow(cosLat,5) * (61 - 58*tanLat*tanLat + Math.pow(tanLat,4));
 6619:   const IV = nu * cosLat;
 6620:   const V = (nu/6) * Math.pow(cosLat,3) * (nu/rho - tanLat*tanLat);
 6621:   const VI = (nu/120) * Math.pow(cosLat,5) * (5 - 18*tanLat*tanLat + Math.pow(tanLat,4) + 14*eta2 - 58*tanLat*tanLat*eta2);
 6622: 
 6623:   const N = I + II*dLon*dLon + III*Math.pow(dLon,4) + IIIA*Math.pow(dLon,6);
 6624:   const E = E0 + IV*dLon + V*Math.pow(dLon,3) + VI*Math.pow(dLon,5);
 6625:   return { E, N };
 6626: }
 6627: function enToOsgb36LatLon(E, N){
 6628:   // Inverse TM for OSGB36 (iterative for lat).
 6629:   const a = ELL_AIRY1830.a, b = a * (1 - ELL_AIRY1830.f);
 6630:   const F0 = 0.9996012717;
 6631:   const lat0 = 49 * DEG, lon0 = -2 * DEG;
 6632:   const N0 = -100000, E0 = 400000;
 6633:   const e2 = ELL_AIRY1830.e2;
 6634:   const n = (a - b) / (a + b);
 6635: 
 6636:   let lat = lat0;
 6637:   let M = 0;
 6638:   const tol = 1e-11;
 6639:   do {
 6640:     lat = (N - N0 - M) / (a * F0) + lat;
 6641:     const Ma = (1 + n + (5/4)*n*n + (5/4)*n*n*n) * (lat - lat0);
 6642:     const Mb = (3*n + 3*n*n + (21/8)*n*n*n) * Math.sin(lat - lat0) * Math.cos(lat + lat0);
 6643:     const Mc = ((15/8)*n*n + (15/8)*n*n*n) * Math.sin(2*(lat - lat0)) * Math.cos(2*(lat + lat0));
 6644:     const Md = (35/24)*n*n*n * Math.sin(3*(lat - lat0)) * Math.cos(3*(lat + lat0));
 6645:     M = b * F0 * (Ma - Mb + Mc - Md);
 6646:   } while (Math.abs(N - N0 - M) >= 0.00001); // 0.01 mm
 6647: 
 6648:   const sinLat = Math.sin(lat), cosLat = Math.cos(lat), tanLat = Math.tan(lat);
 6649:   const nu = a * F0 / Math.sqrt(1 - e2 * sinLat*sinLat);
 6650:   const rho = a * F0 * (1 - e2) / Math.pow(1 - e2 * sinLat*sinLat, 1.5);
 6651:   const eta2 = nu / rho - 1;
 6652: 
 6653:   const dE = E - E0;
 6654:   const VII = tanLat / (2*rho*nu);
 6655:   const VIII = tanLat / (24*rho*Math.pow(nu,3)) * (5 + 3*tanLat*tanLat + eta2 - 9*tanLat*tanLat*eta2);
 6656:   const IX = tanLat / (720*rho*Math.pow(nu,5)) * (61 + 90*tanLat*tanLat + 45*Math.pow(tanLat,4));
 6657:   const X = 1/(cosLat*nu);
 6658:   const XI = 1/(6*cosLat*Math.pow(nu,3)) * (nu/rho + 2*tanLat*tanLat);
