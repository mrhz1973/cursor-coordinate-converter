 7943: function formatMapMeasureDistance(meters, unit){
 7944:   const m = Number(meters);
 7945:   if (!Number.isFinite(m)) return "—";
 7946:   const u = String(unit || "m").toLowerCase();
 7947:   if (u === "km"){
 7948:     const v = m / 1000;
 7949:     return (v < 10 ? v.toFixed(3) : v < 100 ? v.toFixed(2) : v.toFixed(1)) + " km";
 7950:   }
 7951:   if (u === "nm"){
 7952:     const v = m / 1852;
 7953:     return (v < 10 ? v.toFixed(3) : v < 100 ? v.toFixed(2) : v.toFixed(1)) + " nm";
 7954:   }
 7955:   if (u === "mi"){
 7956:     const v = m / 1609.344;
 7957:     return (v < 10 ? v.toFixed(3) : v < 100 ? v.toFixed(2) : v.toFixed(1)) + " mi";
 7958:   }
 7959:   if (u === "ft"){
 7960:     const v = m / 0.3048;
 7961:     return (v < 1000 ? Math.round(v) : (v/1000).toFixed(1) + "k") + " ft";
 7962:   }
 7963:   // default meters
 7964:   return (m < 1000 ? Math.round(m) : (m/1000).toFixed(3) + "k") + " m";
 7965: }
 7966: function azimuthTriple(deg, fromWhat, decl, gamma){
 7967:   const d = ((parseFloat(deg) % 360) + 360) % 360;
 7968:   let t, m, g;
 7969:   if (fromWhat === "true"){ t = d; m = t - decl; g = t - gamma; }
 7970:   else if (fromWhat === "mag"){ m = d; t = m + decl; g = t - gamma; }
 7971:   else { g = d; t = g + gamma; m = t - decl; }
 7972:   const fix = (x) => ((x % 360) + 360) % 360;
 7973:   return { trueDeg: fix(t), magDeg: fix(m), gridDeg: fix(g) };
 7974: }
