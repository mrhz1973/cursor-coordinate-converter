 7622: function computePolylinePerimeterMeters(pts, closed){
 7623:   if (!Array.isArray(pts) || pts.length < 2) return 0;
 7624:   let sum = 0;
 7625:   for (let i = 1; i < pts.length; i++){
 7626:     const a = pts[i - 1], b = pts[i];
