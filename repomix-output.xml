 5866:   const od = parseFloatStrict(o.lonD), om = parseFloatStrict(o.lonM);
 5867:   validateDMSParts(ld, lm, undefined, 90, false);
 5868:   validateDMSParts(od, om, undefined, 180, true);
 5869:   const lat = applyHem(ld + lm/60, o.latHem);
 5870:   const lon = applyHem(od + om/60, o.lonHem);
 5871:   validateLatLon(lat, lon);
 5872:   return { lat, lon };
