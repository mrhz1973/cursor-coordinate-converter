 9798:   stopLocationTracking();
 9799:   if (my) my.classList.add("geo-acquiring");
 9800:   if (st){ st.textContent = t("geo.acquiring"); st.className = "ok geo-pending"; }
 9801:   refreshGeolocationBarriers();
 9802:   if (ico) ico.textContent = "⏳";
