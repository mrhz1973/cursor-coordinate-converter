11425: /* ============== BBOX SELECTION ON MAP (helpers) ==============
11426:  *
11427:  * Design notes:
11428:  *   - Drawing happens in pixel space in the .tile-map container (we use a
11429:  *     lightweight <div class="bbox-draft"> that tracks mousemove).
11430:  *   - On mouseup we convert the 4 corner pixels to lat/lon using the
11431:  *     exact same tile math as renderTileMap (origin + tile X/Y helpers)
11432:  *     and store the result in state.bboxSelection.
11433:  *   - Post-commit, the rectangle is redrawn inside .tile-layer so it
11434:  *     pans and zooms together with the map tiles (no extra math needed
11435:  *     to "follow" the map). 4 corner handles live on the overlay and
11436:  *     allow resize; the "X" button on the top-right removes the bbox.
11437:  *   - Pan handlers and bbox handlers both listen to mousedown on the
11438:  *     tile-layer. When .bbox-selecting is set on .tile-map, pan handlers
11439:  *     short-circuit (see attachPanHandlers early-return), and bbox
11440:  *     handlers take over. When bbox mode is off, the opposite happens.
11441:  */
11442: 
11443: /** Read the 4 bbox fields (pcN/pcS/pcE/pcW) as numbers, or null if invalid.
11444:  *  Accepts both "41.18" and "41,18" (Italian/French locale). */
11445: function readBboxFields(){
11446:   const i = id => document.getElementById(id);
11447:   const pf = (v) => parseFloat(String(v == null ? "" : v).replace(",", "."));
11448:   const n = pf(i("pcN")?.value);
11449:   const s = pf(i("pcS")?.value);
11450:   const e = pf(i("pcE")?.value);
11451:   const w = pf(i("pcW")?.value);
11452:   if (!Number.isFinite(n) || !Number.isFinite(s) || !Number.isFinite(e) || !Number.isFinite(w)) return null;
11453:   if (n <= s || w >= e) return null;
11454:   return { n, s, e, w };
11455: }
