 9299: 
 9300:   // ---- Composite card: MGRS + UTM (reticulated coordinates) --------------
 9301:   // MGRS and UTM are two projections of the same underlying point, so
 9302:   // grouping them under one card with a tab switcher keeps related
 9303:   // information together and frees vertical space for the mini-map.
 9304:   let mgrsTab, utmTab;
 9305:   try {
 9306:     const mg1m = latLonToMGRS(lat, lon, 5); // 5+5 = 10 digits → 1 m precision
