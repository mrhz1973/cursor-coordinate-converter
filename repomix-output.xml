 8821: /* ========================= SECTION 14L: GEOCODING (Nominatim + offline fallback) =========================
 8822:  *
 8823:  * Online forward/reverse geocoding via Nominatim (nominatim.openstreetmap.org).
 8824:  * We respect the Nominatim usage policy:
 8825:  *  - Max 1 request per second (enforced by the internal queue).
 8826:  *  - A custom User-Agent-like referrer/header chain is not settable from the
 8827:  *    browser, but we set `Referer` implicitly (the page URL) and include an
 8828:  *    `X-Client` query param so admins can identify our traffic in logs.
 8829:  *  - We expose a "custom endpoint" setting for users who self-host Nominatim
 8830:  *    and want heavy usage without hitting the public server.
 8831:  *
 8832:  * Everything returns safely on failure — the card degrades quietly when
 8833:  * offline or when the service is temporarily flaky. A simple circuit
 8834:  * breaker disables calls for 60s after three consecutive failures.
 8835:  *
 8836:  * Offline fallback: a small haversine-based lookup against an optional
 8837:  * cities dataset stored in IndexedDB. We ship a compact seed of ~40 major
 8838:  * world capitals so the feature is usable even with zero user data; users
 8839:  * who want more can drop a JSON file with {name, lat, lon, country, pop}
 8840:  * entries via the settings panel (parser handles arrays or objects).
 8841:  */
 8842: 
 8843: /* ---- In-memory cache (rounded to ~10 m precision) ---- */
 8844: const geocodeCache = {
 8845:   fwd: new Map(),  // query (normalized) → array of results
 8846:   rev: new Map()   // "lat4,lon4" → { display_name, address }
 8847: };
 8848: const GEOCODE_CACHE_MAX = 200;
 8849: 
 8850: /* ---- Circuit breaker + request queue state ---- */
 8851: const _nominatim = {
 8852:   queue: [],
 8853:   running: false,
 8854:   lastAt: 0,             // timestamp of last request start (ms)
 8855:   minGap: 1100,          // hard-cap at slightly over 1 req/s (usage policy)
 8856:   timeout: 8000,         // per-request timeout
 8857:   failStreak: 0,
 8858:   breakerUntil: 0,       // timestamp after which calls are allowed again
 8859:   hostsContacted: new Set()
 8860: };
 8861: 
 8862: /** Lowercase + collapse spaces; used as cache key for forward geocode. */
 8863: function _normQ(s){
 8864:   return String(s || "").toLowerCase().replace(/\s+/g, " ").trim();
 8865: }
 8866: 
 8867: /** True if the user has geocoding enabled AND we're not inside a circuit-breaker window. */
 8868: function geocodingAllowed(){
 8869:   if (state.opsecStrict) return false;
 8870:   if (!state.geocodeEnabled) return false;
 8871:   if (Date.now() < _nominatim.breakerUntil) return false;
 8872:   return true;
 8873: }
 8874: 
 8875: /** Currently configured endpoint (custom or the public default). */
 8876: function nominatimBase(){
 8877:   const ep = (state.geocodeEndpoint || "").trim();
 8878:   const base = ep || "https://nominatim.openstreetmap.org";
 8879:   // Strip trailing slash for consistent URL building
 8880:   return base.replace(/\/+$/, "");
 8881: }
 8882: 
 8883: /**
 8884:  * Low-level queued fetch against Nominatim. Responsible for:
 8885:  *  - Serializing requests to ≤ 1/sec.
 8886:  *  - Applying the 8s timeout.
 8887:  *  - Automatic retry (up to 2 extra tries) on 429/503/network errors,
 8888:  *    with exponential backoff (1 s, 2 s).
 8889:  *  - Updating the circuit breaker and the "hosts contacted" set.
 8890:  *
 8891:  * Returns parsed JSON or throws on final failure.
 8892:  */
 8893: async function nominatimQuery(path, params){
 8894:   if (!geocodingAllowed()){
 8895:     throw new Error("geo.disabled");
 8896:   }
 8897:   if (!isEffectivelyOnline()){
 8898:     throw new Error("geo.offline");
 8899:   }
 8900:   // Serialize via the queue. Each caller awaits an open slot.
 8901:   await new Promise((resolve) => {
 8902:     _nominatim.queue.push(resolve);
 8903:     _drainNominatimQueue();
 8904:   });
 8905:   const url = new URL(nominatimBase() + path);
 8906:   Object.entries(params || {}).forEach(([k, v]) => {
 8907:     if (v === null || v === undefined || v === "") return;
 8908:     url.searchParams.set(k, String(v));
 8909:   });
 8910:   // Discreet client hint for self-hosted admins; public Nominatim ignores it
 8911:   // but logs it, which is fine (no PII beyond what Referer already carries).
 8912:   url.searchParams.set("X-Client", "CoordinateConverter/1.0");
 8913: 
 8914:   // Track the host for the network-status badge tooltip.
 8915:   try { _nominatim.hostsContacted.add(new URL(url).host); } catch(_){}
 8916:   try { refreshHostsContactedUI(); } catch(_){}
 8917: 
 8918:   const attempts = 3;
 8919:   let lastErr = null;
 8920:   for (let i = 0; i < attempts; i++){
 8921:     const ctl = new AbortController();
 8922:     const to  = setTimeout(() => ctl.abort(), _nominatim.timeout);
 8923:     try {
 8924:       const lang = (state.lang || "it");
 8925:       const r = await fetch(url.toString(), {
 8926:         signal: ctl.signal,
 8927:         mode: "cors",
 8928:         credentials: "omit",
 8929:         headers: { "Accept": "application/json", "Accept-Language": lang }
 8930:       });
 8931:       clearTimeout(to);
 8932:       if (r.status === 429 || r.status === 503){
 8933:         lastErr = new Error("geo.http" + r.status);
 8934:         // Exponential backoff before retrying.
 8935:         await _sleep(1000 * Math.pow(2, i));
 8936:         continue;
 8937:       }
 8938:       if (!r.ok){
 8939:         lastErr = new Error("geo.http" + r.status);
 8940:         break;
 8941:       }
 8942:       const j = await r.json();
 8943:       _nominatim.failStreak = 0;
 8944:       return j;
 8945:     } catch(e){
 8946:       clearTimeout(to);
 8947:       lastErr = e;
 8948:       await _sleep(1000 * Math.pow(2, i));
 8949:     }
 8950:   }
 8951:   // All retries exhausted.
 8952:   _nominatim.failStreak++;
 8953:   if (_nominatim.failStreak >= 3){
 8954:     _nominatim.breakerUntil = Date.now() + 60000;
 8955:     try { showGeocodeBannerTemp(60); } catch(_){}
 8956:   }
 8957:   throw lastErr || new Error("geo.unreachable");
 8958: }
 8959: function _sleep(ms){ return new Promise(r => setTimeout(r, ms)); }
 8960: 
 8961: /** Pop the next resolver when enough time has elapsed since the last call. */
 8962: function _drainNominatimQueue(){
 8963:   if (_nominatim.running) return;
 8964:   const next = _nominatim.queue.shift();
 8965:   if (!next) return;
 8966:   _nominatim.running = true;
 8967:   const wait = Math.max(0, _nominatim.lastAt + _nominatim.minGap - Date.now());
 8968:   setTimeout(() => {
 8969:     _nominatim.lastAt = Date.now();
 8970:     _nominatim.running = false;
 8971:     next();
 8972:     _drainNominatimQueue();
 8973:   }, wait);
 8974: }
 8975: 
 8976: /**
 8977:  * Forward geocoding: turn "Torre di Pisa" into an array of candidate matches
 8978:  * with lat/lon/display_name/bounding_box/type/importance.
 8979:  *
 8980:  * @param {string} q
 8981:  * @param {object} [opts]  { limit, countryCodes, viewbox, bounded }
 8982:  */
 8983: async function geocodeSearch(q, opts){
 8984:   const query = String(q || "").trim();
 8985:   if (!query) return [];
 8986:   const normKey = _normQ(query) + "|" + JSON.stringify(opts || {});
 8987:   if (geocodeCache.fwd.has(normKey)) return geocodeCache.fwd.get(normKey);
 8988:   const params = {
 8989:     q: query,
 8990:     format: "jsonv2",
 8991:     addressdetails: 1,
 8992:     limit: (opts && opts.limit) || 10
 8993:   };
 8994:   if (opts && opts.countryCodes) params.countrycodes = String(opts.countryCodes).toLowerCase();
 8995:   if (opts && opts.viewbox){ params.viewbox = opts.viewbox; if (opts.bounded) params.bounded = 1; }
 8996:   const results = await nominatimQuery("/search", params);
 8997:   const norm = Array.isArray(results) ? results.map(_normalizeForwardHit) : [];
 8998:   _cacheSetLimited(geocodeCache.fwd, normKey, norm);
 8999:   return norm;
 9000: }
 9001: 
 9002: /** Reverse geocoding: lat/lon → { display_name, address, ... }. */
 9003: async function reverseGeocode(lat, lon, opts){
 9004:   if (!Number.isFinite(lat) || !Number.isFinite(lon)) return null;
 9005:   const key = `${lat.toFixed(4)},${lon.toFixed(4)}`;
 9006:   if (!(opts && opts.force) && geocodeCache.rev.has(key))
 9007:     return geocodeCache.rev.get(key);
 9008:   // Try IDB long-term cache first (survives reloads).
 9009:   if (!(opts && opts.force)){
 9010:     try {
 9011:       const saved = await idbGet("geo:rev:" + key);
 9012:       if (saved && saved.display_name){
 9013:         geocodeCache.rev.set(key, saved);
 9014:         return saved;
 9015:       }
 9016:     } catch(_){}
 9017:   }
 9018:   try {
 9019:     const r = await nominatimQuery("/reverse", {
 9020:       lat: lat.toFixed(6),
 9021:       lon: lon.toFixed(6),
 9022:       format: "jsonv2",
 9023:       zoom: (opts && opts.zoom) || 18,
 9024:       addressdetails: 1
 9025:     });
 9026:     const out = {
 9027:       display_name: r.display_name || "",
 9028:       address: r.address || {},
 9029:       lat: parseFloat(r.lat),
 9030:       lon: parseFloat(r.lon)
 9031:     };
 9032:     _cacheSetLimited(geocodeCache.rev, key, out);
 9033:     try { await idbPut("geo:rev:" + key, out); } catch(_){}
 9034:     return out;
 9035:   } catch(e){
 9036:     // Offline / breaker / error — try the local dataset as a degraded answer.
 9037:     const nn = await offlineNearestCity(lat, lon);
 9038:     if (nn){
 9039:       const synthetic = {
 9040:         display_name: nn.name + (nn.country ? ", " + nn.country : "") + " (~" + Math.round(nn.distKm) + " km)",
 9041:         address: { city: nn.name, country: nn.country || "" },
 9042:         lat: nn.lat, lon: nn.lon,
 9043:         _offline: true, _nearest: nn
 9044:       };
 9045:       geocodeCache.rev.set(key, synthetic);
 9046:       return synthetic;
 9047:     }
 9048:     return null;
 9049:   }
 9050: }
