 1167:    * doesn't trap touch gestures; enlarged views override this to "none"
 1168:    * below so 2-axis panning works. */
 1169:   touch-action:pan-y;
 1170: }
 1171: /* Sidebar mini-map: never inherit a fixed pixel height from older renders;
 1172:  * the square is driven purely by width + aspect-ratio (see renderTileMap). */
