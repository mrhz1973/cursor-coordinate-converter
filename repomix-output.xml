14011: /**
14012:  * Build a human-friendly short name from a reverse-geocode payload.
14013:  * Prefers "City (Suburb)" when available, falling back to broader
14014:  * administrative levels (state, country) so there's always *something*.
14015:  */
14016: function favNameFromLocality(loc){
14017:   if (!loc) return "";
14018:   const a = loc.address || {};
14019:   const primary = a.city || a.town || a.village || a.hamlet || a.municipality || a.county || a.state || a.country || "";
14020:   const sub = a.suburb || a.neighbourhood || a.quarter || a.district || "";
14021:   let s = primary || "";
14022:   if (sub && sub !== primary) s += " (" + sub + ")";
14023:   if (!s && loc.display_name){
14024:     // Last resort: keep the first two comma-separated tokens of display_name.
14025:     const parts = String(loc.display_name).split(",").map(x => x.trim()).filter(Boolean);
14026:     s = parts.slice(0, 2).join(", ");
14027:   }
14028:   return s.slice(0, 80);
14029: }
