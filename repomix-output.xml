13190: /**
13191:  * Wheel / trackpad zoom with cursor-anchored re-centering.
13192:  *
13193:  * Behavior:
13194:  *   - A wheel up (deltaY < 0) zooms in; wheel down zooms out.
13195:  *   - One "click" of a classic mouse wheel ≈ one zoom level. Large
13196:  *     trackpad deltas still map to at most ±3 levels per burst to keep
13197:  *     the experience predictable on high-resolution input.
13198:  *   - The geographic point under the cursor stays pinned to the same
13199:  *     pixel after the zoom — i.e. the map zooms toward the mouse, not
13200:  *     toward the current view center. This matches the convention used
13201:  *     by Leaflet/Google Maps.
13202:  *   - Events are collapsed with a short debounce so rapid wheel bursts
13203:  *     produce a single re-render instead of dozens.
13204:  *
13205:  * preventDefault on the wheel stops the page from scrolling while the
13206:  * cursor is over the map, which is the behavior users expect from a
13207:  * dedicated map widget.
13208:  */
13209: function attachWheelZoom(root, lat, lon, zoom, layer){
13210:   const tileMap = root.querySelector(".tile-map");
13211:   if (!tileMap) return;
13212: 
13213:   // Recompute the same view-center tile coords the renderer used, so wheel
13214:   // math stays consistent with the currently displayed frame.
13215:   const vc   = state.viewCenter || { lat, lon };
13216:   const vLat = Math.max(-85.05, Math.min(85.05, vc.lat));
13217:   const vLon = normalizeLon(vc.lon);
13218:   const vtx  = lonToTileX(vLon, zoom);
13219:   const vty  = latToTileY(vLat, zoom);
13220: 
13221:   let wheelAcc = 0;
13222:   let wheelTimer = null;
13223:   let lastCursor = null; // pixel offset from map center at time of event
13224: 
13225:   const flush = () => {
13226:     wheelTimer = null;
13227:     // Convert accumulated deltaY into integer zoom steps. deltaY > 0 on
13228:     // OS X / Windows means "scroll down / zoom out"; we flip the sign.
13229:     const raw = -Math.sign(wheelAcc) * Math.min(3, Math.max(1, Math.ceil(Math.abs(wheelAcc) / 100)));
13230:     wheelAcc = 0;
13231:     if (!raw || !lastCursor) return;
13232: 
13233:     const newZoom = Math.max(2, Math.min(layer.maxZoom, zoom + raw));
13234:     if (newZoom === zoom) return;
13235:     const factor = Math.pow(2, newZoom - zoom);
13236: 
13237:     // Keep the lat/lon that was under the cursor pinned at the same
13238:     // pixel after the zoom. Derivation:
13239:     //   oldTileCursor = vtx + cx/256                (at old zoom)
13240:     //   newTileCursor = factor * oldTileCursor      (tile space doubles per zoom)
13241:     //   newVtx        = newTileCursor - cx/256      (want same screen offset)
13242:     //                 = factor*vtx + (factor-1)*cx/256
13243:     const newVtx = factor * vtx + (factor - 1) * lastCursor.x / 256;
13244:     const newVty = factor * vty + (factor - 1) * lastCursor.y / 256;
13245:     const newLon = normalizeLon(tileX2Lon(newVtx, newZoom));
13246:     const newLat = tileY2Lat(newVty, newZoom);
13247: 
13248:     state.viewCenter = { lat: newLat, lon: newLon };
13249:     state.mapZoom    = newZoom;
13250:     saveStore();
13251:     renderTileMap(lat, lon, newZoom);
13252:   };
13253: 
13254:   tileMap.addEventListener("wheel", (ev) => {
13255:     // Only zoom when the cursor is on the map itself (not over an overlay
13256:     // card that bubbled up). Overlays with pointer-events:none don't fire
13257:     // wheel events, so reaching this handler is already a good signal —
13258:     // but we still want to let native page scroll win on buttons.
13259:     if (ev.target.closest("button, a")) return;
13260:     ev.preventDefault();
13261: 
13262:     const rect = tileMap.getBoundingClientRect();
13263:     lastCursor = {
13264:       x: ev.clientX - rect.left - rect.width  / 2,
13265:       y: ev.clientY - rect.top  - rect.height / 2
13266:     };
13267:     wheelAcc += ev.deltaY;
13268:     // Debounce: collapse rapid burst (typical of trackpads) into a
13269:     // single render. 45 ms feels instant but catches a full flick.
13270:     if (wheelTimer) clearTimeout(wheelTimer);
13271:     wheelTimer = setTimeout(flush, 45);
13272:   }, { passive: false });
13273: }
