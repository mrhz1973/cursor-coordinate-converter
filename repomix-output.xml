10647: /**
10648:  * Pick the appropriate MGRS grid spacing (in meters) for a given zoom level.
10649:  * The goal is to keep roughly 5-15 grid lines visible on screen: too few and
10650:  * it looks empty, too many and the overlay gets noisy. Values follow the
10651:  * standard MGRS precision ladder (100 km / 10 km / 1 km / 100 m / 10 m).
10652:  */
10653: function pickMgrsGridSpacing(zoom){
10654:   if (zoom >= 15) return 100;      // 100 m squares
10655:   if (zoom >= 12) return 1000;     // 1 km squares
10656:   if (zoom >= 9)  return 10000;    // 10 km squares
10657:   return 100000;                   // 100 km squares
10658: }
10659: 
10660: /**
10661:  * Build an SVG <g> with the MGRS / UTM grid overlay for the current view.
10662:  * Lines are computed in the UTM zone of the map center — they will extend
10663:  * a bit outside the zone for visual continuity but are only accurate within
10664:  * ~50 km of the zone's central meridian. 100 km square letters are drawn
10665:  * at cell centers when the chosen spacing is 100 km or finer.
10666:  *
10667:  * All coordinates are returned in *tile-pixel space* relative to (originX,
10668:  * originY) so the SVG can be placed inside the pannable .tile-layer and
10669:  * translated together with the tiles.
10670:  */
10671: function buildMgrsGridSVG(W, H, originX, originY, zoom, centerLat, centerLon){
10672:   const spacing = pickMgrsGridSpacing(zoom);
10673:   let centerUTM;
10674:   try { centerUTM = latLonToUTM(centerLat, centerLon); } catch(_){ return ""; }
10675:   const zone = centerUTM.zone;
10676:   const hem  = centerUTM.hemisphere;
10677: 
10678:   // Determine the visible lat/lon bounding box (viewport corners).
10679:   const tlLat = tileY2Lat(originY / 256, zoom);
10680:   const brLat = tileY2Lat((originY + H) / 256, zoom);
10681:   const tlLon = tileX2Lon(originX / 256, zoom);
10682:   const brLon = tileX2Lon((originX + W) / 256, zoom);
10683:   const latMin = Math.min(tlLat, brLat), latMax = Math.max(tlLat, brLat);
10684:   const lonMin = tlLon, lonMax = brLon;  // longitudes may cross antimeridian
10685: 
10686:   // Project a few sample points around the viewport perimeter onto the
10687:   // center zone's central meridian, then build a bounding box in E/N.
10688:   const samples = [];
10689:   for (let i = 0; i <= 6; i++){
10690:     const t = i / 6;
10691:     samples.push(latLonToUTMForceZone(latMin + t*(latMax-latMin), lonMin, zone));
10692:     samples.push(latLonToUTMForceZone(latMin + t*(latMax-latMin), lonMax, zone));
10693:     samples.push(latLonToUTMForceZone(latMin, lonMin + t*(lonMax-lonMin), zone));
10694:     samples.push(latLonToUTMForceZone(latMax, lonMin + t*(lonMax-lonMin), zone));
10695:   }
10696:   let eMin = Infinity, eMax = -Infinity, nMin = Infinity, nMax = -Infinity;
10697:   for (const s of samples){
10698:     if (s.easting  < eMin) eMin = s.easting;
10699:     if (s.easting  > eMax) eMax = s.easting;
10700:     if (s.northing < nMin) nMin = s.northing;
10701:     if (s.northing > nMax) nMax = s.northing;
10702:   }
10703:   const eStart = Math.floor(eMin / spacing) * spacing;
10704:   const eEnd   = Math.ceil (eMax / spacing) * spacing;
10705:   const nStart = Math.floor(nMin / spacing) * spacing;
10706:   const nEnd   = Math.ceil (nMax / spacing) * spacing;
10707: 
10708:   // Cap the number of lines to avoid catastrophic SVG on degenerate views.
10709:   if ((eEnd - eStart)/spacing > 200 || (nEnd - nStart)/spacing > 200) return "";
10710: 
10711:   const latLonToPx = (la, lo) => {
10712:     const tx = lonToTileX(lo, zoom);
10713:     const ty = latToTileY(Math.max(-85.05, Math.min(85.05, la)), zoom);
10714:     return { x: tx*256 - originX, y: ty*256 - originY };
10715:   };
10716: 
10717:   // Palette and weight depend on "major" 100 km boundaries vs. finer lines.
10718:   const majorStroke = "#fbbf24", minorStroke = "#f59e0b";
10719:   const majorW = 1.3, minorW = 0.6;
10720:   const sampleSteps = 24;  // points per polyline (enough to look smooth)
10721: 
10722:   // Helpers: find where a polyline (array of [x,y]) crosses a target row / col.
10723:   // Used to anchor axis labels at the edge of the visible viewport.
10724:   const crossRow = (pts, yT) => {
10725:     for (let i = 1; i < pts.length; i++){
10726:       const [x1, y1] = pts[i-1], [x2, y2] = pts[i];
10727:       if ((y1 - yT) * (y2 - yT) <= 0 && y1 !== y2){
10728:         const t = (yT - y1) / (y2 - y1);
10729:         return x1 + t * (x2 - x1);
10730:       }
10731:     }
10732:     return null;
10733:   };
10734:   const crossCol = (pts, xT) => {
10735:     for (let i = 1; i < pts.length; i++){
10736:       const [x1, y1] = pts[i-1], [x2, y2] = pts[i];
10737:       if ((x1 - xT) * (x2 - xT) <= 0 && x1 !== x2){
10738:         const t = (xT - x1) / (x2 - x1);
10739:         return y1 + t * (y2 - y1);
10740:       }
10741:     }
10742:     return null;
10743:   };
10744: 
10745:   // Emit numeric labels on each line when we're at a useful zoom (10 km or
10746:   // finer spacing). Labels show the last 5 digits of the easting/northing —
10747:   // i.e. the position inside the current 100 km square — which matches the
10748:   // MGRS convention used by the bottom-of-map readout.
10749:   const showLineLabels = (spacing <= 10000);
10750:   const labelRowY = 34;  // vertical-line labels anchored to this row (below GZD)
10751:   const labelColX = 10;  // horizontal-line labels anchored to this column
10752: 
10753:   let svg = `<g class="mgrs-grid" pointer-events="none">`;
10754: 
10755:   // Vertical lines (fixed easting, varying northing).
10756:   for (let e = eStart; e <= eEnd; e += spacing){
10757:     const major = (Math.round(e) % 100000 === 0);
10758:     const ptsArr = [];
10759:     for (let i = 0; i <= sampleSteps; i++){
10760:       const nn = nStart + (nEnd - nStart) * i / sampleSteps;
10761:       const ll = utmToLatLon(zone, hem, e, nn);
10762:       const p = latLonToPx(ll.lat, ll.lon);
10763:       ptsArr.push([p.x, p.y]);
10764:     }
10765:     const ptsStr = ptsArr.map(p => p[0].toFixed(1) + "," + p[1].toFixed(1)).join(" ");
10766:     svg += `<polyline points="${ptsStr}" fill="none" stroke="${major?majorStroke:minorStroke}" stroke-width="${major?majorW:minorW}" opacity="${major?0.85:0.55}"/>`;
10767:     if (showLineLabels){
10768:       const lx = crossRow(ptsArr, labelRowY);
10769:       // Keep clear of the GZD (≈ x<44 at top) and the top-right controls
10770:       // cluster (zoom ± / size / layer / grid toggle), which occupies up
10771:       // to ~130 px on the right edge at its widest.
10772:       if (lx != null && lx > 46 && lx < W - 130){
10773:         const eMod = ((Math.round(e) % 100000) + 100000) % 100000;
10774:         const txt  = String(eMod).padStart(5, "0");
10775:         svg += `<text x="${lx.toFixed(1)}" y="${labelRowY}" fill="#fde68a" font-size="11" font-weight="700" text-anchor="middle" style="paint-order:stroke;stroke:#1f2937;stroke-width:3px;stroke-linejoin:round">${txt}</text>`;
10776:       }
10777:     }
10778:   }
10779:   // Horizontal lines (fixed northing, varying easting).
10780:   for (let n = nStart; n <= nEnd; n += spacing){
10781:     const major = (Math.round(n) % 100000 === 0);
10782:     const ptsArr = [];
10783:     for (let i = 0; i <= sampleSteps; i++){
10784:       const ee = eStart + (eEnd - eStart) * i / sampleSteps;
10785:       const ll = utmToLatLon(zone, hem, ee, n);
10786:       const p = latLonToPx(ll.lat, ll.lon);
10787:       ptsArr.push([p.x, p.y]);
10788:     }
10789:     const ptsStr = ptsArr.map(p => p[0].toFixed(1) + "," + p[1].toFixed(1)).join(" ");
10790:     svg += `<polyline points="${ptsStr}" fill="none" stroke="${major?majorStroke:minorStroke}" stroke-width="${major?majorW:minorW}" opacity="${major?0.85:0.55}"/>`;
10791:     if (showLineLabels){
10792:       const ly = crossCol(ptsArr, labelColX);
10793:       // Stay below GZD area (y<30) and above the readout pills (~ y > H-70).
10794:       if (ly != null && ly > 52 && ly < H - 70){
10795:         const nMod = ((Math.round(n) % 100000) + 100000) % 100000;
10796:         const txt  = String(nMod).padStart(5, "0");
10797:         svg += `<text x="${labelColX}" y="${ly.toFixed(1)}" fill="#fde68a" font-size="11" font-weight="700" text-anchor="start" dominant-baseline="middle" style="paint-order:stroke;stroke:#1f2937;stroke-width:3px;stroke-linejoin:round">${txt}</text>`;
10798:       }
10799:     }
10800:   }
10801: 
10802:   // 100 km square letter labels at each square center when we're zoomed in
10803:   // enough that the 100 km step is smaller than the viewport.
10804:   const sq = 100000;
10805:   const sqEStart = Math.floor(eStart / sq) * sq;
10806:   const sqNStart = Math.floor(nStart / sq) * sq;
10807:   for (let e = sqEStart; e <= eEnd; e += sq){
10808:     for (let n = sqNStart; n <= nEnd; n += sq){
10809:       const cE = e + sq/2, cN = n + sq/2;
10810:       const ll = utmToLatLon(zone, hem, cE, cN);
10811:       const p = latLonToPx(ll.lat, ll.lon);
10812:       if (p.x < -60 || p.x > W + 60 || p.y < -60 || p.y > H + 60) continue;
10813:       let label = "";
10814:       try {
10815:         const mg = latLonToMGRS(ll.lat, ll.lon, 0); // "33T UM"
10816:         const m = mg.match(/\d+[A-Z]\s*([A-Z]{2})/);
10817:         if (m) label = m[1];
10818:       } catch(_){ continue; }
10819:       if (!label) continue;
10820:       svg += `<text x="${p.x.toFixed(1)}" y="${p.y.toFixed(1)}" fill="#fde68a" font-size="13" font-weight="700" text-anchor="middle" dominant-baseline="middle" style="paint-order:stroke;stroke:#1f2937;stroke-width:3px;stroke-linejoin:round">${label}</text>`;
10821:     }
10822:   }
10823: 
10824:   // GZD label (zone + band) in the upper-left of the viewport.
10825:   const band = latitudeBand(centerLat) || "";
10826:   svg += `<text x="8" y="18" fill="#fde68a" font-size="13" font-weight="800" style="paint-order:stroke;stroke:#1f2937;stroke-width:3px;stroke-linejoin:round">${zone}${band}</text>`;
10827: 
10828:   svg += `</g>`;
10829:   return svg;
