14576: function renderRouteSummary(root, pts, closed){
14577:   const n = pts.length;
14578:   const dist = routeDistance(pts, closed);
14579:   const km = dist / 1000;
14580:   const nmi = dist / 1852;
14581: 
14582:   let areaHtml = "";
14583:   if (closed && n >= 3){
14584:     const area = sphericalPolygonArea(pts);
14585:     const km2 = area / 1e6;
14586:     const ha  = area / 1e4;
14587:     areaHtml = `
14588:       <div class="route-line"><b>${t("route.area")}:</b> ${fmtArea(km2, area, ha)}</div>`;
14589:   } else if (closed && n < 3){
14590:     areaHtml = `<div class="route-line sub">${t("route.areaNeed3")}</div>`;
14591:   }
14592: 
14593:   const distLbl = closed ? t("route.perim") : t("route.dist");
14594:   root.innerHTML = `
14595:     <div class="route-line"><b>${t("route.points")}:</b> ${n}</div>
14596:     <div class="route-line"><b>${distLbl}:</b> ${km.toFixed(3)} km <span class="sub">(${nmi.toFixed(2)} NM · ${Math.round(dist)} m)</span></div>
14597:     ${areaHtml}`;
14598: }
