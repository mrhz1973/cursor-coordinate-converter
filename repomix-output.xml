 7286:       }
 7287:     }
 7288:   }
 7289:   for (n = 1; n <= n_max; n++) {
 7290:     i = n * (n + 1) / 2;
 7291:     i1 = (n - 1) * n / 2;
 7292:     schmidt_quasi_norm[i] = schmidt_quasi_norm[i1] * (2 * n - 1) / n;
