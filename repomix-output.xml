12105: /** Attach drag-to-resize behaviour on one of the 4 corner handles. */
12106: function attachResizeHandle(handle, overlay, tileMap, root){
12107:   const which = handle.dataset.handle; // nw|ne|sw|se
12108: 
12109:   function onDown(ev){
12110:     ev.stopPropagation();
12111:     ev.preventDefault();
12112:     const startClient = { x: (ev.touches ? ev.touches[0].clientX : ev.clientX),
12113:                           y: (ev.touches ? ev.touches[0].clientY : ev.clientY) };
12114:     const b0 = Object.assign({}, state.bboxSelection);
12115:     if (!b0 || !Number.isFinite(b0.n)) return;
12116: 
12117:     function onMove(ev2){
12118:       ev2.preventDefault();
12119:       const cx = ev2.touches ? ev2.touches[0].clientX : ev2.clientX;
12120:       const cy = ev2.touches ? ev2.touches[0].clientY : ev2.clientY;
12121:       const r = tileMap.getBoundingClientRect();
12122:       const px = cx - r.left, py = cy - r.top;
12123:       // Convert the moved corner to lat/lon
12124:       const pt = tileMapPxToLatLon(root, px, py);
12125:       const b = Object.assign({}, b0);
12126:       if (which === "nw"){ b.n = pt.lat; b.w = pt.lon; }
12127:       else if (which === "ne"){ b.n = pt.lat; b.e = pt.lon; }
12128:       else if (which === "sw"){ b.s = pt.lat; b.w = pt.lon; }
12129:       else if (which === "se"){ b.s = pt.lat; b.e = pt.lon; }
12130:       // Normalize so n>s and e>w
12131:       const nn = Math.max(b.n, b.s), ss = Math.min(b.n, b.s);
12132:       const ee = Math.max(b.e, b.w), ww = Math.min(b.e, b.w);
12133:       state.bboxSelection = { n: nn, s: ss, e: ee, w: ww };
12134:       writeBboxFields(state.bboxSelection);
12135:       // Redraw overlay in place without a full map re-render (fast)
12136:       drawBboxOverlay(tileMap);
12137:     }
12138: 
12139:     function onUp(){
12140:       window.removeEventListener("mousemove", onMove);
12141:       window.removeEventListener("mouseup", onUp);
12142:       window.removeEventListener("touchmove", onMove);
12143:       window.removeEventListener("touchend", onUp);
12144:     }
12145: 
12146:     window.addEventListener("mousemove", onMove, { passive: false });
12147:     window.addEventListener("mouseup", onUp);
12148:     window.addEventListener("touchmove", onMove, { passive: false });
12149:     window.addEventListener("touchend", onUp);
12150:   }
12151: 
12152:   handle.addEventListener("mousedown", onDown);
12153:   handle.addEventListener("touchstart", onDown, { passive: false });
12154: }
