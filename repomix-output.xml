14888: /**
14889:  * Refresh the network status badge. The effective state is:
14890:  *   - "forced":  user clicked the badge to simulate offline (orange ring)
14891:  *   - "offline": navigator.onLine === false (red ring)
14892:  *   - "online":  everything OK (green ring, soft pulse)
14893:  * When the state changes, the mini-map is re-rendered so it can swap
14894:  * between OSM tiles and the SVG fallback.
14895:  */
14896: function updateNetStatus(){
14897:   const el = document.getElementById("netStatus");
14898:   if (!el) return;
14899:   const browserOnline = (typeof navigator !== "undefined") ? navigator.onLine : true;
14900:   const forced = !!state.forceOffline;
14901:   el.classList.toggle("online",  browserOnline && !forced);
14902:   el.classList.toggle("offline", !browserOnline);
14903:   el.classList.toggle("forced",  forced);
14904:   const label = el.querySelector(".net-label");
14905:   if (label){
14906:     label.textContent = forced ? t("net.forced")
14907:                        : browserOnline ? t("net.online") : t("net.offline");
14908:   }
14909:   el.setAttribute("data-tip", t("tip.netStatus"));
14910:   // Re-apply the per-session "hosts contacted" annotation so the tooltip
14911:   // always reflects the latest set of external domains we've hit (e.g.
14912:   // nominatim.openstreetmap.org after the first geocoding call).
14913:   try { refreshHostsContactedUI(); } catch(_){}
14914:   // Re-render the map so the tile source can swap between network and cache.
14915:   // Use resetView=false so the user's current pan/view stays where it is:
14916:   // toggling online ↔ offline must NOT re-center on the last converted point.
14917:   // The marker stays at state.lastPoint (passed as lat/lon), while the actual
14918:   // view center comes from state.viewCenter (preserved by skipping the reset).
14919:   if (state.lastPoint){
14920:     renderMiniMap(state.lastPoint.lat, state.lastPoint.lon, false);
14921:   }
14922: }
