12565: function buildKmlFromTrack(){
12566:   ensureTrackState();
12567:   const pts = state.track.points;
12568:   if (pts.length < 2) return null;
12569:   const coords = pts.map(p => `${round(p.lon,7)},${round(p.lat,7)},0`);
12570:   const closed = !!state.track.closed && pts.length >= 3;
12571:   const coordStr = (closed ? coords.concat(coords.slice(0,1)) : coords).join(" ");
12572:   const geom = closed
12573:     ? `<Polygon><outerBoundaryIs><LinearRing><coordinates>${coordStr}</coordinates></LinearRing></outerBoundaryIs></Polygon>`
12574:     : `<LineString><coordinates>${coordStr}</coordinates></LineString>`;
12575:   const waypoints = pts.map(p => `<Placemark><name>${esc(p.name || "")}</name><Point><coordinates>${round(p.lon,7)},${round(p.lat,7)},0</coordinates></Point></Placemark>`).join("\n");
12576:   const dtg = formatDTG(new Date(), "Z", { short: false });
12577:   return `<?xml version="1.0" encoding="UTF-8"?>
12578: <kml xmlns="http://www.opengis.net/kml/2.2">
12579: <Document>
12580:   <name>Track</name>
12581:   <description>DTG: ${xmlEsc(dtg)}</description>
12582:   <Placemark><name>Track</name>${geom}</Placemark>
12583: ${waypoints}
12584: </Document>
