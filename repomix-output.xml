 8159:       properties: { name: routeName || "Route", kind: "polygon" },
 8160:       geometry: { type: "Polygon", coordinates: [ring] }
 8161:     });
 8162:   } else {
 8163:     features.push({
 8164:       type: "Feature",
 8165:       properties: { name: routeName || "Route", kind: "linestring" },
 8166:       geometry: { type: "LineString", coordinates: coords }
 8167:     });
 8168:   }
 8169:   return JSON.stringify({
 8170:     type: "FeatureCollection",
 8171:     metadata: {
 8172:       generated: new Date().toISOString(),
 8173:       dtg: formatDTG(new Date(), "Z", { short: false }),
 8174:       creator: "Convertitore Coordinate",
 8175:       routeName: routeName || null,
 8176:       closed: !!closed
 8177:     },
 8178:     features
 8179:   }, null, 2);
