 9052: /** Normalize a raw Nominatim /search hit into our lightweight shape. */
 9053: function _normalizeForwardHit(h){
 9054:   const bbox = Array.isArray(h.boundingbox) ? h.boundingbox.map(Number) : null;
 9055:   return {
 9056:     lat: parseFloat(h.lat),
