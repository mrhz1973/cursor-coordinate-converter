 9804:     (pos) => {
 9805:       if (my) my.classList.remove("geo-acquiring");
 9806:       if (ico){
 9807:         ico.textContent = "✓";
 9808:         setTimeout(() => { if (ico) ico.textContent = "📍"; }, 850);
 9809:       }
 9810:       if (st){ st.textContent = t("paste.detectedLL"); st.className = "ok"; st.classList.remove("geo-pending"); }
 9811:       const lat = pos.coords.latitude, lon = pos.coords.longitude;
 9812:       if (!Number.isFinite(lat) || !Number.isFinite(lon) || lat < -90 || lat > 90 || lon < -180 || lon > 180){
 9813:         handleGeolocationError({ code: 2 });
 9814:         refreshGeolocationBarriers();
 9815:         return;
 9816:       }
 9817:       const meta = {
 9818:         type: "LatLon",
 9819:         raw: formatGpsRawLine(pos),
 9820:         gps: buildGpsMetaFromPosition(pos)
 9821:       };
 9822:       const pi = document.getElementById("pasteInput");
 9823:       if (pi) pi.value = round(lat, 7) + ", " + round(lon, 7);
 9824:       setBadge("LatLon", fmtDD(lat, lon).cardinal);
 9825:       renderResults(lat, lon, meta);
 9826:       refreshGeolocationBarriers();
