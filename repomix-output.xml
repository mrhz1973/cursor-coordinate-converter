 9231: /* ========================= SECTION 15: UNIVERSAL AUTO-DETECT ========================= */
 9232: function autoDetect(input){
 9233:   const s = String(input || "").trim();
 9234:   if (!s) throw new ErrI18n("err.empty");
 9235:   // British National Grid (BNG) — two letters + digits (2..10), permissive spaces.
 9236:   try {
 9237:     if (/^[A-Za-z]{2}\s*\d{2,10}\s*$/.test(s.replace(/\s+/g,""))){
 9238:       const ll = bngToWgs84(s);
 9239:       return { type:"BNG", lat: ll.lat, lon: ll.lon, bng: s, raw: s };
 9240:     }
 9241:   } catch(_){}
 9242:   // SK42 Gauss-Krüger (zone-based TM). Accepts "Z7 E N" / "7 E N" / "E N".
 9243:   try {
 9244:     const gk = parseSK42GaussKruger(s);
 9245:     if (gk){
 9246:       const ll = sk42GaussKrugerToWgs84(gk.zone, gk.easting, gk.northing);
 9247:       return { type:"SK42GK", lat: ll.lat, lon: ll.lon, sk42gk: gk, raw: s };
 9248:     }
 9249:   } catch(_){}
 9250:   // Plus Code first: it has a distinctive "+" at position 8 so it can't be
 9251:   // confused with MGRS/UTM/Lat-Lon. Cheap pre-filter avoids throwing on
 9252:   // inputs that don't even look like a Plus Code.
 9253:   if (looksLikePlusCode(s)){
 9254:     try {
 9255:       const p = decodePlusCode(s);
 9256:       return { type:"OLC", lat: p.lat, lon: p.lon, plus: p, raw: s };
 9257:     } catch(_){ /* fall through to next detector */ }
 9258:   }
 9259:   // Try MGRS (tight regex, least ambiguous)
 9260:   try { const m = parseMGRS(s); const ll = mgrsToLatLonExt(s); return { type:"MGRS", lat: ll.lat, lon: ll.lon, mgrs: ll, raw: s }; }
 9261:   catch(_){}
 9262:   // UTM next
 9263:   try {
 9264:     const u = parseUTMFree(s);
 9265:     if (u){
 9266:       validateUTM(u);
 9267:       const ll = utmToLatLon(u.zone, u.hemisphere, u.easting, u.northing);
 9268:       return { type:"UTM", lat: ll.lat, lon: ll.lon, utm: u, raw: s };
 9269:     }
 9270:   } catch(_){}
 9271:   // Lat/Lon free text
 9272:   try { const ll = parseFreeTextLatLon(s); return { type:"LatLon", lat: ll.lat, lon: ll.lon, raw: s }; }
 9273:   catch(_){}
 9274:   throw new ErrI18n("err.notRecognized");
 9275: }
