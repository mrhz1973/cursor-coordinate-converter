11800: /** Save the current bbox (from state or fields) as a named area. */
11801: function saveNamedArea(name){
11802:   let b = state.bboxSelection;
11803:   if (!b) b = readBboxFields();
11804:   if (!b){
11805:     setBadge("error", t("offcache.saveNamedPrompt"));
11806:     return;
11807:   }
11808:   const clean = String(name || "").trim().slice(0, 40);
11809:   if (!clean){
11810:     setBadge("error", t("offcache.saveNamedPrompt"));
11811:     return;
11812:   }
11813:   if (!Array.isArray(state.namedAreas)) state.namedAreas = [];
11814:   // Snapshot the current zoom range too, so the named area can be restored
11815:   // with the exact z0..z1 that was chosen when the user saved it.
11816:   const z0raw = parseInt(document.getElementById("pcZ0")?.value, 10);
11817:   const z1raw = parseInt(document.getElementById("pcZ1")?.value, 10);
11818:   const z0 = Number.isFinite(z0raw) ? Math.max(0, Math.min(19, z0raw)) : null;
11819:   const z1 = Number.isFinite(z1raw) ? Math.max(0, Math.min(19, z1raw)) : null;
11820:   const entry = {
11821:     id: uidNamed(),
11822:     name: clean,
11823:     n: b.n, s: b.s, e: b.e, w: b.w,
11824:     z0: z0, z1: z1,
11825:     createdAt: Date.now()
11826:   };
11827:   state.namedAreas.unshift(entry);
11828:   if (state.namedAreas.length > 30) state.namedAreas.length = 30;
11829:   saveStore();
11830:   renderNamedAreasOptgroup();
11831:   const sel = document.getElementById("pcPreset");
11832:   if (sel) sel.value = "named:" + entry.id;
11833:   const txt = document.getElementById("pcAreaName");
11834:   if (txt) txt.value = "";
11835:   setBadge("success", t("offcache.saveNamedOk").replace("{0}", clean));
11836:   // Refresh the coverage overlay immediately so the new rectangle shows up.
11837:   const _tm = document.querySelector("#miniMap .tile-map");
11838:   if (_tm) drawCoverageOverlay(_tm);
11839: }
