13275: /**
13276:  * Live-update the "cursor coordinates" overlay as the user moves their
13277:  * pointer (or finger) over the tile map. We convert the cursor pixel
13278:  * position into the tile-pixel coordinate of the corresponding point on
13279:  * Earth (relative to the current view center + any active pan transform)
13280:  * and then format it in the user's chosen primary format.
13281:  *
13282:  * Uses a small rAF throttle so rapid mousemove events don't stall the
13283:  * main thread with repeated MGRS/UTM computations.
13284:  */
13285: /**
13286:  * Wire up the CURSORE row so that:
13287:  *   - Moving the pointer updates the coord text on every animation frame
13288:  *     (cheap: just formatting MGRS/UTM/DD from lat/lon).
13289:  *   - Stopping the pointer for ≥ 450 ms triggers a one-shot elevation
13290:  *     lookup for that coord, with the shared elevCache preventing
13291:  *     duplicate network hits on revisited spots.
13292:  *   - Leaving the map reverts the row to the converted point's values,
13293:  *     so it stays informative instead of going blank.
13294:  *
13295:  * The 450 ms debounce is a compromise between reactivity and server
13296:  * politeness — short enough that brief pauses feel live, long enough that
13297:  * dragging across the map doesn't fire dozens of requests.
13298:  */
13299: function attachCursorReadout(root, lat, lon, zoom){
13300:   const tileMap   = root.querySelector(".tile-map");
13301:   const coordEl   = root.querySelector('.trp-cursor [data-role="cursor-coord"]');
13302:   const elevEl    = root.querySelector('.trp-cursor [data-role="cursor-elev"]');
13303:   if (!tileMap || !coordEl) return;
13304: 
13305:   const vc = state.viewCenter || { lat, lon };
13306:   const vLat = Math.max(-85.05, Math.min(85.05, vc.lat));
13307:   const vLon = normalizeLon(vc.lon);
13308:   const vtx = lonToTileX(vLon, zoom);
13309:   const vty = latToTileY(vLat, zoom);
13310: 
13311:   let scheduled = false;
13312:   let lastPt    = null;
13313: 
13314:   // --- Elevation for the CURSORE row -------------------------------------
13315:   // The old approach debounced every move by 300 ms, which looked "frozen"
13316:   // during continuous motion because the timer kept resetting.
13317:   //
13318:   // New approach: a single-slot coalescing queue.
13319:   //   * Cache hits update the DOM synchronously (no network).
13320:   //   * On a cache miss, we stash {lat, lon} in `pending`. If no request is
13321:   //     in flight, we kick one off immediately. If one is in flight, we
13322:   //     just overwrite `pending`: when the current fetch resolves we chain
13323:   //     into the most recent coords.
13324:   //   * A `seq` counter invalidates stale fetches: when a newer cursor
13325:   //     position comes in, the old response is ignored.
13326:   // Result: elevation updates as fast as the network allows, every ~300–
13327:   // 600 ms during continuous movement, instead of only when the user pauses.
13328:   let elevSeq       = 0;
13329:   let elevInFlight  = false;
13330:   let pendingPt     = null;  // { lat, lon, seq }
13331: 
13332:   const applyElev = (seq, val) => {
13333:     if (!elevEl || !elevEl.isConnected) return;
13334:     if (seq !== elevSeq) return;   // a newer request has overtaken this one
13335:     elevEl.classList.remove("is-loading");
13336:     elevEl.textContent = (typeof val === "number") ? Math.round(val) + " m" : "—";
13337:   };
13338: 
13339:   const flushPending = () => {
13340:     if (elevInFlight || !pendingPt || !elevEl) return;
13341:     const job = pendingPt;
13342:     pendingPt = null;
13343:     elevInFlight = true;
13344:     elevEl.classList.add("is-loading");
13345:     fetchElevation(job.lat, job.lon).then(val => {
13346:       elevInFlight = false;
13347:       applyElev(job.seq, val);
13348:       // If the cursor moved again while we were waiting, chain immediately
13349:       // into the freshest coords so the user sees another update.
13350:       flushPending();
13351:     });
13352:   };
13353: 
13354:   const setCursorElev = (curLat, curLon) => {
13355:     if (!elevEl) return;
13356:     const myReq = ++elevSeq;
13357: 
13358:     if (!navigator.onLine || state.forceOffline){
13359:       elevEl.textContent = t("map.elevOffline");
13360:       elevEl.classList.add("is-offline");
13361:       elevEl.classList.remove("is-loading");
13362:       pendingPt = null;
13363:       return;
13364:     }
13365:     elevEl.classList.remove("is-offline");
13366: 
13367:     const key = `${curLat.toFixed(4)},${curLon.toFixed(4)}`;
13368:     const cached = elevCache.get(key);
13369:     if (typeof cached === "number"){
13370:       // Instant update, no network traffic.
13371:       elevEl.textContent = Math.round(cached) + " m";
13372:       elevEl.classList.remove("is-loading");
13373:       // Drop any pending job — our current display is authoritative now.
13374:       pendingPt = null;
13375:       return;
13376:     }
13377: 
13378:     // Cache miss: enqueue the latest coords and kick the queue.
13379:     pendingPt = { lat: curLat, lon: curLon, seq: myReq };
13380:     flushPending();
13381:   };
13382: 
13383:   // Initialize the CURSORE row with the point's own elevation while the
13384:   // user hasn't moved yet (matches what PUNTO row is about to show).
13385:   setCursorElev(lat, lon);
13386: 
13387:   const computeLatLon = () => {
13388:     const rect = tileMap.getBoundingClientRect();
13389:     const layer = root.querySelector(".tile-layer");
13390:     let dx = 0, dy = 0;
13391:     if (layer){
13392:       const tr = layer.style.transform;
13393:       const m = tr && tr.match(/translate3d\(([-\d.]+)px,\s*([-\d.]+)px/);
13394:       if (m){ dx = parseFloat(m[1]); dy = parseFloat(m[2]); }
13395:     }
13396:     const px = lastPt.x - rect.left - rect.width / 2  - dx;
13397:     const py = lastPt.y - rect.top  - rect.height / 2 - dy;
13398:     const curLon = normalizeLon(tileX2Lon(vtx + px / 256, zoom));
13399:     const curLat = tileY2Lat(vty + py / 256, zoom);
13400:     return { lat: curLat, lon: curLon };
13401:   };
13402: 
13403:   const update = () => {
13404:     scheduled = false;
13405:     if (!lastPt) return;
13406:     const { lat: curLat, lon: curLon } = computeLatLon();
13407:     if (!Number.isFinite(curLat) || !Number.isFinite(curLon)){
13408:       coordEl.textContent = "—";
13409:       if (elevEl){
13410:         // Invalidate any in-flight / pending fetch so it can't overwrite this.
13411:         elevSeq++;
13412:         pendingPt = null;
13413:         elevEl.textContent = "—";
13414:         elevEl.classList.remove("is-loading");
13415:       }
13416:       return;
13417:     }
13418:     coordEl.textContent = fmtPrimary(curLat, curLon);
13419:     state.mapCursorLL = { lat: curLat, lon: curLon };
13420:     setCursorElev(curLat, curLon);
13421:   };
13422: 
13423:   const onMove = (ev) => {
13424:     const src = (ev.touches && ev.touches.length) ? ev.touches[0] : ev;
13425:     lastPt = { x: src.clientX, y: src.clientY };
13426:     if (!scheduled){ scheduled = true; requestAnimationFrame(update); }
13427:   };
13428:   const onLeave = () => {
13429:     lastPt = null;
13430:     // Pointer left the map → show the point's own values again so the
13431:     // row stays meaningful instead of going blank.
13432:     coordEl.textContent = fmtPrimary(lat, lon);
13433:     state.mapCursorLL = { lat, lon };
13434:     setCursorElev(lat, lon);
13435:   };
13436: 
13437:   tileMap.addEventListener("mousemove", onMove);
13438:   tileMap.addEventListener("mouseleave", onLeave);
13439:   tileMap.addEventListener("touchmove", onMove, { passive: true });
13440:   tileMap.addEventListener("touchend", onLeave);
13441:   tileMap.addEventListener("touchcancel", onLeave);
13442: }
