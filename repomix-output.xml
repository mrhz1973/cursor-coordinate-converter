12062: /**
12063:  * Two-step delete flow triggered by the × on a coverage rectangle:
12064:  *   1) "Delete this named area?" → Cancel aborts.
12065:  *   2) "Also delete cached tiles inside it?" → OK wipes the tiles in
12066:  *      IndexedDB for every known layer within the area's bbox × z-range;
12067:  *      Cancel keeps the tiles (they remain reachable if another area or
12068:  *      manual pan/zoom already covered the same region).
12069:  * Using two window.confirm's keeps the flow dependency-free while still
12070:  * being explicit about what's being deleted.
12071:  */
12072: async function confirmRemoveNamedArea(area){
12073:   if (!area) return;
12074:   const name = area.name || "Area";
12075:   const q1 = (t("cov.removeConfirm") || "Rimuovere la zona '{0}'?").replace("{0}", name);
12076:   if (!window.confirm(q1)) return;
12077: 
12078:   let wipedTiles = 0;
12079:   const q2 = (t("cov.removeWithTiles") || "Cancellare anche i tile scaricati di '{0}' dall'archivio offline?").replace("{0}", name);
12080:   if (window.confirm(q2)){
12081:     try { wipedTiles = await deleteNamedAreaTiles(area); } catch(_){ wipedTiles = 0; }
12082:   }
12083:   // Remove the named area itself.
12084:   state.namedAreas = (state.namedAreas || []).filter(x => x.id !== area.id);
12085:   saveStore();
12086:   renderNamedAreasOptgroup();
12087:   const _tm = document.querySelector("#miniMap .tile-map");
12088:   if (_tm){
12089:     // If we wiped tiles, the current map needs a re-render so the freed
12090:     // tiles fall back to network (or show "?" offline). If we only removed
12091:     // the area entry, a light redraw of the overlay is enough.
12092:     if (wipedTiles > 0 && state.lastPoint){
12093:       renderMiniMap(state.lastPoint.lat, state.lastPoint.lon, false);
12094:     } else {
12095:       drawCoverageOverlay(_tm);
12096:     }
12097:   }
12098:   const msg = wipedTiles > 0
12099:     ? (t("cov.removeOkTiles") || "Zona '{0}' rimossa ({1} tile cancellati).")
12100:         .replace("{0}", name).replace("{1}", wipedTiles)
12101:     : (t("cov.removeOk")      || "Zona '{0}' rimossa.").replace("{0}", name);
12102:   setBadge("success", msg);
12103: }
