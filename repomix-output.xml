 6345: /* ========================= SECTION 11b: ITALIAN DATUMS (ROMA40 / ED50) ========================= *
 6346:  * Fornisce conversioni approssimate WGS84 → ROMA40 (Monte Mario) → Gauss-Boaga
 6347:  * (Fuso Ovest / Est) e WGS84 → ED50 lat/lon. Usa ellissoide di Hayford
 6348:  * (International 1924) e una trasformazione di Helmert a 3 parametri (media
 6349:  * nazionale italiana). Accuratezza attesa ~5-10 m: NON sostituisce la
 6350:  * trasformazione a griglia IGM (GK2) richiesta per precisione centimetrica.
 6351:  *
 6352:  * Parametri ellissoidi ed EPSG di riferimento:
 6353:  *   - WGS84        EPSG:4326   a=6378137,    1/f=298.257223563
 6354:  *   - Hayford 1924 EPSG:7022   a=6378388,    1/f=297
 6355:  *   - Gauss-Boaga Fuso Ovest   EPSG:3003    CM=9°  E0=1500000  k0=0.9996
 6356:  *   - Gauss-Boaga Fuso Est     EPSG:3004    CM=15° E0=2520000  k0=0.9996
 6357:  *   - ED50 lat/lon             EPSG:4230
 6358:  *
 6359:  * Shift (ECEF, metri) "aggiunti al punto WGS84" per ottenere il datum target.
 6360:  * Valori calibrati per minimizzare lo scarto rispetto alla trasformazione
 6361:  * ufficiale basata su griglia NTv2 (pyproj) sull'intera Italia. Residuo atteso:
 6362:  *   ROMA40 → Gauss-Boaga: ~20 m RMS, max ~65 m (nelle aree più periferiche).
 6363:  *   ED50  → lat/lon:     <2 m RMS.
 6364:  * Fonti di riferimento: EPSG:1659 "Monte Mario to WGS 84 (1)" (sign-inverted),
 6365:  * EPSG:1134 "ED50 to WGS 84 (7)" (sign-inverted).
 6366:  */
 6367: 
 6368: const ELL_WGS84   = (function(){ const f = 1/298.257223563; const e2 = 2*f - f*f; return { a: 6378137,   f, e2, e: Math.sqrt(e2) }; })();
 6369: const ELL_HAYFORD = (function(){ const f = 1/297;             const e2 = 2*f - f*f; return { a: 6378388,   f, e2, e: Math.sqrt(e2) }; })();
 6370: 
 6371: const SHIFT_WGS84_TO_ROMA40 = { dX: +225.0, dY: +65.0, dZ:  -9.0 };
 6372: const SHIFT_WGS84_TO_ED50   = { dX:  +87.0, dY: +98.0, dZ: +121.0 };
