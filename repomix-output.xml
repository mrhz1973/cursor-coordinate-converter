16268:     svgWrap.innerHTML = `<p style="color:var(--error)">${esc(String(e.message || e))}</p>`;
16269:   }
16270:   urlEl.textContent = url;
16271:   urlEl.dataset.url = url;
16272:   modal.classList.add("open");
16273: }
