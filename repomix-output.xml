16234: /* Render a QR matrix as an inline SVG string. */
16235: function qrRenderSVG(result, options){
16236:   const { matrix } = result;
16237:   const { M, size } = matrix;
16238:   const scale = options && options.scale ? options.scale : 8;
16239:   const quiet = options && options.quiet != null ? options.quiet : 4;
16240:   const total = (size + quiet * 2) * scale;
16241:   let rects = "";
16242:   for (let r = 0; r < size; r++){
16243:     for (let c = 0; c < size; c++){
16244:       if (M[r][c]){
16245:         rects += `<rect x="${(c + quiet) * scale}" y="${(r + quiet) * scale}" width="${scale}" height="${scale}"/>`;
16246:       }
16247:     }
16248:   }
16249:   return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${total} ${total}" width="${total}" height="${total}" shape-rendering="crispEdges" role="img" aria-label="QR Code"><rect width="${total}" height="${total}" fill="#ffffff"/><g fill="#000000">${rects}</g></svg>`;
16250: }
16251: 
16252: /* Convenience API used by the UI */
16253: function qrGenerateSVG(text, options){
16254:   return qrRenderSVG(qrEncode(text), options);
16255: }
