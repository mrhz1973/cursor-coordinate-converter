 9966: /**
 9967:  * Render an interactive OSM tile map inside #miniMap. Uses direct <img>
 9968:  * tiles from tile.openstreetmap.org (no 3rd-party JS), positioned absolutely.
 9969:  * Includes zoom +/- controls and the mandatory OSM attribution. The marker
 9970:  * is drawn at the visual center, which by construction is the current point.
 9971:  */
 9972: /* Tile layer definitions.
 9973:  *
 9974:  * Cartography: CARTO Voyager (OSM-derived basemap served by CARTO's
 9975:  *   public CDN). We *don't* use tile.openstreetmap.org directly because
 9976:  *   OSM's volunteer tile servers now enforce a Referer/User-Agent policy
 9977:  *   and return 403 "Access blocked" to requests that don't send an
 9978:  *   identifying Referer — including anything loaded from file:// or from
 9979:  *   origins without an HTTP referrer. CARTO's CDN doesn't require that
 9980:  *   and is explicitly allowed for end-user apps at light volume.
 9981:  *   Subdomain sharding (a-d) parallelizes downloads in the browser.
 9982:  *
 9983:  * Satellite: Esri World Imagery (free tier, no key, CORS enabled).
 9984:  *   Note the /{z}/{y}/{x} coordinate order (Esri convention).
 9985:  *
 9986:  * Both use Web Mercator @ 256 px tiles. Retina (@2x) skipped for size. */
 9987: const TILE_LAYERS = {
 9988:   osm: {
 9989:     url:    (z, x, y) => {
 9990:       const sub = ["a","b","c","d"][Math.abs(x + y) % 4];
 9991:       return `https://${sub}.basemaps.cartocdn.com/rastertiles/voyager/${z}/${x}/${y}.png`;
 9992:     },
 9993:     attrib: '© <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> · © <a href="https://carto.com/attributions" target="_blank" rel="noopener">CARTO</a>',
 9994:     maxZoom: 19
 9995:   },
 9996:   sat: {
 9997:     url:    (z, x, y) => `https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/${z}/${y}/${x}`,
 9998:     attrib: 'Imagery © <a href="https://www.esri.com/" target="_blank" rel="noopener">Esri</a>, Maxar, Earthstar Geographics',
 9999:     maxZoom: 19
10000:   }
10001: };
