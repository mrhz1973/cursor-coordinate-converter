15830: /* ========================= SECTION 26: QR CODE ENCODER =========================
15831:  * Compact offline QR Code Model 2 encoder (ISO/IEC 18004).
15832:  * - Byte mode (UTF-8), EC level M (~15 % recoverable)
15833:  * - Versions 1..10 (matrix 21×21 up to 57×57), payloads up to ~213 UTF-8 bytes
15834:  * - Zero dependencies, renders directly as inline SVG (no canvas needed)
15835:  * Used to share the current coordinate as a scannable Google Maps URL.
15836:  */
15837: 
15838: // --- GF(256) log / exp tables for Reed–Solomon arithmetic ---
15839: const QR_EXP = new Uint8Array(512);
15840: const QR_LOG = new Uint8Array(256);
15841: (function initGF(){
15842:   let x = 1;
15843:   for (let i = 0; i < 255; i++){
15844:     QR_EXP[i] = x;
15845:     QR_LOG[x] = i;
15846:     x <<= 1;
15847:     if (x & 0x100) x ^= 0x11D; // QR primitive polynomial
15848:   }
15849:   for (let i = 255; i < 512; i++) QR_EXP[i] = QR_EXP[i - 255];
15850: })();
15851: function qrGfMul(a, b){
15852:   if (a === 0 || b === 0) return 0;
15853:   return QR_EXP[QR_LOG[a] + QR_LOG[b]];
15854: }
15855: 
15856: // --- Reed–Solomon generator polynomial of degree n ---
15857: function qrRsGen(n){
15858:   let poly = [1];
15859:   for (let i = 0; i < n; i++){
15860:     const next = new Array(poly.length + 1).fill(0);
15861:     for (let j = 0; j < poly.length; j++){
15862:       next[j]     ^= poly[j];
15863:       next[j + 1] ^= qrGfMul(poly[j], QR_EXP[i]);
15864:     }
15865:     poly = next;
15866:   }
15867:   return poly;
15868: }
15869: // Encode `data` (Uint8Array) into `ecLen` EC codewords
15870: function qrRsEncode(data, ecLen){
15871:   const gen = qrRsGen(ecLen);
15872:   const buf = new Uint8Array(data.length + ecLen);
15873:   buf.set(data, 0);
15874:   for (let i = 0; i < data.length; i++){
15875:     const factor = buf[i];
15876:     if (!factor) continue;
15877:     for (let j = 0; j < ecLen; j++){
15878:       buf[i + 1 + j] ^= qrGfMul(gen[j + 1], factor);
15879:     }
15880:   }
15881:   return buf.slice(data.length);
15882: }
15883: 
15884: /* EC level M block structure (ISO/IEC 18004 Table 9)
15885:  * Each entry: [ ecCodewordsPerBlock, [grpBlocks, dataCwsPerBlock], [grpBlocks, dataCwsPerBlock]? ]
15886:  */
15887: const QR_BLOCKS_M = {
15888:   1:  [10, [1, 16]],
15889:   2:  [16, [1, 28]],
15890:   3:  [26, [1, 44]],
15891:   4:  [18, [2, 32]],
15892:   5:  [24, [2, 43]],
15893:   6:  [16, [4, 27]],
15894:   7:  [18, [4, 31]],
15895:   8:  [22, [2, 38], [2, 39]],
15896:   9:  [22, [3, 36], [2, 37]],
15897:   10: [26, [4, 43], [1, 44]]
15898: };
15899: 
15900: // Alignment pattern centre coordinates per version
15901: const QR_ALIGN = {
15902:   1: [], 2: [6, 18], 3: [6, 22], 4: [6, 26], 5: [6, 30],
15903:   6: [6, 34], 7: [6, 22, 38], 8: [6, 24, 42], 9: [6, 26, 46], 10: [6, 28, 50]
15904: };
15905: 
15906: // Pre-computed 15-bit format info codewords for EC level M + mask 0..7
15907: // (ISO/IEC 18004 Annex C, already XOR'd with 101010000010010)
15908: const QR_FORMAT_M = [0x5412, 0x5125, 0x5E7C, 0x5B4B, 0x45F9, 0x40CE, 0x4F97, 0x4AA0];
15909: 
15910: // Total data / EC codeword counts for a given version
15911: function qrCounts(v){
15912:   const t = QR_BLOCKS_M[v];
15913:   const ecPer = t[0];
15914:   let data = 0, blocks = 0;
15915:   for (let i = 1; i < t.length; i++){
15916:     blocks += t[i][0];
15917:     data   += t[i][0] * t[i][1];
15918:   }
15919:   return { data, ec: ecPer * blocks, ecPer, blocks };
15920: }
15921: 
15922: // Select the smallest version whose data capacity holds the payload
15923: function qrSelectVersion(byteLen){
15924:   for (let v = 1; v <= 10; v++){
15925:     const cci  = v <= 9 ? 8 : 16;
15926:     const need = 4 + cci + 8 * byteLen + 4; // mode + count + data + terminator
15927:     if (need <= qrCounts(v).data * 8) return v;
15928:   }
15929:   throw new Error("QR payload too long (>213 UTF-8 bytes)");
15930: }
15931: 
15932: /* Build the raw data codewords (pre-RS) for a given text + version. */
15933: function qrBuildData(text, version){
15934:   const utf8 = new TextEncoder().encode(text);
15935:   const cci = version <= 9 ? 8 : 16;
15936:   const totalData = qrCounts(version).data;
15937: 
15938:   const bits = [];
15939:   const push = (val, n) => { for (let i = n - 1; i >= 0; i--) bits.push((val >> i) & 1); };
15940:   push(0b0100, 4);          // byte-mode indicator
15941:   push(utf8.length, cci);
15942:   for (const b of utf8) push(b, 8);
15943: 
15944:   const cap = totalData * 8;
15945:   for (let i = 0; i < 4 && bits.length < cap; i++) bits.push(0); // terminator
15946:   while (bits.length % 8) bits.push(0);                          // byte align
15947:   let pad = 0;
15948:   while (bits.length < cap){
15949:     push(pad === 0 ? 0xEC : 0x11, 8);
15950:     pad ^= 1;
15951:   }
15952: 
15953:   const out = new Uint8Array(totalData);
15954:   for (let i = 0; i < totalData; i++){
15955:     let v = 0;
15956:     for (let j = 0; j < 8; j++) v = (v << 1) | bits[i * 8 + j];
15957:     out[i] = v;
15958:   }
15959:   return out;
15960: }
15961: 
15962: /* Split data codewords into blocks, compute EC per block, then interleave
15963:  * according to ISO/IEC 18004 §8.6: codewords are read by column across blocks.
15964:  */
15965: function qrInterleave(dataCw, version){
15966:   const t = QR_BLOCKS_M[version];
15967:   const ecLen = t[0];
15968:   const blocks = [];
15969:   let off = 0;
15970:   for (let g = 1; g < t.length; g++){
15971:     const [num, dataPer] = t[g];
15972:     for (let b = 0; b < num; b++){
15973:       const slice = dataCw.slice(off, off + dataPer);
15974:       off += dataPer;
15975:       blocks.push({ data: slice, ec: qrRsEncode(slice, ecLen) });
15976:     }
15977:   }
15978:   const maxData = Math.max(...blocks.map(b => b.data.length));
15979:   const out = [];
15980:   for (let i = 0; i < maxData; i++){
15981:     for (const b of blocks) if (i < b.data.length) out.push(b.data[i]);
15982:   }
15983:   for (let i = 0; i < ecLen; i++){
15984:     for (const b of blocks) out.push(b.ec[i]);
15985:   }
15986:   return new Uint8Array(out);
15987: }
15988: 
15989: /* Build the matrix with all function patterns (finder, timing, alignment,
15990:  * reserved format/version info, dark module). Data is zigzag-placed afterwards.
15991:  */
15992: function qrBuildMatrix(version){
15993:   const size = 4 * version + 17;
15994:   const M = []; const F = [];
15995:   for (let r = 0; r < size; r++){ M.push(new Uint8Array(size)); F.push(new Uint8Array(size)); }
15996:   const set = (r, c, v) => { M[r][c] = v ? 1 : 0; F[r][c] = 1; };
15997: 
15998:   // Finder patterns at 3 corners + separator (1-px white gap)
15999:   const placeFinder = (r0, c0) => {
16000:     for (let dr = -1; dr <= 7; dr++){
16001:       for (let dc = -1; dc <= 7; dc++){
16002:         const r = r0 + dr, c = c0 + dc;
16003:         if (r < 0 || c < 0 || r >= size || c >= size) continue;
16004:         let v = 0;
16005:         if (dr >= 0 && dr <= 6 && dc >= 0 && dc <= 6){
16006:           const edge   = (dr === 0 || dr === 6 || dc === 0 || dc === 6);
16007:           const centre = (dr >= 2 && dr <= 4 && dc >= 2 && dc <= 4);
16008:           v = (edge || centre) ? 1 : 0;
16009:         }
16010:         set(r, c, v);
16011:       }
16012:     }
16013:   };
16014:   placeFinder(0, 0);
16015:   placeFinder(0, size - 7);
16016:   placeFinder(size - 7, 0);
16017: 
16018:   // Timing patterns (row 6 and column 6, excluding the finder areas)
16019:   for (let i = 8; i <= size - 9; i++){
16020:     set(6, i, i % 2 === 0 ? 1 : 0);
16021:     set(i, 6, i % 2 === 0 ? 1 : 0);
16022:   }
16023: 
16024:   // Alignment patterns (5×5) at every pair of centres that doesn't overlap a finder
16025:   const pos = QR_ALIGN[version] || [];
16026:   for (const r of pos){
16027:     for (const c of pos){
16028:       if ((r === 6 && c === 6) ||
16029:           (r === 6 && c === size - 7) ||
16030:           (r === size - 7 && c === 6)) continue;
16031:       for (let dr = -2; dr <= 2; dr++){
16032:         for (let dc = -2; dc <= 2; dc++){
16033:           const edge   = (Math.abs(dr) === 2 || Math.abs(dc) === 2);
16034:           const centre = (dr === 0 && dc === 0);
16035:           set(r + dr, c + dc, edge || centre ? 1 : 0);
16036:         }
16037:       }
16038:     }
16039:   }
16040: 
16041:   // Reserve format info modules (will be overwritten after mask selection)
16042:   for (let i = 0; i <= 8; i++){
16043:     if (!F[i][8] && i !== 6) F[i][8] = 1;
16044:     if (!F[8][i] && i !== 6) F[8][i] = 1;
16045:   }
16046:   for (let i = 0; i < 8; i++){
16047:     F[8][size - 1 - i] = 1;
16048:     F[size - 1 - i][8] = 1;
16049:   }
16050:   // Dark module (always 1) — ISO/IEC 18004 §8.9
16051:   set(size - 8, 8, 1);
16052: 
16053:   // Reserve version info blocks for v ≥ 7 (two 3×6 blocks)
16054:   if (version >= 7){
16055:     for (let i = 0; i < 18; i++){
16056:       const r = Math.floor(i / 3), c = size - 11 + (i % 3);
16057:       F[r][c] = 1; F[c][r] = 1;
16058:     }
16059:   }
16060: 
16061:   return { M, F, size };
16062: }
16063: 
16064: function qrCloneMatrix(m){
16065:   const M = m.M.map(r => new Uint8Array(r));
16066:   const F = m.F.map(r => new Uint8Array(r));
16067:   return { M, F, size: m.size };
16068: }
16069: 
16070: /* Zigzag placement of data codewords (ISO/IEC 18004 §8.7).
16071:  * Traverses pairs of columns from the right, alternating direction, skipping
16072:  * function modules. Column 6 is skipped entirely (timing pattern).
16073:  */
16074: function qrPlaceData(matrix, bytes){
16075:   const { M, F, size } = matrix;
16076:   let bit = 0, up = true;
16077:   for (let col = size - 1; col > 0; col -= 2){
16078:     if (col === 6) col--; // skip vertical timing pattern
16079:     for (let rowStep = 0; rowStep < size; rowStep++){
16080:       const r = up ? (size - 1 - rowStep) : rowStep;
16081:       for (let dc = 0; dc < 2; dc++){
16082:         const c = col - dc;
16083:         if (F[r][c]) continue;
16084:         const byteIdx = bit >> 3;
16085:         const bitIdx  = 7 - (bit & 7);
16086:         M[r][c] = (byteIdx < bytes.length) ? ((bytes[byteIdx] >> bitIdx) & 1) : 0;
16087:         bit++;
16088:       }
16089:     }
16090:     up = !up;
16091:   }
16092: }
16093: 
16094: // Mask functions — ISO/IEC 18004 Table 10
16095: const QR_MASKS = [
16096:   (r, c) => (r + c) % 2 === 0,
16097:   (r, c) => r % 2 === 0,
16098:   (r, c) => c % 3 === 0,
16099:   (r, c) => (r + c) % 3 === 0,
16100:   (r, c) => (Math.floor(r / 2) + Math.floor(c / 3)) % 2 === 0,
16101:   (r, c) => ((r * c) % 2) + ((r * c) % 3) === 0,
16102:   (r, c) => (((r * c) % 2) + ((r * c) % 3)) % 2 === 0,
16103:   (r, c) => (((r + c) % 2) + ((r * c) % 3)) % 2 === 0
16104: ];
16105: 
16106: function qrApplyMask(matrix, idx){
16107:   const { M, F, size } = matrix;
16108:   const fn = QR_MASKS[idx];
16109:   for (let r = 0; r < size; r++){
16110:     for (let c = 0; c < size; c++){
16111:       if (!F[r][c] && fn(r, c)) M[r][c] ^= 1;
16112:     }
16113:   }
16114: }
16115: 
16116: /* Place the 15-bit format info (level M + mask idx) and the dark module.
16117:  * The two redundant copies are per ISO/IEC 18004 §8.9.
16118:  */
16119: function qrPlaceFormatInfo(matrix, maskIdx){
16120:   const { M, size } = matrix;
16121:   const bits = QR_FORMAT_M[maskIdx];
16122:   const b = (i) => (bits >> i) & 1;
16123: 
16124:   // Copy 1: around the top-left finder
16125:   for (let i = 0; i < 6; i++) M[i][8]     = b(i);
16126:   M[7][8]    = b(6);
16127:   M[8][8]    = b(7);
16128:   M[8][7]    = b(8);
16129:   for (let i = 9; i < 15; i++) M[8][14 - i] = b(i);
16130: 
16131:   // Copy 2: split across bottom-left + top-right
16132:   for (let i = 0; i < 8; i++) M[8][size - 1 - i] = b(i);
16133:   for (let i = 8; i < 15; i++) M[size - 15 + i][8] = b(i);
16134:   M[size - 8][8] = 1; // dark module (redundant safety)
16135: }
16136: 
16137: function qrPlaceVersionInfo(matrix, version){
16138:   if (version < 7) return;
16139:   const { M, size } = matrix;
16140:   // BCH(18,6) encode with generator 0x1F25
16141:   let rem = version;
16142:   for (let i = 0; i < 12; i++) rem = (rem << 1) ^ (((rem >> 11) & 1) * 0x1F25);
16143:   const bits = (version << 12) | rem;
16144:   for (let i = 0; i < 18; i++){
16145:     const bit = (bits >> i) & 1;
16146:     const r = Math.floor(i / 3), c = size - 11 + (i % 3);
16147:     M[r][c] = bit; M[c][r] = bit;
16148:   }
16149: }
16150: 
16151: /* Penalty function (ISO/IEC 18004 §8.8.2, 4 rules).
16152:  * Used to pick the mask pattern with the lowest visual bias.
16153:  */
16154: function qrPenalty(matrix){
16155:   const { M, size } = matrix;
16156:   let total = 0;
16157: 
16158:   // Rule 1: runs of 5+ same-colour modules in rows and columns
16159:   const runPenalty = (get) => {
16160:     let p = 0;
16161:     for (let a = 0; a < size; a++){
16162:       let run = 1, prev = get(a, 0);
16163:       for (let b = 1; b < size; b++){
16164:         const v = get(a, b);
16165:         if (v === prev) run++;
16166:         else { if (run >= 5) p += 3 + (run - 5); run = 1; prev = v; }
16167:       }
16168:       if (run >= 5) p += 3 + (run - 5);
16169:     }
16170:     return p;
16171:   };
16172:   total += runPenalty((r, c) => M[r][c]);
16173:   total += runPenalty((c, r) => M[r][c]);
16174: 
16175:   // Rule 2: every 2×2 block of same colour scores 3
16176:   for (let r = 0; r < size - 1; r++){
16177:     for (let c = 0; c < size - 1; c++){
16178:       const v = M[r][c];
16179:       if (v === M[r][c+1] && v === M[r+1][c] && v === M[r+1][c+1]) total += 3;
16180:     }
16181:   }
16182: 
16183:   // Rule 3: finder-like patterns (1:1:3:1:1 with 4-module light margin) in rows/cols
16184:   const look = [1,0,1,1,1,0,1,0,0,0,0];
16185:   const lookRev = look.slice().reverse();
16186:   const hasPattern = (arr, start, pat) => {
16187:     for (let i = 0; i < pat.length; i++) if (arr[start + i] !== pat[i]) return false;
16188:     return true;
16189:   };
16190:   const scanLine = (line) => {
16191:     let p = 0;
16192:     for (let i = 0; i <= line.length - 11; i++){
16193:       if (hasPattern(line, i, look) || hasPattern(line, i, lookRev)) p += 40;
16194:     }
16195:     return p;
16196:   };
16197:   for (let r = 0; r < size; r++) total += scanLine(Array.from(M[r]));
16198:   for (let c = 0; c < size; c++){
16199:     const col = new Uint8Array(size);
16200:     for (let r = 0; r < size; r++) col[r] = M[r][c];
16201:     total += scanLine(Array.from(col));
16202:   }
16203: 
16204:   // Rule 4: deviation of dark-module proportion from 50 %
16205:   let dark = 0;
16206:   for (let r = 0; r < size; r++) for (let c = 0; c < size; c++) dark += M[r][c];
16207:   const ratio = (dark / (size * size)) * 100;
16208:   total += Math.floor(Math.abs(ratio - 50) / 5) * 10;
16209: 
16210:   return total;
16211: }
16212: 
16213: /* High-level encoder: returns { M, size } for the final matrix. */
16214: function qrEncode(text){
16215:   const utf8 = new TextEncoder().encode(text);
16216:   const version = qrSelectVersion(utf8.length);
16217:   const dataCw  = qrBuildData(text, version);
16218:   const bytes   = qrInterleave(dataCw, version);
16219:   const base    = qrBuildMatrix(version);
16220:   qrPlaceVersionInfo(base, version);
16221: 
16222:   let best = null;
16223:   for (let m = 0; m < 8; m++){
16224:     const mat = qrCloneMatrix(base);
16225:     qrPlaceData(mat, bytes);
16226:     qrApplyMask(mat, m);
16227:     qrPlaceFormatInfo(mat, m);
16228:     const p = qrPenalty(mat);
16229:     if (!best || p < best.p) best = { mat, p, mask: m };
16230:   }
16231:   return { matrix: best.mat, version, mask: best.mask };
16232: }
