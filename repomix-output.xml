12311: /** Render the full point list into #track-points with drag&drop reorder. */
12312: function renderTrackPointsList(){
12313:   const root = document.getElementById("track-points");
12314:   if (!root) return;
12315:   ensureTrackState();
12316:   root.setAttribute("data-empty", t("track.empty"));
12317:   const pts = state.track.points;
12318:   if (!pts.length){
12319:     root.innerHTML = "";
12320:     return;
12321:   }
12322:   // Pre-compute leg distances and bearings
12323:   const legs = [];
12324:   for (let i = 1; i < pts.length; i++){
12325:     try {
12326:       const inv = vincentyInverse(pts[i-1].lat, pts[i-1].lon, pts[i].lat, pts[i].lon);
12327:       legs.push({ dist: inv.distance, brg: inv.initialBearing });
12328:     } catch(_){ legs.push({ dist: NaN, brg: NaN }); }
12329:   }
12330:   // Closing leg (only if closed and ≥3 points)
12331:   let closingLeg = null;
12332:   if (state.track.closed && pts.length >= 3){
12333:     try {
12334:       const last = pts[pts.length - 1], first = pts[0];
12335:       const inv = vincentyInverse(last.lat, last.lon, first.lat, first.lon);
12336:       closingLeg = { dist: inv.distance, brg: inv.initialBearing };
12337:     } catch(_){}
12338:   }
12339: 
12340:   const html = pts.map((p, i) => {
12341:     const coordStr = p.lat.toFixed(5) + ", " + p.lon.toFixed(5);
12342:     let mgrsStr = "";
12343:     try { mgrsStr = " · " + latLonToMGRS(p.lat, p.lon, 5); } catch(_){}
12344:     let legStr = "";
12345:     if (i > 0){
12346:       const lg = legs[i-1];
12347:       if (lg && Number.isFinite(lg.dist)){
12348:         legStr = `<span class="tp-leg">${esc(t("track.leg"))} #${i}: ${fmtDistMetric(lg.dist)} · ${lg.brg.toFixed(1)}°</span>`;
12349:       }
12350:     }
12351:     return `<div class="track-point-row" draggable="true" data-id="${esc(p.id)}" data-idx="${i}">
12352:       <span class="tp-idx">${i+1}</span>
12353:       <span class="tp-grip" aria-hidden="true">⋮⋮</span>
12354:       <div class="tp-data">
12355:         <label class="tp-name"><input type="text" maxlength="60" data-role="tp-name" value="${esc(p.name || "")}" placeholder="${esc(t("track.pointNamePh"))}"></label>
12356:         <div class="tp-coords">${esc(coordStr)}${esc(mgrsStr)}</div>
12357:         ${legStr}
12358:       </div>
12359:       <div class="tp-actions">
12360:         <button type="button" data-role="tp-rm" title="${esc(t("track.removePoint"))}">✕</button>
12361:       </div>
12362:     </div>`;
12363:   }).join("");
12364: 
12365:   // Closing leg row (informational only, no data-id)
12366:   let closingRow = "";
12367:   if (closingLeg && Number.isFinite(closingLeg.dist)){
12368:     closingRow = `<div class="track-point-row" style="opacity:.7;background:var(--panel2)">
12369:       <span class="tp-idx">↻</span><span class="tp-grip">·</span>
12370:       <div class="tp-data">
12371:         <span class="tp-leg">${esc(t("track.leg"))} ${esc(t("track.closed"))}: ${fmtDistMetric(closingLeg.dist)} · ${closingLeg.brg.toFixed(1)}°</span>
12372:       </div>
12373:       <div class="tp-actions"></div>
12374:     </div>`;
12375:   }
12376: 
12377:   root.innerHTML = html + closingRow;
12378: 
12379:   // Wire remove buttons and name edits
12380:   root.querySelectorAll('[data-role="tp-rm"]').forEach(btn => {
12381:     btn.addEventListener("click", (ev) => {
12382:       ev.preventDefault();
12383:       const row = btn.closest(".track-point-row");
12384:       if (row) trackRemovePoint(row.dataset.id);
12385:     });
12386:   });
12387:   root.querySelectorAll('[data-role="tp-name"]').forEach(inp => {
12388:     inp.addEventListener("change", () => {
12389:       const row = inp.closest(".track-point-row");
12390:       if (row) trackRenamePoint(row.dataset.id, inp.value);
12391:     });
12392:   });
12393: 
12394:   // Drag & drop to reorder
12395:   attachTrackDnd(root);
12396: }
