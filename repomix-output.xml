 5828: function validateDMSParts(d, m, s, maxDeg, isLon){
 5829:   if (!Number.isFinite(d) || d < 0 || d > maxDeg) throw new ErrI18n(isLon ? "err.lonDeg" : "err.latDeg");
 5830:   if (m !== undefined){
 5831:     if (!Number.isFinite(m) || m < 0 || m >= 60) throw new ErrI18n("err.minutes");
 5832:   }
 5833:   if (s !== undefined){
 5834:     if (!Number.isFinite(s) || s < 0 || s >= 60) throw new ErrI18n("err.seconds");
 5835:   }
 5836: }
 5837: function validateUTM(utm){
 5838:   if (!Number.isInteger(utm.zone) || utm.zone < 1 || utm.zone > 60) throw new ErrI18n("err.utmZone");
 5839:   if (utm.hemisphere !== "N" && utm.hemisphere !== "S") throw new ErrI18n("err.utmHem");
 5840:   if (!Number.isFinite(utm.easting))  throw new ErrI18n("err.utmEast");
 5841:   if (!Number.isFinite(utm.northing)) throw new ErrI18n("err.utmNorth");
 5842:   if (utm.easting < 100000 || utm.easting > 900000) throw new ErrI18n("err.utmEastRange");
 5843:   if (utm.northing < 0 || utm.northing > 10000000) throw new ErrI18n("err.utmNorthRange");
