 8497: /* ========================= SECTION 14H: AUTO-PASTE FROM CLIPBOARD ========================= */
 8498: async function maybeAutoPaste(textarea){
 8499:   if (!textarea || textarea.value.trim()) return;
 8500:   if (!navigator.clipboard || !navigator.clipboard.readText) return;
 8501:   try {
 8502:     const txt = await navigator.clipboard.readText();
 8503:     if (!txt) return;
 8504:     const s = txt.trim();
 8505:     if (!s || s.length > 500) return;
 8506:     // Heuristic: only fill if it plausibly looks like a coordinate
 8507:     const looksMGRS   = /^\s*\d{1,2}\s*[A-Z]\s*[A-Z]{2}\s*\d/i.test(s);
 8508:     const looksUTM    = /^\s*\d{1,2}\s*[A-Z]\s*\d{3,}/i.test(s);
 8509:     const looksLatLon = /[NSEW]/i.test(s) || /-?\d+\.\d+\s*[,;\s]\s*-?\d+\.\d+/.test(s);
 8510:     if (looksMGRS || looksUTM || looksLatLon){
 8511:       textarea.value = s;
 8512:       try { textarea.setSelectionRange(0, s.length); } catch(_){}
 8513:     }
 8514:   } catch(_){ /* clipboard denied or not available — ignore silently */ }
 8515: }
