13762: /**
13763:  * Build a composite result card that hosts several formats as inline tabs.
13764:  * A single Copy button lives in the header and always reflects the active
13765:  * tab's copy text — clicking a tab switches both the visible panel and
13766:  * the Copy target in one gesture.
13767:  *
13768:  * @param {string} compositeKind "LATLON" (DD/DDM/DMS) or "GRID" (MGRS/UTM).
13769:  * @param {Array<{kind:string,label:string,body:string,copyText:string}>} tabs
13770:  * @param {string} initialActive the kind of the tab to open first (must be
13771:  *        one of the tab kinds; falls back to the first tab if not found).
13772:  */
13773: function makeMultiCard(compositeKind, tabs, initialActive){
13774:   const card = document.createElement("div");
13775:   card.className = "result-card result-card-multi";
13776:   card.dataset.kind = compositeKind;
13777: 
13778:   let activeIdx = tabs.findIndex(tb => tb.kind === initialActive);
13779:   if (activeIdx < 0) activeIdx = 0;
13780:   const active = tabs[activeIdx];
13781:   card.dataset.active = active.kind;
13782: 
13783:   const tabsHTML = tabs.map((tb, i) =>
13784:     `<button type="button" class="tab-btn ${i === activeIdx ? "active" : ""}" data-tab="${esc(tb.kind)}" data-tip="${esc(tb.label)}">${esc(tb.kind)}</button>`
13785:   ).join("");
13786: 
13787:   const panelsHTML = tabs.map((tb, i) =>
13788:     `<div class="tab-panel ${i === activeIdx ? "active" : ""}" data-tab="${esc(tb.kind)}">${tb.body}</div>`
13789:   ).join("");
13790: 
13791:   const activeCopy = active.copyText || "";
13792:   card.innerHTML = `
13793:     <div class="result-head">
13794:       <div class="result-head-tabs" role="tablist" aria-label="${esc(t("res.formats") || "Formati")}">${tabsHTML}</div>
13795:       <button class="btn btn-sm copy-btn" data-copy="${esc(activeCopy)}" data-tip="${esc(t("tip.copy"))}">${t("btn.copy")}</button>
13796:     </div>
13797:     <div class="result-body">${panelsHTML}</div>`;
13798: 
13799:   const copyBtn = card.querySelector(".copy-btn");
13800:   card.querySelectorAll(".tab-btn").forEach(btn => {
13801:     btn.addEventListener("click", () => {
13802:       const kind = btn.dataset.tab;
13803:       const target = tabs.find(tb => tb.kind === kind);
13804:       if (!target) return;
13805:       card.querySelectorAll(".tab-btn").forEach(b => b.classList.toggle("active", b === btn));
13806:       card.querySelectorAll(".tab-panel").forEach(p => p.classList.toggle("active", p.dataset.tab === kind));
13807:       card.dataset.active = kind;
13808:       if (copyBtn) copyBtn.dataset.copy = target.copyText || "";
13809:       // Remember the user's preferred sub-format so subsequent conversions
13810:       // open on the same tab.
13811:       state.compositeTab = state.compositeTab || {};
13812:       state.compositeTab[compositeKind] = kind;
13813:       saveStore();
13814:     });
13815:   });
13816: 
13817:   return card;
13818: }
