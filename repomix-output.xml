12222: function trackRenamePoint(id, name){
12223:   ensureTrackState();
12224:   const p = state.track.points.find(x => x.id === id);
12225:   if (!p) return;
12226:   p.name = String(name || "").slice(0, 60);
12227:   saveStore();
12228: }
