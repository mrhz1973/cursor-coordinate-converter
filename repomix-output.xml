 9929: function renderMiniMap(lat, lon, resetView = true){
 9930:   state.lastPoint = { lat, lon };
 9931:   if (resetView) state.viewCenter = { lat, lon };
 9932:   const root = document.getElementById("miniMap");
 9933:   if (!root) return;
 9934:   // Always render the tile map: when offline, hydrateMapTiles() will serve
 9935:   // cached tiles from IndexedDB and show a "?" placeholder for missing ones.
 9936:   // This keeps the cached satellite/street imagery visible offline instead
 9937:   // of reverting to the schematic SVG map. Users can still force the SVG
 9938:   // fallback via the layers menu if needed.
