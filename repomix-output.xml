12398: /** Render summary row with counts, total distance, area (if polygon), ETA. */
12399: function renderTrackSummary(){
12400:   const root = document.getElementById("track-summary");
12401:   if (!root) return;
12402:   ensureTrackState();
12403:   const pts = state.track.points;
12404:   if (pts.length < 2){ root.innerHTML = ""; return; }
12405:   let distM = 0;
12406:   try { distM = routeDistance(pts, !!state.track.closed); } catch(_){}
12407:   const walkEta = distM / (4 * 1000 / 3600);   // 4 km/h
12408:   const carEta  = distM / (60 * 1000 / 3600);  // 60 km/h
12409:   let areaHtml = "";
12410:   if (state.track.closed && pts.length >= 3){
12411:     try {
12412:       const areaM2 = sphericalPolygonArea(pts);
12413:       areaHtml = `<div class="ts-cell">
12414:         <span class="ts-label">${esc(t("track.area"))}</span>
12415:         <span class="ts-value">${fmtArea(areaM2 / 1e6, areaM2, areaM2 / 1e4)}</span>
12416:       </div>`;
12417:     } catch(_){}
12418:   }
12419:   root.innerHTML = `
12420:     <div class="track-summary">
12421:       <div class="ts-cell">
12422:         <span class="ts-label">${esc(t("track.points"))}</span>
12423:         <span class="ts-value">${pts.length}</span>
12424:       </div>
12425:       <div class="ts-cell">
12426:         <span class="ts-label">${esc(t("track.distance"))}</span>
12427:         <span class="ts-value">${fmtDistMetric(distM)}</span>
12428:       </div>
12429:       ${areaHtml}
12430:       <div class="ts-cell">
12431:         <span class="ts-label">${esc(t("track.etaWalk"))}</span>
12432:         <span class="ts-value">${fmtEta(walkEta)}</span>
12433:       </div>
12434:       <div class="ts-cell">
12435:         <span class="ts-label">${esc(t("track.etaCar"))}</span>
12436:         <span class="ts-value">${fmtEta(carEta)}</span>
12437:       </div>
12438:     </div>
12439:   `;
12440: }
