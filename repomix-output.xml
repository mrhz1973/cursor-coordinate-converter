11882: // ============ PERSISTENT OVERLAY + RESIZE HANDLES ============
11883: 
11884: /** Draw the persistent bbox overlay inside the .tile-layer so it pans
11885:  *  with the map. Called from renderTileMap when state.bboxSelection is set. */
11886: function drawBboxOverlay(tileMap){
11887:   if (!tileMap) return;
11888:   // Remove stale overlay
11889:   const old = tileMap.querySelector(".bbox-overlay");
11890:   if (old) old.remove();
11891:   const root = document.getElementById("miniMap");
11892:   if (!root) return;
11893:   const b = state.bboxSelection;
11894:   if (!b) return;
11895:   const tileLayer = tileMap.querySelector(".tile-layer");
11896:   if (!tileLayer) return;
11897: 
11898:   // Project 4 corners to px relative to the viewport
11899:   const pxNW = tileMapLatLonToPx(root, b.n, b.w);
11900:   const pxSE = tileMapLatLonToPx(root, b.s, b.e);
11901:   const left = Math.min(pxNW.x, pxSE.x);
11902:   const top  = Math.min(pxNW.y, pxSE.y);
11903:   const w    = Math.abs(pxSE.x - pxNW.x);
11904:   const h    = Math.abs(pxSE.y - pxNW.y);
11905: 
11906:   // The overlay is positioned inside .tile-layer, so we need to offset
11907:   // it by the tile-layer's current transform (it's translated during pan).
11908:   // Simpler: we add it as a sibling of .tile-layer inside .tile-map,
11909:   // which uses the same pixel origin as the viewport. However tile-layer
11910:   // is translated during drag — here we want it to follow the tiles,
11911:   // so we DO put it inside tile-layer.
11912:   // The coords we just computed are relative to the viewport, but
11913:   // tile-layer is at transform:translate(dx,dy). We need to un-apply
11914:   // that transform. Read current transform matrix:
11915:   const style = tileLayer.style.transform || "";
11916:   let tx = 0, ty = 0;
11917:   const m = style.match(/translate\(\s*(-?\d+(?:\.\d+)?)px\s*,\s*(-?\d+(?:\.\d+)?)px\s*\)/);
11918:   if (m){ tx = parseFloat(m[1]); ty = parseFloat(m[2]); }
11919: 
11920:   const overlay = document.createElement("div");
11921:   overlay.className = "bbox-overlay";
11922:   overlay.style.left = (left - tx) + "px";
11923:   overlay.style.top  = (top  - ty) + "px";
11924:   overlay.style.width  = Math.max(4, w) + "px";
11925:   overlay.style.height = Math.max(4, h) + "px";
11926:   overlay.innerHTML = `
11927:     <div class="bbox-handle h-nw" data-handle="nw" title="resize"></div>
11928:     <div class="bbox-handle h-ne" data-handle="ne" title="resize"></div>
11929:     <div class="bbox-handle h-sw" data-handle="sw" title="resize"></div>
11930:     <div class="bbox-handle h-se" data-handle="se" title="resize"></div>
11931:     <button type="button" class="bbox-remove" title="Remove">×</button>
11932:   `;
11933:   tileLayer.appendChild(overlay);
11934: 
11935:   // Remove button
11936:   overlay.querySelector(".bbox-remove").addEventListener("click", (ev) => {
11937:     ev.stopPropagation();
11938:     ev.preventDefault();
11939:     clearBboxSelection();
11940:   });
11941: 
11942:   // Resize handles
11943:   overlay.querySelectorAll(".bbox-handle").forEach(h => {
11944:     attachResizeHandle(h, overlay, tileMap, root);
11945:   });
11946: }
11947: 
11948: /**
11949:  * Draw an offline-coverage overlay on the tile map:
11950:  *   - toggles `.coverage-on` on `.tile-map` so cached (mission) tiles get
11951:  *     a soft green tint via CSS (real-time "what's in cache at this zoom");
11952:  *   - draws a dashed green rectangle + label for every saved named area
11953:  *     inside `.tile-layer` so it pans along with the tiles;
11954:  *   - rectangles whose z0..z1 range does NOT include the current zoom are
11955:  *     rendered as dotted amber (saved-area boundary but not actually cached
11956:  *     at this zoom level — a visual hint that you need to zoom in/out).
11957:  * Cheap to call (no DOM beyond visible areas); safe to re-run on every
11958:  * pan / zoom / render.
11959:  */
11960: function drawCoverageOverlay(tileMap){
11961:   if (!tileMap) return;
11962:   // Always clean up previous rectangles, even if coverage is now off.
11963:   tileMap.querySelectorAll(".named-cov").forEach(n => n.remove());
11964:   const on = state.showCoverage !== false;
11965:   tileMap.classList.toggle("coverage-on", on);
11966:   if (!on) return;
11967: 
11968:   const root = document.getElementById("miniMap");
11969:   const tileLayer = tileMap.querySelector(".tile-layer");
11970:   if (!root || !tileLayer) return;
11971: 
11972:   const areas = state.namedAreas || [];
11973:   if (!areas.length) return;
11974: 
11975:   // Un-apply the tile-layer's pan transform so our coords match the tiles.
11976:   const m = (tileLayer.style.transform || "")
11977:     .match(/translate\(\s*(-?\d+(?:\.\d+)?)px\s*,\s*(-?\d+(?:\.\d+)?)px\s*\)/);
11978:   const tx = m ? parseFloat(m[1]) : 0;
11979:   const ty = m ? parseFloat(m[2]) : 0;
11980:   const curZ = state.mapZoom || 11;
11981:   const vw   = root.clientWidth  || 400;
11982:   const vh   = root.clientHeight || 400;
11983: 
11984:   areas.forEach(a => {
11985:     const pxNW = tileMapLatLonToPx(root, a.n, a.w);
11986:     const pxSE = tileMapLatLonToPx(root, a.s, a.e);
11987:     const left = Math.min(pxNW.x, pxSE.x);
11988:     const top  = Math.min(pxNW.y, pxSE.y);
11989:     const w    = Math.abs(pxSE.x - pxNW.x);
11990:     const h    = Math.abs(pxSE.y - pxNW.y);
11991:     // Skip rectangles fully outside the viewport (with a small margin).
11992:     if (left + w < -80 || top + h < -80 || left > vw + 80 || top > vh + 80) return;
11993: 
11994:     const el = document.createElement("div");
11995:     el.className = "named-cov";
11996:     el.style.left   = (left - tx) + "px";
11997:     el.style.top    = (top  - ty) + "px";
11998:     el.style.width  = Math.max(8, w) + "px";
11999:     el.style.height = Math.max(8, h) + "px";
12000: 
12001:     let zTag = "";
12002:     let outOfZoom = false;
12003:     if (Number.isFinite(a.z0) && Number.isFinite(a.z1)){
12004:       zTag = " · z" + (a.z0 === a.z1 ? a.z0 : (a.z0 + "-" + a.z1));
12005:       if (curZ < a.z0 || curZ > a.z1){
12006:         outOfZoom = true;
12007:         el.classList.add("out-of-zoom");
12008:       }
12009:     }
12010: 
12011:     // ---- Smart placement for label & remove button ----
12012:     // Compute the visible intersection of this rectangle with the viewport
12013:     // and anchor label + X inside it. That way when the user pans so that
12014:     // the rectangle's NW corner is off-screen, label and button slide to
12015:     // stay inside the visible portion — always reachable, never clipped.
12016:     const visL = Math.max(0, left);
12017:     const visT = Math.max(0, top);
12018:     const visR = Math.min(vw, left + w);
12019:     const visB = Math.min(vh, top + h);
12020:     const usableW = Math.max(0, visR - visL);
12021:     const usableH = Math.max(0, visB - visT);
12022:     // In element-local coords the visible top-left is at:
12023:     const innerL = visL - left;   // non-negative offset from el.left
12024:     const innerT = visT - top;    // non-negative offset from el.top
12025: 
12026:     const label = document.createElement("div");
12027:     label.className = "named-cov-label";
12028:     label.textContent = (a.name || "Area") + zTag + (outOfZoom ? " ⚠" : "");
12029:     label.title = outOfZoom
12030:       ? (t("cov.outOfZoom") || ("Zoom " + curZ + " fuori dal range salvato"))
12031:       : (t("cov.inRange")   || "Tile scaricati per questa area");
12032:     label.style.left = (innerL + 4) + "px";
12033:     label.style.top  = (innerT + 4) + "px";
12034: 
12035:     const btn = document.createElement("button");
12036:     btn.type = "button";
12037:     btn.className = "named-cov-remove";
12038:     btn.textContent = "×";
12039:     btn.title = t("cov.removeTip") || "Rimuovi zona offline";
12040:     btn.setAttribute("aria-label", t("cov.removeTip") || "Rimuovi zona offline");
12041:     btn.addEventListener("click", (ev) => {
12042:       ev.preventDefault();
12043:       ev.stopPropagation();
12044:       confirmRemoveNamedArea(a);
12045:     });
12046:     // Place the X opposite to the label (NE of the visible area) to avoid
12047:     // visual clashes inside small rectangles.
12048:     btn.style.left = (innerL + Math.max(28, usableW - 26)) + "px";
12049:     btn.style.top  = (innerT + 4) + "px";
12050: 
12051:     el.appendChild(label);
12052:     el.appendChild(btn);
12053:     tileLayer.appendChild(el);
12054: 
12055:     // For tiny visible regions the label/button won't fit legibly → hide
12056:     // them but keep the outline. Zoom out and they reappear.
12057:     if (usableW < 60 || usableH < 30) label.style.display = "none";
12058:     if (usableW < 30 || usableH < 26) btn.style.display   = "none";
12059:   });
12060: }
