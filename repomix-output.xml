 6528: function datum3(lat, lon, fromEll, toEll, shift){
 6529:   const ecef = geoToECEF(lat, lon, fromEll);
 6530:   const sh = helmertShift(ecef, shift);
 6531:   return ecefToGeo(sh.X, sh.Y, sh.Z, toEll);
 6532: }
 6533: function datum7(lat, lon, fromEll, toEll, prm7){
 6534:   const ecef = geoToECEF(lat, lon, fromEll);
 6535:   const sh = helmert7ECEF(ecef, prm7);
 6536:   return ecefToGeo(sh.X, sh.Y, sh.Z, toEll);
