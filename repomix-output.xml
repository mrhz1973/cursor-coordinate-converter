 5628: WGS84.b = WGS84.a * (1 - WGS84.f);
 5629: WGS84.e2 = WGS84.f * (2 - WGS84.f);
 5630: WGS84.e = Math.sqrt(WGS84.e2);
 5631: WGS84.n = WGS84.f / (2 - WGS84.f);
