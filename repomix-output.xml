11314: function updatePrecacheEstimate(){
11315:   const el = document.getElementById("pcEstimate");
11316:   if (!el) return;
11317:   // Accept both "41.18" and "41,18" — Italian/French browsers type-number
11318:   // fields accept a comma; plain parseFloat("41,18") silently truncates
11319:   // to 41 and breaks the badbox check (n===s → empty selection).
11320:   const pf = (v) => parseFloat(String(v == null ? "" : v).replace(",", "."));
11321:   const pi = (v) => parseInt(String(v == null ? "" : v).replace(",", "."), 10);
11322:   const n = pf(document.getElementById("pcN")?.value);
11323:   const s = pf(document.getElementById("pcS")?.value);
11324:   const e = pf(document.getElementById("pcE")?.value);
11325:   const w = pf(document.getElementById("pcW")?.value);
11326:   const z0 = pi(document.getElementById("pcZ0")?.value);
11327:   const z1 = pi(document.getElementById("pcZ1")?.value);
11328:   if (![n, s, e, w, z0, z1].every(Number.isFinite)) { el.textContent = ""; return; }
11329:   if (n <= s || w > e || z0 > z1){ el.textContent = t("offcache.badbox"); return; }
11330:   const c = countBboxTiles(n, s, e, w, z0, z1);
11331:   const mb = (c * 20) / 1024; // ~20 KB / tile
11332:   el.textContent = t("offcache.estimate") + ": " + c + " · " + t("offcache.mb") + " ≈ " + (mb < 0.1 ? "<0.1" : mb.toFixed(0)) + " MB";
11333: }
