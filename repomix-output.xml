 2218: /* ========= FLOATING AUTHOR BADGE (bottom-right monogram) =========
 2219:  * Discreet circular chip with the author's initials. Opacity is low by
 2220:  * default and rises on hover so it never interferes with the UI while still
 2221:  * asserting authorship. Hidden when printing. */
 2222: .sig-badge{
 2223:   position:fixed; right:14px; bottom:14px; z-index:7000;
 2224:   width:40px; height:40px; border-radius:50%;
 2225:   border:1px solid var(--border);
 2226:   background:linear-gradient(145deg, var(--accent), #1e40af);
 2227:   color:#fff; cursor:pointer;
 2228:   display:flex; align-items:center; justify-content:center;
 2229:   font-weight:700; font-size:.78rem; letter-spacing:.08em;
 2230:   box-shadow:0 4px 14px rgba(0,0,0,.35);
 2231:   opacity:.55; transition:opacity .18s ease, transform .18s ease, box-shadow .18s ease;
 2232:   font-family:inherit; padding:0; line-height:1;
 2233: }
 2234: .sig-badge:hover,
 2235: .sig-badge:focus-visible{
 2236:   opacity:1; transform:translateY(-2px) scale(1.04);
 2237:   box-shadow:0 8px 22px rgba(0,0,0,.45);
 2238:   outline:none;
 2239: }
