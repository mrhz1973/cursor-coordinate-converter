14078:     // Persist the locality so exports / post-load displays don't need a
14079:     // fresh reverse lookup (and keep working offline).
14080:     locality: loc ? (loc.display_name || "") : "",
14081:     meta: r.meta || null
14082:   });
14083:   // Keep at most 200 favorites to avoid storage bloat
14084:   if (state.favorites.length > 200) state.favorites.length = 200;
14085:   renderFavorites();
14086:   saveStore();
14087:   // Give quick visual feedback in the pasteStatus line
14088:   const st = document.getElementById("pasteStatus");
14089:   if (st){ st.textContent = t("fav.saved"); st.className = "ok"; setTimeout(() => { if (st.textContent === t("fav.saved")) { st.textContent = ""; st.className = ""; } }, 2000); }
