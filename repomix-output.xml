 6131: /* ========================= SECTION 9: UTM FORWARD ========================= */
 6132: /**
 6133:  * Lat/Lon → UTM (serie di Krüger a 6 termini) + fattore di scala k e convergenza γ.
 6134:  * Gestisce override zona per Norvegia (32V) e Svalbard (31X, 33X, 35X, 37X).
 6135:  */
 6136: function latLonToUTM(lat, lon){
 6137:   if (lat < -80 || lat > 84) throw new ErrI18n("err.outRange");
 6138:   let zone = Math.floor((lon + 180) / 6) + 1;
 6139:   if (zone > 60) zone = 60;
 6140:   // Norway
 6141:   if (lat >= 56 && lat < 64 && lon >= 3 && lon < 12) zone = 32;
 6142:   // Svalbard
 6143:   if (lat >= 72 && lat < 84){
 6144:     if (lon >= 0  && lon <  9) zone = 31;
 6145:     else if (lon >=  9 && lon < 21) zone = 33;
 6146:     else if (lon >= 21 && lon < 33) zone = 35;
 6147:     else if (lon >= 33 && lon < 42) zone = 37;
 6148:   }
 6149:   const cm = (zone - 1) * 6 - 180 + 3;
 6150:   const phi  = lat * DEG;
 6151:   const dlam = (lon - cm) * DEG;
 6152: 
 6153:   const e = WGS84.e, A = WGS84.A, k0 = WGS84.k0, a = WGS84.a;
 6154:   const t = Math.tan(phi);
 6155:   const sigma = Math.sinh(e * Math.atanh(e * t / Math.sqrt(1 + t*t)));
 6156:   const tp = t * Math.sqrt(1 + sigma*sigma) - sigma * Math.sqrt(1 + t*t);
 6157: 
 6158:   const xiP  = Math.atan2(tp, Math.cos(dlam));
 6159:   const etaP = Math.asinh(Math.sin(dlam) / Math.sqrt(tp*tp + Math.cos(dlam)*Math.cos(dlam)));
 6160: 
 6161:   let xi = xiP, eta = etaP;
 6162:   let pPart = 1, qPart = 0;
 6163:   for (let j = 1; j <= 6; j++){
 6164:     const aj = WGS84.alpha[j-1];
 6165:     xi  += aj * Math.sin(2*j*xiP) * Math.cosh(2*j*etaP);
 6166:     eta += aj * Math.cos(2*j*xiP) * Math.sinh(2*j*etaP);
 6167:     pPart += 2*j*aj * Math.cos(2*j*xiP) * Math.cosh(2*j*etaP);
 6168:     qPart += 2*j*aj * Math.sin(2*j*xiP) * Math.sinh(2*j*etaP);
 6169:   }
 6170: 
 6171:   const x = k0 * A * eta;
 6172:   const y = k0 * A * xi;
 6173:   const easting  = 500000 + x;
 6174:   const hemisphere = lat >= 0 ? "N" : "S";
 6175:   let northing = y;
 6176:   if (hemisphere === "S") northing += 10000000;
 6177: 
 6178:   // Meridian convergence γ = γ' + γ''
 6179:   const gammaP  = Math.atan2(tp * Math.tan(dlam), Math.sqrt(1 + tp*tp));
 6180:   const gammaPP = Math.atan2(qPart, pPart);
 6181:   const gamma   = (gammaP + gammaPP) * RAD;
 6182: 
 6183:   // Scale factor k = k0 * (A/a) * √((1 + ((1-n)/(1+n))²·tan²φ) / (tp²+cos²Δλ)·(1+tp²)) * √(p²+q²)
 6184:   const sinLat = Math.sin(phi);
 6185:   const kFact1 = Math.sqrt((1 - WGS84.e2 * sinLat*sinLat) * (1 + t*t) / (tp*tp + Math.cos(dlam)*Math.cos(dlam)));
 6186:   const kFact2 = (A/a) * Math.sqrt(pPart*pPart + qPart*qPart);
 6187:   const k = k0 * kFact1 * kFact2;
 6188: 
 6189:   return {
 6190:     zone, hemisphere, easting, northing,
 6191:     k, gamma,
 6192:     band: latitudeBand(lat)
 6193:   };
 6194: }
