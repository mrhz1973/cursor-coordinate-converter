  134: /* --- "Chip" — a select wrapped with a leading icon + chevron,
  135:  * so the dropdown feels like a native toolbar pill instead of a
  136:  * raw <select>. The <select> itself is invisible-but-accessible
  137:  * (opacity=0 over the whole chip) so native OS menus still work. */
  138: .header-ctrls .hdr-chip{
  139:   position:relative; display:inline-flex; align-items:center; gap:6px;
  140:   height:34px; padding:0 26px 0 10px;
  141:   background:var(--panel2); border:1px solid var(--border);
  142:   border-radius:8px; cursor:pointer;
  143:   font-size:.82rem; font-weight:600; color:var(--text);
  144:   transition:border-color .15s ease, background .15s ease, box-shadow .15s ease;
  145: }
  146: .header-ctrls .hdr-chip:hover{
  147:   border-color:var(--accent);
  148:   background:var(--panel);
  149:   box-shadow:0 1px 3px rgba(0,0,0,.08);
  150: }
  151: .header-ctrls .hdr-chip:focus-within{
  152:   border-color:var(--accent);
  153:   box-shadow:0 0 0 3px rgba(37,99,235,.2);
  154: }
  155: .header-ctrls .hdr-chip-ico{ font-size:.95rem; line-height:1 }
  156: .header-ctrls .hdr-chip-label{ color:var(--muted); font-size:.75rem; font-weight:500 }
  157: .header-ctrls .hdr-chip-chev{
  158:   position:absolute; right:8px; top:50%; transform:translateY(-50%);
  159:   color:var(--muted); font-size:.8rem; pointer-events:none;
  160:   transition:color .15s ease;
  161: }
  162: .header-ctrls .hdr-chip:hover .hdr-chip-chev{ color:var(--accent) }
  163: .header-ctrls .hdr-chip-select{
  164:   position:absolute; inset:0;
  165:   width:100%; height:100%;
  166:   margin:0; padding:0 26px 0 10px;
  167:   border:none; outline:none; background:transparent;
  168:   color:transparent; /* native text hidden, chip renders its own */
  169:   font-size:.82rem; font-weight:600; cursor:pointer;
  170:   appearance:none; -webkit-appearance:none; -moz-appearance:none;
  171: }
  172: .header-ctrls .hdr-chip-select option{
  173:   color:var(--text); background:var(--panel);
  174: }
  175: /* Keep the currently selected value visible for the primary format chip
  176:  * (since format labels are short like "MGRS"): show it between the
  177:  * chip label and the chevron via a :not() trick — the select's first
  178:  * text child is rendered invisible, but we mirror the value into a
  179:  * pseudo-element below via JS (see updateHdrChipValue). */
  180: .header-ctrls .hdr-chip[data-value]::after{
  181:   content:attr(data-value);
  182:   margin-left:2px;
  183:   color:var(--accent); font-weight:700; font-size:.82rem;
  184:   letter-spacing:.02em;
