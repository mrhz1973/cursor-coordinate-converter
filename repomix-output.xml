16278: function qrDownloadPng(){
16279:   const svgEl = document.querySelector("#qrSvg svg");
16280:   if (!svgEl){ return; }
16281:   const xml = new XMLSerializer().serializeToString(svgEl);
16282:   const svgBlob = new Blob([xml], { type: "image/svg+xml;charset=utf-8" });
16283:   const svgUrl = URL.createObjectURL(svgBlob);
16284:   const img = new Image();
16285:   const vb = svgEl.viewBox && svgEl.viewBox.baseVal;
16286:   const w = (vb && vb.width)  ? vb.width  : 300;
16287:   const h = (vb && vb.height) ? vb.height : 300;
16288:   img.onload = () => {
16289:     // Render at 4× resolution for crisp printing (~1200 px)
16290:     const s = 4;
16291:     const canvas = document.createElement("canvas");
16292:     canvas.width = w * s; canvas.height = h * s;
16293:     const ctx = canvas.getContext("2d");
16294:     ctx.fillStyle = "#ffffff";
16295:     ctx.fillRect(0, 0, canvas.width, canvas.height);
16296:     ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
16297:     URL.revokeObjectURL(svgUrl);
16298:     canvas.toBlob((blob) => {
16299:       const r = state.lastResult;
16300:       const stamp = new Date().toISOString().slice(0,10);
16301:       const fname = r ? `qr_${round(r.lat,4)}_${round(r.lon,4)}_${stamp}.png` : `qr_${stamp}.png`;
16302:       downloadBlob(blob, fname, "image/png");
16303:     }, "image/png");
16304:   };
16305:   img.onerror = () => { URL.revokeObjectURL(svgUrl); };
16306:   img.src = svgUrl;
16307: }
