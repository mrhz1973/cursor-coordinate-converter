14031: function nextFavPatternId(ex, cat){
14032:   const pfx = String(ex) + "-" + String(cat) + "-";
14033:   const re = new RegExp("^" + pfx.replace(/[.*+?^${}()|[\]\\]/g, "\\$&") + "(\\d+)", "i");
14034:   let max = 0;
14035:   for (const f of state.favorites) {
14036:     if (!f || !f.name) continue;
14037:     const m = f.name.match(re);
14038:     if (m) max = Math.max(max, parseInt(m[1], 10));
14039:   }
14040:   return String(max + 1).padStart(3, "0");
14041: }
14042: function addCurrentAsFavorite(){
14043:   const r = state.lastResult;
14044:   if (!r){ showError(t("err.noResult")); return; }
14045:   // Use the reverse-geocoded locality when available to produce meaningful
14046:   // default names (e.g. "Abidjan, Plateau (5.35, -4.01)") instead of the
14047:   // anonymous coordinate-only form.
14048:   const loc = state.lastLocality && Math.abs(state.lastLocality.lat - r.lat) < 1e-4 && Math.abs(state.lastLocality.lon - r.lon) < 1e-4
14049:     ? state.lastLocality : null;
14050:   const shortLocality = loc ? favNameFromLocality(loc) : "";
14051:   let name;
14052:   const patChk = document.getElementById("favNamePattern");
14053:   if (patChk && patChk.checked) {
14054:     const ex = (document.getElementById("favExTag") && document.getElementById("favExTag").value || state.favExTag || "FL26")
14055:       .trim().toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 12) || "X";
14056:     const cat = (document.getElementById("favCatTag") && document.getElementById("favCatTag").value || state.favCatTag || "PT")
14057:       .trim().toUpperCase().replace(/[^A-Z0-9-]/g, "").replace(/-+/g, "").slice(0, 8) || "PT";
14058:     state.favExTag = ex; state.favCatTag = cat;
14059:     const idn = nextFavPatternId(ex, cat);
14060:     name = ex + "-" + cat + "-" + idn;
14061:   } else {
14062:     const defName = shortLocality
14063:       ? (shortLocality + " (" + r.lat.toFixed(4) + ", " + r.lon.toFixed(4) + ")")
14064:       : (t("fav.defaultName") + " " + r.lat.toFixed(4) + ", " + r.lon.toFixed(4));
