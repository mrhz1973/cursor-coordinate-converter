 6374: /** Geodetic (lat,lon) → geocentric ECEF (X,Y,Z) on a given ellipsoid. */
 6375: function geoToECEF(latDeg, lonDeg, ell){
 6376:   const phi = latDeg * DEG, lam = lonDeg * DEG;
 6377:   const sp = Math.sin(phi), cp = Math.cos(phi);
 6378:   const N = ell.a / Math.sqrt(1 - ell.e2 * sp*sp);
 6379:   return {
 6380:     X: N * cp * Math.cos(lam),
 6381:     Y: N * cp * Math.sin(lam),
 6382:     Z: N * (1 - ell.e2) * sp
 6383:   };
 6384: }
 6385: 
 6386: /** ECEF → (lat,lon) on a given ellipsoid using the Bowring closed-form. */
 6387: function ecefToGeo(X, Y, Z, ell){
 6388:   const a = ell.a, e2 = ell.e2;
 6389:   const b  = a * Math.sqrt(1 - e2);
 6390:   const ep2 = (a*a - b*b)/(b*b);
 6391:   const p  = Math.hypot(X, Y);
 6392:   const th = Math.atan2(Z * a, p * b);
 6393:   const s = Math.sin(th), c = Math.cos(th);
 6394:   const lat = Math.atan2(Z + ep2 * b * s*s*s, p - e2 * a * c*c*c);
 6395:   const lon = Math.atan2(Y, X);
 6396:   return { lat: lat * RAD, lon: lon * RAD };
 6397: }
