13444: /**
13445:  * Watches the <img class="tile"> elements that were just rendered. If the
13446:  * vast majority error out (>= 80%) and none load within a 4 s window, the
13447:  * network is likely blocking the tile CDN — switch to the offline SVG map
13448:  * with a clear hint so the user still gets visual feedback. Common on:
13449:  *   - mobile carriers that proxy/strip third-party images
13450:  *   - corporate networks with outbound deny-lists
13451:  *   - file:// origin on a browser with strict mixed-content policies
13452:  */
13453: function monitorTileLoading(root, lat, lon){
13454:   const imgs = root.querySelectorAll(".tile-map .tile");
13455:   const total = imgs.length;
13456:   if (!total) return;
13457:   let loaded = 0, errored = 0;
13458:   let decided = false;
13459: 
13460:   const decide = () => {
13461:     if (decided) return;
13462:     // When offline (navigator.onLine=false or forceOffline), don't revert to
13463:     // the SVG map: cached tiles from IndexedDB are served by hydrateMapTiles
13464:     // and any remaining "?" placeholders are expected. The user explicitly
13465:     // chose offline mode; respect it.
13466:     if (!isEffectivelyOnline()){
13467:       decided = true;
13468:       return;
13469:     }
13470:     // If nothing loaded and at least 80% failed, fall back to SVG.
13471:     if (loaded === 0 && errored >= Math.ceil(total * 0.8)){
13472:       decided = true;
13473:       renderOfflineMiniMap(lat, lon);
13474:       const mm = document.getElementById("miniMap");
13475:       if (mm && !mm.querySelector(".tile-load-warn")){
13476:         const warn = document.createElement("div");
13477:         warn.className = "tile-load-warn";
13478:         warn.textContent = t("map.tileLoadFail") || "Tile non caricabili — mappa offline";
13479:         mm.appendChild(warn);
13480:       }
13481:     }
13482:   };
13483: 
13484:   imgs.forEach(img => {
13485:     // If a tile is already cached it may have loaded before we attached the
13486:     // handler — check naturalWidth synchronously.
13487:     if (img.complete && img.naturalWidth > 0){ loaded++; return; }
13488:     img.addEventListener("load",  () => { loaded++; if (loaded === 1) decided = true; });
13489:     img.addEventListener("error", () => {
13490:       errored++;
13491:       img.style.visibility = "hidden";
13492:       if (errored === total) decide();
13493:     });
13494:   });
13495: 
13496:   // Safety timeout in case some tiles never fire any event (e.g. hung).
13497:   setTimeout(decide, 4500);
13498: }
