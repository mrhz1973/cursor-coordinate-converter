 6322: /**
 6323:  * MGRS → Lat/Lon (centro cella se precisione ridotta) + angoli SW e NE della cella.
 6324:  * Gli angoli vengono calcolati convertendo in Lat/Lon i quattro spigoli in UTM.
 6325:  */
 6326: function mgrsToLatLonExt(str){
 6327:   const p = parseMGRS(str);
 6328:   const cs = p.cellSize; // meters
 6329:   let eCenter = p.easting, nCenter = p.northing;
 6330:   if (cs > 1){
 6331:     eCenter += cs / 2;
 6332:     nCenter += cs / 2;
 6333:   }
 6334:   const center = utmToLatLon(p.zone, p.hemisphere, eCenter, nCenter);
 6335:   const sw = utmToLatLon(p.zone, p.hemisphere, p.easting,       p.northing);
 6336:   const ne = utmToLatLon(p.zone, p.hemisphere, p.easting + cs,  p.northing + cs);
 6337:   return {
 6338:     lat: center.lat, lon: center.lon,
 6339:     precision: p.precision, cellSize: cs,
 6340:     sw, ne,
 6341:     zone: p.zone, hemisphere: p.hemisphere, band: p.band
 6342:   };
 6343: }
