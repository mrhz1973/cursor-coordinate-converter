 1157: .tile-map{
 1158:   position:relative; width:100%; aspect-ratio:1/1;
 1159:   overflow:hidden; border-radius:4px; background:#1e2a3a;
 1160:   user-select:none;
 1161:   /* Red crosshair cursor (inline SVG data URI, hotspot 12 12). Falls back
 1162:    * to the native "crosshair" keyword on browsers that can't decode the
 1163:    * data URI (older Safari in some cases). The hotspot sits precisely on
 1164:    * the center dot, which is what the CURSORE readout reports. */
 1165:   cursor:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24'><circle cx='12' cy='12' r='9' fill='none' stroke='%23ef4444' stroke-width='1.5' opacity='0.9'/><line x1='12' y1='0' x2='12' y2='7' stroke='%23ef4444' stroke-width='1.5'/><line x1='12' y1='17' x2='12' y2='24' stroke='%23ef4444' stroke-width='1.5'/><line x1='0' y1='12' x2='7' y2='12' stroke='%23ef4444' stroke-width='1.5'/><line x1='17' y1='12' x2='24' y2='12' stroke='%23ef4444' stroke-width='1.5'/><circle cx='12' cy='12' r='1.6' fill='%23ef4444'/></svg>") 12 12, crosshair;
