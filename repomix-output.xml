10888: function pickEsriDateAttr(attrs){
10889:   if (!attrs || typeof attrs !== "object") return null;
10890:   const keys = [
10891:     "SRC_DATE2","SRC_DATE","SRC_DATE1","ACQ_DATE","ACQUISITIONDATE","ACQDATE",
10892:     "S_DATE","DATE","DATE_","CAPTUREDATE","CAPTURE_DATE","IMG_DATE","IMAGEDATE"
10893:   ];
10894:   for (const k of keys){
10895:     const v = attrs[k] ?? attrs[k.toLowerCase()] ?? attrs[k.toUpperCase()];
10896:     if (v == null) continue;
10897:     // ArcGIS often returns epoch ms.
10898:     if (typeof v === "number" && Number.isFinite(v)){
10899:       const ms = v > 1e12 ? v : (v > 1e9 ? v*1000 : null);
10900:       if (ms){
10901:         const d = new Date(ms);
10902:         if (!isNaN(d)) return d;
10903:       }
10904:     }
10905:     if (typeof v === "string"){
10906:       const s = v.trim();
10907:       if (!s) continue;
10908:       const d = new Date(s);
10909:       if (!isNaN(d)) return d;
10910:     }
10911:   }
10912:   // Fallback: scan any "*date*" key.
10913:   for (const [k, v] of Object.entries(attrs)){
10914:     if (!/date/i.test(k)) continue;
10915:     if (typeof v === "number" && Number.isFinite(v)){
10916:       const ms = v > 1e12 ? v : (v > 1e9 ? v*1000 : null);
10917:       if (ms){
10918:         const d = new Date(ms);
10919:         if (!isNaN(d)) return d;
10920:       }
10921:     }
10922:     if (typeof v === "string"){
10923:       const d = new Date(v);
10924:       if (!isNaN(d)) return d;
10925:     }
10926:   }
10927:   return null;
10928: }
