12230: /** Parse a free-text bulk input (one coord per line) and append all valid
12231:  *  points to the current track. Returns { ok, fail }. */
12232: function trackAddFromText(text){
12233:   ensureTrackState();
12234:   const lines = String(text || "").split(/\r?\n/).map(l => l.trim()).filter(Boolean);
12235:   let ok = 0, fail = 0;
12236:   for (const line of lines){
12237:     try {
12238:       const d = autoDetect(line);
12239:       if (d && Number.isFinite(d.lat) && Number.isFinite(d.lon)){
12240:         // Bypass consecutive-dup check for bulk paste — each line is intentional
12241:         state.track.points.push({
12242:           id: uidNamed(),
12243:           lat: d.lat, lon: d.lon,
12244:           name: "", meta: { from: "paste" }
12245:         });
12246:         ok++;
12247:       } else { fail++; }
12248:     } catch(_){ fail++; }
12249:   }
12250:   if (state.track.points.length > 500) state.track.points.splice(0, state.track.points.length - 500);
12251:   saveStore();
12252:   renderTrackAll();
12253:   return { ok, fail };
12254: }
