11335: function onPrecacheStart(){
11336:   if (!window.indexedDB){
11337:     const st = document.getElementById("pcStatus");
11338:     if (st) st.textContent = t("offcache.noIdb");
11339:     return;
11340:   }
11341:   // Same parse helpers as updatePrecacheEstimate (see comment there).
11342:   const pf = (v) => parseFloat(String(v == null ? "" : v).replace(",", "."));
11343:   const pi = (v) => parseInt(String(v == null ? "" : v).replace(",", "."), 10);
11344:   const n = pf(document.getElementById("pcN")?.value);
11345:   const s = pf(document.getElementById("pcS")?.value);
11346:   const e = pf(document.getElementById("pcE")?.value);
11347:   const w = pf(document.getElementById("pcW")?.value);
11348:   const z0 = pi(document.getElementById("pcZ0")?.value);
11349:   const z1 = pi(document.getElementById("pcZ1")?.value);
11350:   const layerId = document.getElementById("pcLayer")?.value || "osm";
11351:   if (![n, s, e, w, z0, z1].every(Number.isFinite) || n <= s || w > e || z0 > z1 || z0 < 2 || z1 > 19){
11352:     const st = document.getElementById("pcStatus");
11353:     if (st) st.textContent = t("offcache.badbox");
11354:     return;
11355:   }
11356:   const tot = countBboxTiles(n, s, e, w, z0, z1);
11357:   if (tot === 0){ const st = document.getElementById("pcStatus"); if (st) st.textContent = t("offcache.badbox"); return; }
11358:   if (tot > MAX_PRECACHE_TILES){ const st = document.getElementById("pcStatus"); if (st) st.textContent = t("offcache.tooMany"); return; }
11359:   const bar = document.getElementById("pcBar");
11360:   const prog = document.getElementById("pcProgress");
11361:   const st = document.getElementById("pcStatus");
11362:   const btnS = document.getElementById("btnPrecacheStart");
11363:   const btnP = document.getElementById("btnPrecacheStop");
11364:   if (bar) bar.hidden = false;
11365:   if (btnP) btnP.hidden = false;
11366:   if (btnS) btnS.disabled = true;
11367:   if (prog){ prog.max = 100; prog.value = 0; }
11368:   if (st) st.textContent = t("offcache.progress");
11369:   startPrecacheDownload({ n, s, e, w, z0, z1, layerId, onProgress: (ev) => {
11370:     if (prog && ev.total) prog.value = Math.min(100, (ev.done / ev.total) * 100);
11371:     if (st) st.textContent = t("offcache.progress") + " " + ev.done + " / " + ev.total + (ev.err ? " (" + ev.err + " err)" : "");
11372:   }}).then((info) => {
11373:     if (st) st.textContent = (info && info.aborted) ? t("offcache.aborted") : t("offcache.done");
11374:     if (btnS) btnS.disabled = false;
11375:     if (btnP) btnP.hidden = true;
11376:     if (state.lastPoint) renderMiniMap(state.lastPoint.lat, state.lastPoint.lon, false);
11377:   }).catch((err) => {
11378:     if (st) st.textContent = (err && err.message === "tooMany") ? t("offcache.tooMany") : t("offcache.err");
11379:     if (btnS) btnS.disabled = false;
11380:     if (btnP) btnP.hidden = true;
11381:   });
11382: }
