11137: /** Delete a set of tile keys in one transaction. Used to wipe only the
11138:  * tiles of a specific named area (bbox × z-range × every layer), instead
11139:  * of trashing the whole IDB store. */
11140: function idbDeleteKeys(keys){
11141:   if (!keys || !keys.length) return Promise.resolve(0);
11142:   return getTileDB().then(db => new Promise((res, rej) => {
11143:     const tx = db.transaction(TILE_IDB.store, "readwrite");
11144:     let n = 0;
11145:     tx.oncomplete = () => res(n);
11146:     tx.onerror    = () => rej(tx.error);
