 6713: function wgs84ToSK42GaussKruger(lat, lon){
 6714:   const p = wgs84ToSK42(lat, lon);
 6715:   // GK 6° zones: zone 1 centered at 0° (covers -3..+3), zone 2 centered at 6°, etc.
 6716:   let lonE = p.lon;
 6717:   if (lonE < -180) lonE += 360;
 6718:   if (lonE >  180) lonE -= 360;
 6719:   const zone = Math.floor((lonE + 3) / 6) + 1;
 6720:   const lam0 = (6*(zone-1)) * DEG;
 6721: 
 6722:   const a = ELL_KRASS1940.a;
 6723:   const e2 = ELL_KRASS1940.e2;
 6724:   const latR = p.lat * DEG, lonR = p.lon * DEG;
 6725:   const sinLat = Math.sin(latR), cosLat = Math.cos(latR), tanLat = Math.tan(latR);
 6726:   const N = a / Math.sqrt(1 - e2*sinLat*sinLat);
 6727:   const T = tanLat*tanLat;
 6728:   const C = e2/(1-e2) * cosLat*cosLat;
 6729:   const A = (lonR - lam0) * cosLat;
 6730: 
 6731:   // Meridional arc (series)
 6732:   const e4 = e2*e2, e6 = e4*e2;
 6733:   const M = a*((1 - e2/4 - 3*e4/64 - 5*e6/256)*latR
 6734:             - (3*e2/8 + 3*e4/32 + 45*e6/1024)*Math.sin(2*latR)
 6735:             + (15*e4/256 + 45*e6/1024)*Math.sin(4*latR)
 6736:             - (35*e6/3072)*Math.sin(6*latR));
 6737: 
 6738:   const easting = (zone*1000000) + 500000 + (N*(A + (1-T+C)*Math.pow(A,3)/6 + (5 - 18*T + T*T + 72*C - 58*e2/(1-e2))*Math.pow(A,5)/120));
 6739:   const northing = (M + N*tanLat*(A*A/2 + (5 - T + 9*C + 4*C*C)*Math.pow(A,4)/24 + (61 - 58*T + T*T + 600*C - 330*e2/(1-e2))*Math.pow(A,6)/720));
