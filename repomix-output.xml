 8248:   const fname = `batch_${pts.length}pts_${stamp}`;
 8249:   if (kind === "gpx")          downloadBlob(buildGPX(pts),     fname + ".gpx",     "application/gpx+xml;charset=utf-8");
 8250:   else if (kind === "kml")     downloadBlob(buildKML(pts),     fname + ".kml",     "application/vnd.google-earth.kml+xml;charset=utf-8");
