14473: /**
14474:  * Sequentially reverse-geocode each valid row and update the .loc-cell in
14475:  * place. The Nominatim queue already enforces 1 req/sec, so this naturally
14476:  * stays within the public server's usage policy without extra throttling.
14477:  */
14478: async function batchFillLocalities(rows){
14479:   const prog = document.getElementById("batchLocProgress");
14480:   const fill = prog && prog.querySelector(".blp-fill");
14481:   const lbl  = prog && prog.querySelector(".blp-label");
14482:   const targets = rows.filter(r => r.ok);
14483:   if (!targets.length){ if (prog) prog.hidden = true; return; }
14484:   if (prog){ prog.hidden = false; }
14485:   let done = 0;
14486:   const setProg = () => {
14487:     const pct = Math.round(100 * done / targets.length);
14488:     if (fill) fill.style.width = pct + "%";
14489:     if (lbl)  lbl.textContent = done + " / " + targets.length;
14490:   };
14491:   setProg();
14492:   for (const r of targets){
14493:     try {
14494:       const rev = await reverseGeocode(r.lat, r.lon);
14495:       r.loc = (rev && rev.display_name) || "";
14496:     } catch(_){ r.loc = ""; }
14497:     done++;
14498:     setProg();
14499:     // Update the visible cell without re-rendering the whole table.
14500:     const cell = document.querySelector(`.batch-table tr[data-batch-idx="${rows.indexOf(r)}"] .loc-cell`);
14501:     if (cell){ cell.textContent = r.loc; cell.title = r.loc; }
14502:     // Bail out if the user flips the toggle off mid-run.
14503:     if (!state.geocodeBatchLoc) break;
14504:   }
14505:   if (prog){ prog.hidden = true; }
14506:   // Persist so reload keeps localities.
14507:   state.lastBatchRows = rows;
14508:   if (state.persist) saveStore();
14509: }
14510: function renderBatch(rows){
14511:   const root = document.getElementById("batch-results");
