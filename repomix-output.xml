13927: function pushHistory(entry){
13928:   const now = new Date();
13929:   // A source="geo" tag surfaces as "[GEO]" in the history UI, per spec.
13930:   const srcTag = (entry.meta && entry.meta.source === "geo") ? "[GEO]" : null;
13931:   // Locality is either a full reverse-geocoded payload (from state.lastLocality)
13932:   // or a short display string carried inside entry.meta.locality.
13933:   const loc = entry.meta && entry.meta.locality
13934:     ? entry.meta.locality
13935:     : (state.lastLocality && Math.abs(state.lastLocality.lat - entry.lat) < 1e-4 && Math.abs(state.lastLocality.lon - entry.lon) < 1e-4
13936:       ? state.lastLocality : null);
13937:   state.history.unshift({
13938:     lat: entry.lat, lon: entry.lon,
13939:     type: entry.meta && entry.meta.type ? entry.meta.type : "LatLon",
13940:     raw:  entry.meta && entry.meta.raw  ? entry.meta.raw  : null,
13941:     when: now.getTime(),
13942:     // Canonical Zulu DTG so history entries can be sorted / filtered / quoted
13943:     // in military comms without further conversion.
13944:     dtg:  formatDTG(now, "Z", { short: false }),
13945:     srcTag,
13946:     locality: loc ? (loc.display_name || "") : ""
13947:   });
13948:   if (state.history.length > 10) state.history.pop();
13949:   renderHistory();
13950:   if (state.persist) saveStore();
13951: }
