11152: /** Wipe all cached tiles that fall inside a named area's bbox × z-range,
11153:  * across every known basemap layer (the stored area doesn't know which
11154:  * layer was downloaded, so we're conservative and cover both). */
11155: async function deleteNamedAreaTiles(area){
11156:   if (!area || !Number.isFinite(area.n) || !Number.isFinite(area.s)) return 0;
11157:   const z0 = Number.isFinite(area.z0) ? area.z0 : 2;
11158:   const z1 = Number.isFinite(area.z1) ? area.z1 : 19;
11159:   const tiles = collectBboxTiles(area.n, area.s, area.e, area.w, z0, z1);
11160:   const keys = [];
11161:   Object.keys(TILE_LAYERS).forEach(layerId => {
11162:     tiles.forEach(t => keys.push(makeTileKey(layerId, t.z, t.x, t.y)));
