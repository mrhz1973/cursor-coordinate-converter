 9333:         <div class="line sub">${t("res.zone")}: ${u.zone} · ${t("res.hem")}: ${u.hemisphere} · ${t("res.band")}: ${u.band}</div>
 9334:         <div class="line sub">${t("res.east")}: ${Math.round(u.easting)} m · ${t("res.north")}: ${Math.round(u.northing)} m</div>
 9335:         <div class="line sub">${t("res.scale")} k = ${u.k.toFixed(7)} · ${t("res.conv")} γ = ${fmtGamma(u.gamma)}<span class="mils-val"> (${fmtMils(u.gamma)} ${t("unit.mils")})</span></div>`
 9336:     };
