10592: /** Current visible mini-map bbox as "left,top,right,bottom" (Nominatim viewbox format). */
10593: function currentViewBbox(){
10594:   const tm = document.querySelector("#miniMap .tile-map");
10595:   if (!tm) return null;
10596:   const w = tm.clientWidth, h = tm.clientHeight;
10597:   if (!w || !h) return null;
10598:   try {
10599:     const nw = tileMapPxToLatLon(tm, 0, 0);
10600:     const se = tileMapPxToLatLon(tm, w, h);
10601:     if (!nw || !se) return null;
10602:     // viewbox order per Nominatim: left(lon), top(lat), right(lon), bottom(lat)
10603:     return `${nw.lon},${nw.lat},${se.lon},${se.lat}`;
10604:   } catch(_){ return null; }
10605: }
