 9947: /* --- Slippy-map tile math (Web Mercator, zoom 0..19). ------------------- */
 9948: function lonToTileX(lon, z){ return (lon + 180) / 360 * Math.pow(2, z); }
 9949: function latToTileY(lat, z){
 9950:   const r = lat * DEG;
 9951:   return (1 - Math.log(Math.tan(r) + 1/Math.cos(r)) / Math.PI) / 2 * Math.pow(2, z);
 9952: }
 9953: /* Inverse projections, used when converting pan offsets back into lat/lon. */
 9954: function tileX2Lon(x, z){ return x / Math.pow(2, z) * 360 - 180; }
 9955: function tileY2Lat(y, z){
 9956:   const n = Math.PI - 2 * Math.PI * y / Math.pow(2, z);
 9957:   return RAD * Math.atan(0.5 * (Math.exp(n) - Math.exp(-n)));
 9958: }
 9959: /* Wrap longitude into the canonical [-180, +180] range (pan across antimeridian). */
 9960: function normalizeLon(lon){
 9961:   let x = ((lon + 180) % 360 + 360) % 360 - 180;
 9962:   if (x === -180) x = 180;
 9963:   return x;
 9964: }
