 6073: /* ========================= SECTION 8: MGRS PARSER ========================= */
 6074: function parseMGRS(str){
 6075:   let s = String(str || "").trim().toUpperCase();
 6076:   if (!s) throw new ErrI18n("err.empty");
 6077:   // Strip optional "MGRS" label, then remove all non-alnum (spaces, dashes, colons, etc.)
 6078:   s = s.replace(/^MGRS[:=\s-]*/,"");
 6079:   s = s.replace(/[^\dA-Z]/g,"");
 6080:   const m = s.match(/^(\d{1,2})([C-HJ-NP-X])([A-HJ-NP-Z])([A-HJ-NP-V])(\d*)$/);
 6081:   if (!m) throw new ErrI18n("err.mgrsInvalid");
 6082:   const zone = parseInt(m[1],10);
 6083:   const band = m[2], col = m[3], row = m[4];
 6084:   const digits = m[5];
 6085:   if (!(zone >= 1 && zone <= 60)) throw new ErrI18n("err.utmZone");
 6086:   if (digits.length % 2 !== 0 || digits.length > 10) throw new ErrI18n("err.mgrsInvalid");
 6087: 
 6088:   const half = digits.length / 2;   // precision: 5=1m, 4=10m, 3=100m, 2=1km, 1=10km, 0=100km
 6089:   const cellSize = Math.pow(10, 5 - half); // meters
 6090:   let eFrac = 0, nFrac = 0;
 6091:   if (half > 0){
 6092:     eFrac = parseInt(digits.substring(0, half),10) * cellSize;
 6093:     nFrac = parseInt(digits.substring(half), 10) * cellSize;
 6094:   }
 6095: 
 6096:   const setIdx = (zone - 1) % 3;
 6097:   const colIdx = MGRS_COL_SETS[setIdx].indexOf(col);
 6098:   if (colIdx < 0) throw new ErrI18n("err.mgrsInvalid");
 6099:   const e100k = (colIdx + 1) * 100000;
 6100: 
 6101:   const rowSet = (zone % 2 === 1) ? MGRS_ROW_ODD : MGRS_ROW_EVEN;
 6102:   const rowIdx = rowSet.indexOf(row);
 6103:   if (rowIdx < 0) throw new ErrI18n("err.mgrsInvalid");
 6104:   let n100k = rowIdx * 100000;
 6105: 
 6106:   // Resolve ambiguity of 2,000,000 m cycles via latitude band
 6107:   const bandIdx = LAT_BANDS.indexOf(band);
 6108:   if (bandIdx < 0) throw new ErrI18n("err.mgrsBand");
 6109:   const bandLatMin = -80 + bandIdx * 8;
 6110:   const bandLatMax = (band === "X") ? 84 : (bandLatMin + 8);
 6111:   const bandLatMid = (bandLatMin + bandLatMax) / 2;
 6112: 
 6113:   // Approximate northing at the central meridian of this zone for the middle latitude of the band
 6114:   const cm = (zone - 1) * 6 - 180 + 3;
 6115:   const approxN = latLonToUTM(bandLatMid, cm).northing;
 6116:   const cycles = Math.round((approxN - n100k) / 2000000);
 6117:   n100k += cycles * 2000000;
 6118: 
 6119:   const hemisphere = (band >= "N") ? "N" : "S";
 6120:   const easting  = e100k + eFrac;
 6121:   const northing = n100k + nFrac;
 6122: 
 6123:   return {
 6124:     zone, hemisphere, band, col, row,
 6125:     easting, northing,
 6126:     precision: half, cellSize,
 6127:     e100kFloor: e100k + eFrac, n100kFloor: n100k + nFrac
 6128:   };
 6129: }
