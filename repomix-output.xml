 6856: /* ========================= SECTION 12b: PLUS CODE (Open Location Code) =========================
 6857:    Reference: https://github.com/google/open-location-code — spec v1.0.3
 6858:    - 20-char alphabet, base-20 pair encoding for the first 10 chars (+ separator at pos 8).
 6859:    - Optional grid refinement (5 rows × 4 cols) for chars 11+.
 6860:    - Length 10 ≈ 13.9 m × 13.9 m cell; length 11 ≈ 2.8 m × 3.5 m (still global).
 6861:    - 100% deterministic, offline, WGS84 lat/lon.                                                */
 6862: const OLC_ALPHABET = "23456789CFGHJMPQRVWX";
 6863: const OLC_SEPARATOR = "+";
 6864: const OLC_SEPARATOR_POS = 8;
 6865: const OLC_PAIR_LEN = 10;
 6866: const OLC_GRID_LEN = 5;
 6867: const OLC_GRID_ROWS = 5;
 6868: const OLC_GRID_COLS = 4;
 6869: const OLC_LAT_MAX = 90;
 6870: const OLC_LON_MAX = 180;
 6871: const OLC_PAIR_PRECISION = 8000; // 20^3
 6872: const OLC_FINAL_LAT_PRECISION = OLC_PAIR_PRECISION * Math.pow(OLC_GRID_ROWS, OLC_GRID_LEN); // 25e6
 6873: const OLC_FINAL_LON_PRECISION = OLC_PAIR_PRECISION * Math.pow(OLC_GRID_COLS, OLC_GRID_LEN); //  8.192e6
