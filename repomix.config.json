{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "headerText": "Tactical GIS Web App — context dump per LLM analysis.",
    "showLineNumbers": true,
    "topFilesLength": 10
  },
  "include": [
    "*.html",
    "*.md",
    "docs/**",
    ".cursor/rules/**"
  ],
  "ignore": {
    "useDefaultPatterns": true,
    "customPatterns": [
      ".DS_Store",
      "*.code-workspace",
      "repomix-output.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
