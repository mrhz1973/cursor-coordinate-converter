 8026: function buildGPX(points){
 8027:   const nowDate = new Date();
 8028:   const now     = nowDate.toISOString();
 8029:   const dtg     = formatDTG(nowDate, "Z", { short: false });
 8030:   let s = `<?xml version="1.0" encoding="UTF-8"?>\n`;
 8031:   s += `<gpx version="1.1" creator="Convertitore Coordinate" xmlns="http://www.topografix.com/GPX/1/1">\n`;
 8032:   s += `  <metadata>\n    <time>${now}</time>\n`;
 8033:   s += `    <desc>DTG: ${xmlEsc(dtg)}</desc>\n  </metadata>\n`;
 8034:   for (const p of points){
 8035:     s += `  <wpt lat="${round(p.lat,7)}" lon="${round(p.lon,7)}">\n`;
 8036:     if (p.name) s += `    <name>${xmlEsc(p.name)}</name>\n`;
 8037:     if (p.desc) s += `    <desc>${xmlEsc(p.desc)}</desc>\n`;
 8038:     s += gpxDatumExtensions(p);
 8039:     s += `  </wpt>\n`;
 8040:   }
 8041:   s += `</gpx>\n`;
 8042:   return s;
 8043: }
 8044: function buildKML(points){
 8045:   const dtg = formatDTG(new Date(), "Z", { short: false });
 8046:   let s = `<?xml version="1.0" encoding="UTF-8"?>\n`;
 8047:   s += `<kml xmlns="http://www.opengis.net/kml/2.2">\n<Document>\n`;
 8048:   s += `  <name>Convertitore Coordinate</name>\n`;
 8049:   s += `  <description>DTG: ${xmlEsc(dtg)}</description>\n`;
