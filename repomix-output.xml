 6239: /* ========================= SECTION 10: UTM INVERSE ========================= */
 6240: function utmToLatLon(zone, hem, easting, northing){
 6241:   const A = WGS84.A, k0 = WGS84.k0, e = WGS84.e;
 6242:   const x = easting - 500000;
 6243:   let y = northing;
 6244:   if (hem === "S") y -= 10000000;
 6245: 
 6246:   const xi  = y / (k0 * A);
 6247:   const eta = x / (k0 * A);
 6248: 
 6249:   let xiP = xi, etaP = eta;
 6250:   for (let j = 1; j <= 6; j++){
 6251:     const bj = WGS84.beta[j-1];
 6252:     xiP  -= bj * Math.sin(2*j*xi) * Math.cosh(2*j*eta);
 6253:     etaP -= bj * Math.cos(2*j*xi) * Math.sinh(2*j*eta);
 6254:   }
 6255: 
 6256:   const chi = Math.asin(Math.sin(xiP) / Math.cosh(etaP));
 6257:   // Inverse hyperbolic conformal latitude → geodetic latitude via series
 6258:   // Using tp = sin(chi), iterate to geodetic t
 6259:   let tp = Math.tan(chi);
 6260:   let t = tp;
 6261:   for (let i = 0; i < 10; i++){
 6262:     const sigma = Math.sinh(e * Math.atanh(e * t / Math.sqrt(1 + t*t)));
 6263:     const tNew = tp * Math.sqrt(1 + sigma*sigma) + sigma * Math.sqrt(1 + t*t);
 6264:     if (Math.abs(tNew - t) < 1e-14){ t = tNew; break; }
 6265:     t = tNew;
 6266:   }
 6267: 
 6268:   const phi = Math.atan(t);
 6269:   const dlam = Math.atan2(Math.sinh(etaP), Math.cos(xiP));
 6270:   const cm = (zone - 1) * 6 - 180 + 3;
 6271:   const lat = phi * RAD;
 6272:   const lon = cm + dlam * RAD;
 6273:   return { lat, lon };
 6274: }
