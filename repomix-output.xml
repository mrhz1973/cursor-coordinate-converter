 9627: /** Fire-and-forget reverse lookup that updates the row when it resolves. */
 9628: function scheduleReverseLookup(lat, lon, opts){
 9629:   const row = document.getElementById("localityRow");
 9630:   if (row) row.classList.add("is-loading");
 9631:   reverseGeocode(lat, lon, opts).then(d => {
 9632:     if (row) row.classList.remove("is-loading");
 9633:     // Guard against stale result: only apply if the displayed point hasn't moved.
 9634:     const lp = state.lastResult;
 9635:     if (!lp || Math.abs(lp.lat - lat) > 1e-4 || Math.abs(lp.lon - lon) > 1e-4) return;
 9636:     state.lastLocality = d ? Object.assign({}, d, { lat, lon }) : null;
 9637:     updateLocalityRow(lat, lon, d);
 9638:     // Ripaint derived UI that uses the locality (history/favorites).
 9639:     try { renderHistory(); } catch(_){}
 9640:   }).catch(() => {
 9641:     if (row) row.classList.remove("is-loading");
 9642:   });
 9643: }
