12442: /** Drag & drop reorder — simple HTML5 drag API on rows. */
12443: function attachTrackDnd(root){
12444:   let dragId = null;
12445:   root.querySelectorAll(".track-point-row[draggable='true']").forEach(row => {
12446:     row.addEventListener("dragstart", (ev) => {
12447:       dragId = row.dataset.id;
12448:       row.classList.add("dragging");
12449:       try { ev.dataTransfer.setData("text/plain", dragId); ev.dataTransfer.effectAllowed = "move"; } catch(_){}
12450:     });
12451:     row.addEventListener("dragend", () => {
12452:       row.classList.remove("dragging");
12453:       dragId = null;
12454:     });
12455:     row.addEventListener("dragover", (ev) => {
12456:       ev.preventDefault();
12457:       try { ev.dataTransfer.dropEffect = "move"; } catch(_){}
12458:     });
12459:     row.addEventListener("drop", (ev) => {
12460:       ev.preventDefault();
12461:       const src = dragId;
12462:       const dst = row.dataset.id;
12463:       if (!src || !dst || src === dst) return;
12464:       const pts = state.track.points;
12465:       const iSrc = pts.findIndex(p => p.id === src);
12466:       const iDst = pts.findIndex(p => p.id === dst);
12467:       if (iSrc < 0 || iDst < 0) return;
12468:       const [moved] = pts.splice(iSrc, 1);
12469:       pts.splice(iDst, 0, moved);
12470:       saveStore();
12471:       renderTrackAll();
12472:     });
12473:   });
12474: }
