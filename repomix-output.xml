12638: /** Import points from a file (GPX/KML/GeoJSON/CSV). Appends, doesn't replace. */
12639: function importTrackFile(file){
12640:   if (!file) return;
12641:   const reader = new FileReader();
12642:   reader.onload = () => {
12643:     const text = String(reader.result || "");
12644:     const name = file.name || "";
12645:     let parsed = null;
12646:     try { parsed = parseImportedText(text, name); } catch(_){}
12647:     if (!parsed || !Array.isArray(parsed.points) || !parsed.points.length){
12648:       setBadge("error", t("err.importFailed") || "Import failed.");
12649:       return;
12650:     }
12651:     ensureTrackState();
12652:     parsed.points.forEach(p => {
12653:       if (Number.isFinite(p.lat) && Number.isFinite(p.lon)){
12654:         state.track.points.push({
12655:           id: uidNamed(),
12656:           lat: p.lat, lon: p.lon,
12657:           name: String(p.name || "").slice(0, 60),
12658:           meta: { from: "import", filename: name }
12659:         });
12660:       }
12661:     });
12662:     if (state.track.points.length > 500) state.track.points.splice(0, state.track.points.length - 500);
12663:     saveStore();
12664:     renderTrackAll();
12665:     setBadge("success", t("track.importedN").replace("{0}", parsed.points.length));
12666:   };
12667:   reader.readAsText(file);
12668: }
