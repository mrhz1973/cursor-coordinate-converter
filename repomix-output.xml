11531: /** Approximate bbox size in km along center latitude. */
11532: function bboxSizeKm(b){
11533:   const meanLat = (b.n + b.s) / 2;
11534:   const kmPerDegLat = 111.32;
11535:   const kmPerDegLon = 111.32 * Math.cos(meanLat * DEG);
11536:   const widthKm  = (b.e - b.w) * kmPerDegLon;
11537:   const heightKm = (b.n - b.s) * kmPerDegLat;
11538:   return { widthKm: Math.max(0, widthKm), heightKm: Math.max(0, heightKm) };
11539: }
