10405: /**
10406:  * Wire up the Geocoding card: autocomplete with 400ms debounce, dropdown,
10407:  * filters (country / viewbox), keyboard navigation (↑/↓/Enter/Esc), and
10408:  * the OPSEC-disabled mode via state.opsecStrict.
10409:  *
10410:  * The callback uses a generation counter so stale queries that complete
10411:  * after a newer one are ignored.
10412:  */
10413: function bindGeocode(){
10414:   const card     = document.getElementById("geocodeCard");
10415:   const input    = document.getElementById("geoInput");
10416:   const btn      = document.getElementById("btnGeoSearch");
10417:   const listEl   = document.getElementById("geoResults");
10418:   const country  = document.getElementById("geoCountry");
10419:   const bboxCb   = document.getElementById("geoBbox");
10420:   if (!card || !input || !listEl) return;
10421: 
10422:   // Reflect the strict-OPSEC / disabled state up-front.
10423:   const refreshCardState = () => {
10424:     card.classList.toggle("geo-disabled", !state.geocodeEnabled || state.opsecStrict);
10425:   };
10426:   refreshCardState();
10427:   card._refreshGeoCard = refreshCardState;
10428: 
10429:   let gen = 0;
10430:   let debTO = null;
10431:   let activeIdx = -1;
10432:   let activeHits = [];
10433: 
10434:   const setActive = (i) => {
10435:     activeIdx = i;
10436:     listEl.querySelectorAll(".geo-result").forEach((el, j) => {
10437:       el.classList.toggle("active", j === i);
10438:       if (j === i) el.scrollIntoView({ block: "nearest" });
10439:     });
10440:   };
10441: 
10442:   const renderEmpty = (msg) => {
10443:     listEl.hidden = false;
10444:     listEl.innerHTML = `<div class="geo-empty">${esc(msg)}</div>`;
10445:   };
10446: 
10447:   const renderHits = (hits) => {
10448:     activeHits = hits;
10449:     if (!hits.length){ renderEmpty(t("geo.noResults") || "Nessun risultato"); return; }
10450:     listEl.hidden = false;
10451:     listEl.innerHTML = hits.map((h, i) => {
10452:       const typeLbl = esc((h.class && h.type) ? (h.class + "/" + h.type) : (h.type || ""));
10453:       const offCls  = h._offline ? "is-offline" : "";
10454:       const coord = `${h.lat.toFixed(4)}, ${h.lon.toFixed(4)}`;
10455:       return `
10456:         <div class="geo-result ${offCls}" role="option" data-idx="${i}" tabindex="0">
10457:           <div class="geo-r-name">${esc(h.display_name)}</div>
10458:           <div class="geo-r-meta">
10459:             ${typeLbl ? `<span class="geo-r-type">${typeLbl}</span>` : ""}
10460:             <span>${esc(coord)}</span>
10461:           </div>
10462:         </div>`;
10463:     }).join("");
10464:     activeIdx = 0;
10465:     setActive(0);
10466:     // Click handler — uses delegation.
10467:     listEl.querySelectorAll(".geo-result").forEach(el => {
10468:       el.addEventListener("click", () => pickHit(parseInt(el.dataset.idx, 10)));
10469:     });
10470:   };
10471: 
10472:   const pickHit = (i) => {
10473:     const h = activeHits[i];
10474:     if (!h) return;
10475:     closeDropdown();
10476:     renderResults(h.lat, h.lon, {
10477:       type: "LatLon",
10478:       raw:  h.display_name,
10479:       source: "geo"
10480:     });
10481:     // Stamp the locality immediately (no need for a round-trip) so downstream
10482:     // consumers (favorites, history, export) have it.
10483:     state.lastLocality = {
10484:       lat: h.lat, lon: h.lon,
10485:       display_name: h.display_name,
10486:       address: h.address || {},
10487:       _offline: !!h._offline
10488:     };
10489:     updateLocalityRow(h.lat, h.lon, state.lastLocality);
10490:     const mm = document.getElementById("miniMap");
10491:     if (mm) mm.scrollIntoView({ behavior: "smooth", block: "center" });
10492:   };
10493: 
10494:   const closeDropdown = () => {
10495:     listEl.hidden = true;
10496:     listEl.innerHTML = "";
10497:     activeIdx = -1;
10498:     activeHits = [];
10499:   };
10500: 
10501:   /** Forward search. Returns nothing — results are rendered into listEl. */
10502:   const runSearch = async (query) => {
10503:     if (!query){ closeDropdown(); return; }
10504:     if (!state.geocodeEnabled || state.opsecStrict){
10505:       renderEmpty(t("geo.disabledMsg") || "Geocoding disabilitato nelle impostazioni");
10506:       return;
10507:     }
10508:     const myGen = ++gen;
10509:     renderEmpty(t("geo.searching") || "Ricerca in corso…");
10510:     const opts = { limit: 10 };
10511:     if (country && country.value.trim()){
10512:       opts.countryCodes = country.value.trim().replace(/\s+/g, "").toLowerCase();
10513:     }
10514:     if (bboxCb && bboxCb.checked){
10515:       const vb = currentViewBbox();
10516:       if (vb){ opts.viewbox = vb; opts.bounded = true; }
10517:     }
10518:     try {
10519:       if (!isEffectivelyOnline()){
10520:         const offHits = await offlineForwardSearch(query);
10521:         if (myGen === gen){
10522:           if (offHits.length) renderHits(offHits);
10523:           else renderEmpty(t("geo.offlineNone") || "Ricerca indirizzo non disponibile offline");
10524:         }
10525:         return;
10526:       }
10527:       const hits = await geocodeSearch(query, opts);
10528:       if (myGen !== gen) return;
10529:       if (!hits.length){
10530:         // Fall back to the offline dataset for a best-effort suggestion.
10531:         const offHits = await offlineForwardSearch(query);
10532:         renderHits(offHits.length ? offHits : []);
10533:         if (!offHits.length) renderEmpty(t("geo.noResults") || "Nessun risultato");
10534:         return;
10535:       }
10536:       renderHits(hits);
10537:     } catch(e){
10538:       if (myGen !== gen) return;
10539:       // Try offline dataset as a consolation prize when the service fails.
10540:       const offHits = await offlineForwardSearch(query);
10541:       if (offHits.length){ renderHits(offHits); return; }
10542:       const key = (e && e.message) || "geo.unreachable";
10543:       let msg = t("geo.err." + key) || t("geo." + key) || (e && e.message) || "Errore";
10544:       renderEmpty(msg);
10545:     }
10546:   };
10547: 
10548:   // Debounced "as-you-type" autocomplete (400ms).
10549:   input.addEventListener("input", () => {
10550:     clearTimeout(debTO);
10551:     const v = input.value.trim();
10552:     if (v.length < 3){ closeDropdown(); return; }
10553:     debTO = setTimeout(() => runSearch(v), 400);
10554:   });
10555:   input.addEventListener("keydown", (ev) => {
10556:     if (ev.key === "ArrowDown" && !listEl.hidden){
10557:       ev.preventDefault();
10558:       setActive(Math.min(activeHits.length - 1, activeIdx + 1));
10559:     } else if (ev.key === "ArrowUp" && !listEl.hidden){
10560:       ev.preventDefault();
10561:       setActive(Math.max(0, activeIdx - 1));
10562:     } else if (ev.key === "Enter"){
10563:       ev.preventDefault();
10564:       if (!listEl.hidden && activeHits.length){
10565:         pickHit(activeIdx >= 0 ? activeIdx : 0);
10566:       } else {
10567:         const v = input.value.trim();
10568:         if (v) runSearch(v);
10569:       }
10570:     } else if (ev.key === "Escape"){
10571:       if (!listEl.hidden){ ev.preventDefault(); closeDropdown(); }
10572:     }
10573:   });
10574:   if (btn) btn.addEventListener("click", () => runSearch(input.value.trim()));
10575: 
10576:   // Re-run when filters change (only if the dropdown is open — otherwise
10577:   // it's a silent preference update).
10578:   [country, bboxCb].forEach(el => { if (el) el.addEventListener("change", () => {
10579:     if (!listEl.hidden){ runSearch(input.value.trim()); }
10580:   }); });
10581: 
10582:   // Dismiss on outside click (unless the click is on card itself).
10583:   document.addEventListener("click", (ev) => {
10584:     if (!card.contains(ev.target) && !listEl.hidden) closeDropdown();
10585:   });
10586: 
10587:   // When the user toggles the strict OPSEC flag elsewhere, refresh.
10588:   state._onOpsecChange = state._onOpsecChange || [];
10589:   state._onOpsecChange.push(refreshCardState);
10590: }
