14513:     root.innerHTML = `<p style="color:var(--muted); font-size:.85rem">${t("batch.empty")}</p>`;
14514:     return;
14515:   }
14516:   const showLoc = !!state.geocodeBatchLoc;
14517:   let html = `<table class="batch-table"><thead><tr>
14518:     <th>#</th>
14519:     <th>${t("batch.th.input")}</th>
14520:     <th>${t("batch.th.dd")}</th>
14521:     <th>${t("batch.th.utm")}</th>
14522:     <th>${t("batch.th.mgrs")}</th>
14523:     ${showLoc ? `<th>${t("batch.th.loc")}</th>` : ""}
14524:     <th>${t("batch.th.err")}</th></tr></thead><tbody>`;
14525:   let idx = 0;
14526:   for (const r of rows){
14527:     const i = idx; idx++;
14528:     if (r.ok){
14529:       const locCell = showLoc ? `<td class="loc-cell" title="${esc(r.loc || "")}">${esc(r.loc || "")}</td>` : "";
14530:       html += `<tr data-batch-idx="${i}"><td class="num">${idx}</td><td>${esc(r.input)}</td><td>${esc(r.dd)}</td><td>${esc(r.utm)}</td><td>${esc(r.mgrs)}</td>${locCell}<td></td></tr>`;
14531:     } else {
14532:       const emptyLoc = showLoc ? `<td></td>` : "";
14533:       html += `<tr class="err" data-batch-idx="${i}"><td class="num">${idx}</td><td>${esc(r.input)}</td><td></td><td></td><td></td>${emptyLoc}<td>${esc(r.err)}</td></tr>`;
14534:     }
