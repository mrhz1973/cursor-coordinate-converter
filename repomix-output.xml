14547:         </div>
14548:         <div class="route-body" id="routeBody"></div>
14549:       </div>`;
14550:   }
14551: 
14552:   root.innerHTML = html;
14553:   root.dataset.rows = JSON.stringify(rows);
14554: 
14555:   // Wire up the toggle + render the numbers
14556:   if (pts.length >= 2){
