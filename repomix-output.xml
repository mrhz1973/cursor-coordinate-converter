12765: /**
12766:  * Render an interactive tile map (OSM or Esri satellite) in #miniMap.
12767:  * Controls rendered inside the map:
12768:  *   - Top-left:  basemap toggle (Mappa / Satellite)
12769:  *   - Top-right: size toggle (small / half / full) + zoom ± with level readout
12770:  *   - Bottom-left: scale bar + MGRS grid toggle
12771:  *   - Bottom-right: live coordinates under cursor, provider attribution
12772:  * The marker is drawn at the exact point.
12773:  */
12774: function renderTileMap(lat, lon, zoom){
12775:   const root = document.getElementById("miniMap");
12776:   if (!root) return;
12777:   revokeMapBlobUrls(root);
12778: 
12779:   // On mobile the container may not be laid out yet when the first
12780:   // conversion fires (e.g. Safari defers layout during JS burst). Wait one
12781:   // animation frame and retry; give up after 5 attempts to avoid infinite
12782:   // loops if the container is genuinely hidden.
12783:   if (!root.clientWidth){
12784:     root._tileRetries = (root._tileRetries || 0) + 1;
12785:     if (root._tileRetries < 5){
12786:       requestAnimationFrame(() => renderTileMap(lat, lon, zoom));
12787:       return;
12788:     }
12789:   }
12790:   root._tileRetries = 0;
12791: 
12792:   const layer = TILE_LAYERS[state.mapLayer] || TILE_LAYERS.osm;
12793:   zoom = Math.max(2, Math.min(layer.maxZoom, Math.round(zoom)));
12794:   state.mapZoom = zoom;
12795: 
12796:   const size = state.mapSize || "small";
12797:   // IMPORTANT: never inflate W above the real container width. The old code
12798:   // used Math.max(clientWidth, minW) with minW ≈ viewport−40, which on a
12799:   // desktop made W ~1000px even when the sidebar #miniMap was only ~400px
12800:   // wide — the tile math then rendered a ~400×1000px "tower" and the
12801:   // bottom (readout, scale, attribution) was off-screen or looked clipped.
12802:   const fallbackW = Math.max(260, Math.min(window.innerWidth - 40, 1200));
12803:   const cw = root.clientWidth;
12804:   const W = cw > 0 ? cw : fallbackW;
12805:   // In "small" the mini-map is square: H follows W for tile math only; the
12806:   // box height comes from CSS aspect-ratio (no inline height — see below).
12807:   const H = (size === "small")
12808:           ? W
12809:           : (root.clientHeight && root.clientHeight > 60 ? root.clientHeight : W);
12810: 
12811:   // View center = where the map is recentered. Defaults to the point, but
12812:   // drifts when the user drags the map (see attachPanHandlers).
12813:   const vc = state.viewCenter || { lat, lon };
12814:   const vLat = Math.max(-85.05, Math.min(85.05, vc.lat));
12815:   const vLon = normalizeLon(vc.lon);
12816: 
12817:   const vtx = lonToTileX(vLon, zoom);
12818:   const vty = latToTileY(vLat, zoom);
12819:   const ctrPx = vtx * 256, ctrPy = vty * 256;
12820:   const originX = ctrPx - W / 2;
12821:   const originY = ctrPy - H / 2;
12822:   const txMin = Math.floor(originX / 256), txMax = Math.floor((originX + W) / 256);
12823:   const tyMin = Math.floor(originY / 256), tyMax = Math.floor((originY + H) / 256);
12824:   const maxTile = Math.pow(2, zoom);
12825: 
12826:   // Marker position: the actual converted point (may be off-center after pan)
12827:   const mtx = lonToTileX(lon, zoom);
12828:   const mty = latToTileY(Math.max(-85.05, Math.min(85.05, lat)), zoom);
12829:   const markerLeft = mtx * 256 - originX;
12830:   const markerTop  = mty * 256 - originY;
12831: 
12832:   const isEnlarged = size !== "small";
12833: 
12834:   // Small mode: do NOT set inline height — it fought with width:100% and
12835:   // produced a tall rectangle when W was wrongly large. CSS aspect-ratio:1/1
12836:   // keeps the viewport truly square after the W fix above.
12837:   const mapBoxStyle = size === "small" ? "" : `height:${H}px`;
12838:   const hintCls = (state.tilePackHints !== false) ? " tile-hints-on" : "";
12839:   let html = `<div class="tile-map ${isEnlarged ? "tm-enlarged" : ""} size-${size}${hintCls}"${mapBoxStyle ? ` style="${mapBoxStyle}"` : ""}>`;
12840: 
12841:   // Panning layer: everything geo-anchored (tiles + marker + grid) lives
12842:   // here so we can translate it as a single group during a drag gesture.
12843:   html += `<div class="tile-layer">`;
12844:   const mapLayerId = state.mapLayer || "osm";
12845:   for (let x = txMin; x <= txMax; x++){
12846:     for (let y = tyMin; y <= tyMax; y++){
12847:       if (y < 0 || y >= maxTile) continue;
12848:       const xw = ((x % maxTile) + maxTile) % maxTile;
12849:       const left = x * 256 - originX;
12850:       const top  = y * 256 - originY;
12851:       const tkey = makeTileKey(mapLayerId, zoom, xw, y);
12852:       // B2: <img> has no initial src; hydrateMapTiles fills from IndexedDB
12853:       // (mission pack) or fetches the network, or shows the hatched "?"
12854:       // placeholder when nothing is available offline.
12855:       html += `<div class="tile-wrap tile-pending" data-tkey="${esc(tkey)}" data-xw="${xw}" data-y="${y}" data-z="${zoom}" style="left:${left}px;top:${top}px">`;
12856:       html += `<div class="tile-void" style="display:none" aria-hidden="true">?</div>`;
12857:       html += `<img class="tile" alt="" data-layer="${esc(mapLayerId)}" style="left:0;top:0" draggable="false" decoding="async">`;
12858:       html += `</div>`;
12859:     }
12860:   }
12861:   // MGRS / UTM grid overlay. Drawn inside .tile-layer so it pans with the
12862:   // tiles. Only rendered when the user has toggled it on.
12863:   if (state.showGrid){
12864:     const gridSVG = buildMgrsGridSVG(W, H, originX, originY, zoom, vLat, vLon);
12865:     if (gridSVG){
12866:       html += `<svg class="tile-grid" width="${W + 256}" height="${H + 256}" style="left:-128px;top:-128px" xmlns="http://www.w3.org/2000/svg">
12867:         <g transform="translate(128 128)">${gridSVG}</g>
12868:       </svg>`;
12869:     }
12870:   }
12871:   if (state.rangeOverlay && state.rangeOverlay.ring && state.rangeOverlay.ring.length > 2){
12872:     const rring = state.rangeOverlay.ring;
12873:     const pts = rring.map(ll => {
12874:       const la = Math.max(-85.05, Math.min(85.05, ll[1]));
12875:       const mx = lonToTileX(ll[0], zoom) * 256 - originX;
12876:       const my = latToTileY(la, zoom) * 256 - originY;
12877:       return round(mx, 2) + "," + round(my, 2);
12878:     });
12879:     html += `<svg class="tile-range" style="position:absolute;left:0;top:0;width:${W}px;height:${H}px;pointer-events:none;overflow:visible" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${W} ${H}">` +
12880:       `<polygon points="${esc(pts.join(" "))}" fill="rgba(99,102,241,0.12)" stroke="#818cf8" stroke-width="2" stroke-linejoin="round"/>` +
12881:       `</svg>`;
12882:   }
12883:   // Inline SVG pin: classic teardrop outline with a white core, drawn at
12884:   // 28×40 viewBox so the tip sits precisely at (14, 40). The wrapper div
12885:   // uses margin-top:-40px so the tip ends up exactly on (markerLeft, markerTop).
12886:   html += `<div class="tile-marker" style="left:${markerLeft}px;top:${markerTop}px" title="${esc(lat.toFixed(5) + ', ' + lon.toFixed(5))}">
12887:     <svg viewBox="0 0 28 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
12888:       <path d="M14 1 C7 1 1.5 6.5 1.5 13.5 C1.5 22 8 27 14 39 C20 27 26.5 22 26.5 13.5 C26.5 6.5 21 1 14 1 Z" fill="#ef4444" stroke="#ffffff" stroke-width="2" stroke-linejoin="round"/>
12889:       <circle cx="14" cy="13.5" r="4.5" fill="#ffffff"/>
12890:     </svg>
12891:   </div>`;
12892:   html += `</div>`; // end .tile-layer
12893: 
12894:   // Controls: rendered outside .tile-layer so they don't move when panning.
12895:   html += `<div class="tile-attrib">${layer.attrib}</div>`;
12896:   if (state.mapLayer === "sat"){
12897:     html += `<div class="tile-imagery-date na" data-role="imagery-date">${esc(t("img.date.loading") || "Imagery: … (Esri)")}</div>`;
12898:   }
12899: 
12900:   // North indicator (true north). Purely visual cue.
12901:   html += `<div class="tile-north" aria-hidden="true"><span class="n-lbl">N</span><span class="n-arr">↑</span></div>`;
12902: 
12903: 
12904:   // Top-left: basemap toggle
12905:   html += `<div class="tile-layers">
12906:     <button class="tl-btn ${state.mapLayer === "osm" ? "active" : ""}" type="button" data-layer="osm" data-tip="${esc(t("tip.layerMap"))}">${esc(t("map.layerMap"))}</button>
12907:     <button class="tl-btn ${state.mapLayer === "sat" ? "active" : ""}" type="button" data-layer="sat" data-tip="${esc(t("tip.layerSat"))}">${esc(t("map.layerSat"))}</button>
12908:   </div>`;
12909: 
12910:   // Top-right: size + zoom controls + MGRS grid toggle
12911:   html += `<div class="tile-ctrls">
12912:     <div class="tile-size">
12913:       <button class="ts-btn ${size === "small" ? "active" : ""}" type="button" data-size="small" aria-label="${esc(t("map.sizeSmall"))}" data-tip="${esc(t("map.sizeSmall"))}">⚬</button>
12914:       <button class="ts-btn ${size === "half"  ? "active" : ""}" type="button" data-size="half"  aria-label="${esc(t("map.sizeHalf"))}"  data-tip="${esc(t("map.sizeHalf"))}">◧</button>
12915:       <button class="ts-btn ${size === "full"  ? "active" : ""}" type="button" data-size="full"  aria-label="${esc(t("map.sizeFull"))}"  data-tip="${esc(t("map.sizeFull"))}">⛶</button>
12916:     </div>
12917:     <div class="tile-zoom">
12918:       <button class="tz-btn" type="button" data-zdelta="1"  aria-label="zoom in"  ${zoom >= layer.maxZoom ? "disabled" : ""}>+</button>
12919:       <button class="tz-btn" type="button" data-zdelta="-1" aria-label="zoom out" ${zoom <= 2 ? "disabled" : ""}>−</button>
12920:       <span class="tz-level">z${zoom}</span>
12921:     </div>
12922:     <button class="tg-btn ${state.showGrid ? "active" : ""}" type="button" data-tip="${esc(t("tip.toggleGrid"))}" aria-label="${esc(t("tip.toggleGrid"))}" aria-pressed="${state.showGrid ? "true" : "false"}">#</button>
12923:     ${(() => {
12924:       const covOn = state.showCoverage !== false;
12925:       const _tOr = (k, f) => { const v = t(k); return (!v || v === k) ? f : v; };
12926:       const covTip = covOn ? _tOr("tip.coverageHide", "Nascondi copertura offline")
12927:                            : _tOr("tip.coverageShow", "Mostra copertura offline");
12928:       const cls = covOn ? " active" : "";
12929:       return `<button class="tcov-btn${cls}" type="button" data-tip="${esc(covTip)}" aria-label="${esc(covTip)}" aria-pressed="${covOn ? "true" : "false"}">📦</button>`;
12930:     })()}
12931:     ${(() => {
12932:       const on = !!state.mapMeasureMode;
12933:       const open = !!state.mapMeasurePanelOpen;
12934:       const tip = esc(t("tip.mapMeasureBox") || "Strumenti di misura (distanza/azimut, poligono/area)");
12935:       const cls = (on || open) ? " active" : "";
12936:       const pressed = (on || open) ? "true" : "false";
12937:       return `<button class="tmeas-btn${cls}" type="button" data-role="measure-box-toggle" data-tip="${tip}" aria-label="${tip}" aria-pressed="${pressed}">📏∠</button>`;
12938:     })()}
12939:   </div>`;
12940: 
12941:   // Floating measure box (ruler + protractor tool)
12942:   if (state.mapMeasurePanelOpen){
12943:     const k = state.mapMeasureKind || "line";
12944:     const u = state.mapMeasureUnit || "m";
12945:     const ttl = esc(t("map.measure") || "MISURA");
12946:     const hint = esc(t("map.measureHint") || "Clicca sulla mappa per aggiungere punti. Trascina i punti per spostarli. Tasto destro su un punto per eliminarlo.");
12947:     html += `<div class="tile-measure-box" data-role="measure-box" aria-label="${ttl}">
12948:       <h4><span>📏 ∠ ${ttl}</span><button class="mb-close" type="button" data-role="measure-box-close" aria-label="close">✕</button></h4>
12949:       <div class="mb-tabs">
12950:         <button class="mb-tab ${k==="line"?"active":""}" type="button" data-role="measure-kind" data-kind="line">📏</button>
12951:         <button class="mb-tab ${k==="poly"?"active":""}" type="button" data-role="measure-kind" data-kind="poly">▱</button>
12952:       </div>
12953:       <div class="mb-row">
12954:         <label>${esc(t("map.unit") || "Unità")}</label>
12955:         <select data-role="measure-unit">
12956:           <option value="m"  ${u==="m"?"selected":""}>m</option>
12957:           <option value="km" ${u==="km"?"selected":""}>km</option>
12958:           <option value="nm" ${u==="nm"?"selected":""}>nm</option>
12959:           <option value="mi" ${u==="mi"?"selected":""}>mi</option>
12960:           <option value="ft" ${u==="ft"?"selected":""}>ft</option>
12961:         </select>
12962:       </div>
12963:       <div class="mb-out" data-role="measure-box-out">—</div>
12964:       <div class="mb-actions">
12965:         <button class="mb-btn" type="button" data-role="measure-clear">${esc(t("map.measureClear") || "Pulisci")}</button>
12966:         <button class="mb-btn danger" type="button" data-role="measure-exit">${esc(t("map.measureExit") || "Esci")}</button>
12967:       </div>
12968:       <div class="mb-row"><label style="opacity:.95">${hint}</label></div>
12969:     </div>`;
12970:   }
12971: 
12972:   // Bottom-left cluster: recenter button (if panned) on the left, scale bar
12973:   // on the right. The scale bar only appears in half/full mode because the
12974:   // small mini-map is too crowded to read it without squinting.
12975:   html += `<div class="tile-bottom-left">`;
12976:   html += `<div class="tile-bl-row">`;
12977:   const vcOff = Math.hypot(mtx - vtx, mty - vty) * 256;
12978:   if (vcOff > 40){
12979:     html += `<button class="tile-recenter" type="button" data-tip="${esc(t("tip.recenter"))}" aria-label="${esc(t("tip.recenter"))}"><span class="tmb-ico" aria-hidden="true">📍</span><span class="tmb-label" data-i18n="tip.recenterShort">Punto</span></button>`;
12980:   }
