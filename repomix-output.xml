 9130: /** In-memory handle for the merged dataset (seed + user-imported). */
 9131: let _offlineCities = null;
 9132: async function loadOfflineCities(){
 9133:   if (_offlineCities) return _offlineCities;
 9134:   let extra = null;
 9135:   try { extra = await idbGet("geo:dataset:cities"); } catch(_){}
 9136:   if (extra && Array.isArray(extra.data)){
 9137:     _offlineCities = [...OFFLINE_CITIES_SEED, ...extra.data.filter(x => x && Number.isFinite(x.lat) && Number.isFinite(x.lon))];
 9138:   } else {
 9139:     _offlineCities = OFFLINE_CITIES_SEED.slice();
 9140:   }
 9141:   return _offlineCities;
 9142: }
 9143: /** Parse + persist a user-supplied JSON dataset. Accepts array or {cities:[…]}. */
 9144: async function importOfflineCitiesJSON(text){
 9145:   let data = null;
 9146:   try { data = JSON.parse(text); } catch(e){ throw new Error("geo.dataset.invalidJson"); }
 9147:   if (data && !Array.isArray(data) && Array.isArray(data.cities)) data = data.cities;
 9148:   if (!Array.isArray(data)) throw new Error("geo.dataset.invalidShape");
 9149:   const clean = data
 9150:     .filter(x => x && Number.isFinite(Number(x.lat)) && Number.isFinite(Number(x.lon)))
 9151:     .map(x => ({
 9152:       name:        String(x.name || x.city || "").slice(0, 120),
 9153:       country:     String(x.country || "").slice(0, 80),
 9154:       countryCode: String(x.countryCode || x.cc || "").slice(0, 3).toLowerCase(),
 9155:       lat:         Number(x.lat),
 9156:       lon:         Number(x.lon),
 9157:       pop:         Number.isFinite(Number(x.pop)) ? Number(x.pop) : null
 9158:     }));
 9159:   await idbPut("geo:dataset:cities", { data: clean, importedAt: Date.now() });
 9160:   _offlineCities = [...OFFLINE_CITIES_SEED, ...clean];
 9161:   return clean.length;
 9162: }
 9163: async function clearOfflineCities(){
 9164:   try { await idbPut("geo:dataset:cities", { data: [] }); } catch(_){}
 9165:   _offlineCities = OFFLINE_CITIES_SEED.slice();
 9166: }
 9167: function haversineKm(aLat, aLon, bLat, bLon){
 9168:   const toRad = d => d * Math.PI / 180;
 9169:   const R = 6371, dLat = toRad(bLat - aLat), dLon = toRad(bLon - aLon);
 9170:   const s = Math.sin(dLat/2)**2 + Math.cos(toRad(aLat)) * Math.cos(toRad(bLat)) * Math.sin(dLon/2)**2;
 9171:   return 2 * R * Math.asin(Math.min(1, Math.sqrt(s)));
 9172: }
 9173: /** Return nearest city in the dataset, annotated with distance in km. */
 9174: async function offlineNearestCity(lat, lon){
 9175:   const cities = await loadOfflineCities();
 9176:   let best = null, bestKm = Infinity;
 9177:   for (const c of cities){
 9178:     const d = haversineKm(lat, lon, c.lat, c.lon);
 9179:     if (d < bestKm){ bestKm = d; best = c; }
 9180:   }
 9181:   return best ? Object.assign({}, best, { distKm: bestKm }) : null;
 9182: }
 9183: /** Substring match against the offline dataset — used when online fails. */
 9184: async function offlineForwardSearch(q){
 9185:   const cities = await loadOfflineCities();
 9186:   const needle = String(q || "").toLowerCase().trim();
 9187:   if (!needle) return [];
 9188:   const out = [];
 9189:   for (const c of cities){
 9190:     const hay = (c.name + " " + c.country).toLowerCase();
 9191:     if (hay.includes(needle)){
 9192:       out.push({
 9193:         lat: c.lat, lon: c.lon,
 9194:         display_name: c.name + ", " + c.country,
 9195:         type: "city", class: "place", importance: null,
 9196:         bbox: null, address: { city: c.name, country: c.country },
 9197:         _offline: true
 9198:       });
 9199:       if (out.length >= 10) break;
 9200:     }
 9201:   }
 9202:   return out;
 9203: }
