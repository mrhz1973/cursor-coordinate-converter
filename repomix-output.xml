 2242: /* The badge sits at the bottom-right corner of the viewport, so a centered
 2243:  * tooltip above it would clip against the right edge. Anchor it to the right
 2244:  * of the badge and remove the default arrow centering. */
 2245: .sig-badge[data-tip]:hover::after,
 2246: .sig-badge[data-tip]:focus-visible::after{
 2247:   left:auto; right:0; transform:none;
 2248:   animation:none;
 2249: }
 2250: .sig-badge[data-tip]:hover::before,
 2251: .sig-badge[data-tip]:focus-visible::before{
 2252:   left:auto; right:14px; transform:none;
 2253: }
