 8273: /* ========================= SECTION 14D: IMPORT FILE PARSERS ========================= */
 8274: function parseGPXText(text){
 8275:   const doc = new DOMParser().parseFromString(text, "application/xml");
 8276:   const nodes = [
 8277:     ...doc.getElementsByTagName("wpt"),
 8278:     ...doc.getElementsByTagName("trkpt"),
 8279:     ...doc.getElementsByTagName("rtept")
 8280:   ];
 8281:   const out = [];
 8282:   for (const n of nodes){
 8283:     const lat = parseFloat(n.getAttribute("lat"));
 8284:     const lon = parseFloat(n.getAttribute("lon"));
 8285:     if (!Number.isFinite(lat) || !Number.isFinite(lon)) continue;
 8286:     const nameEl = n.getElementsByTagName("name")[0];
 8287:     out.push({ lat, lon, name: nameEl ? nameEl.textContent.trim() : null });
 8288:   }
 8289:   return out;
 8290: }
 8291: function parseKMLText(text){
 8292:   const doc = new DOMParser().parseFromString(text, "application/xml");
 8293:   const coordsEls = doc.getElementsByTagName("coordinates");
 8294:   const out = [];
 8295:   for (const c of coordsEls){
 8296:     const parent = c.parentNode;
 8297:     const isPoint = parent && parent.nodeName && parent.nodeName.toLowerCase() === "point";
 8298:     const tuples = c.textContent.trim().split(/\s+/).filter(Boolean);
 8299:     for (const tpl of tuples){
 8300:       const parts = tpl.split(",");
 8301:       if (parts.length < 2) continue;
 8302:       const lon = parseFloat(parts[0]);
 8303:       const lat = parseFloat(parts[1]);
 8304:       if (!Number.isFinite(lat) || !Number.isFinite(lon)) continue;
 8305:       let name = null;
 8306:       if (isPoint){
 8307:         const pm = parent.parentNode;
 8308:         if (pm){
 8309:           const nEl = pm.getElementsByTagName("name")[0];
 8310:           if (nEl) name = nEl.textContent.trim();
 8311:         }
 8312:       }
 8313:       out.push({ lat, lon, name });
 8314:       if (!isPoint && tuples.length > 1) break; // avoid flooding from long lines/polygons
 8315:     }
 8316:   }
 8317:   return out;
 8318: }
 8319: function parseGeoJSONText(text){
 8320:   const data = JSON.parse(text);
 8321:   const out = [];
 8322:   const pushCoord = (coord, name) => {
 8323:     if (!Array.isArray(coord) || coord.length < 2) return;
 8324:     const lon = parseFloat(coord[0]), lat = parseFloat(coord[1]);
 8325:     if (!Number.isFinite(lat) || !Number.isFinite(lon)) return;
 8326:     out.push({ lat, lon, name });
 8327:   };
 8328:   const handleGeom = (g, name) => {
 8329:     if (!g) return;
 8330:     if (g.type === "Point") pushCoord(g.coordinates, name);
 8331:     else if (g.type === "MultiPoint") g.coordinates.forEach(c => pushCoord(c, name));
 8332:     else if (g.type === "LineString") g.coordinates.forEach((c,i) => pushCoord(c, name ? `${name} #${i+1}` : null));
 8333:     else if (g.type === "GeometryCollection") g.geometries.forEach(x => handleGeom(x, name));
 8334:   };
 8335:   const featName = (f) => f.properties ? (f.properties.name || f.properties.Name || f.properties.title || null) : null;
 8336:   if (data.type === "FeatureCollection")      data.features.forEach(f => handleGeom(f.geometry, featName(f)));
 8337:   else if (data.type === "Feature")           handleGeom(data.geometry, featName(data));
 8338:   else if (data.type)                         handleGeom(data, null);
 8339:   return out;
 8340: }
 8341: function parseImportedText(text, filename){
 8342:   const fn = String(filename || "").toLowerCase();
 8343:   try {
 8344:     if (fn.endsWith(".gpx") || /<gpx\b/i.test(text.slice(0, 500)))       return parseGPXText(text);
 8345:     if (fn.endsWith(".kml") || /<kml\b/i.test(text.slice(0, 500)))       return parseKMLText(text);
 8346:     if (fn.endsWith(".geojson") || fn.endsWith(".json") || /^\s*\{/.test(text)) return parseGeoJSONText(text);
 8347:   } catch(_){ throw new ErrI18n("err.importFailed"); }
 8348:   return null; // signal: treat as generic text
 8349: }
