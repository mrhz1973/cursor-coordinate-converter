11177: function collectBboxTiles(n, s, e, w, z0, z1){
11178:   const out = [];
11179:   n = +n; s = +s; e = +e; w = +w; z0 = +z0; z1 = +z1;
11180:   if (n <= s || w > e || z0 > z1) return out;
11181:   for (let z = z0; z <= z1; z++){
11182:     const cap = 1 << z;
11183:     const x0 = Math.floor(lonToTileX(w, z));
11184:     const x1 = Math.floor(lonToTileX(e, z));
11185:     const y0 = Math.floor(latToTileY(n, z));
11186:     const y1 = Math.floor(latToTileY(s, z));
11187:     const xMin = Math.min(x0, x1), xMax = Math.max(x0, x1);
11188:     const yMin = Math.min(y0, y1), yMax = Math.max(y0, y1);
11189:     for (let x = xMin; x <= xMax; x++){
11190:       const xw = ((x % cap) + cap) % cap;
11191:       for (let y = yMin; y <= yMax; y++){
11192:         if (y < 0 || y >= cap) continue;
11193:         out.push({ z, x: xw, y });
11194:       }
11195:     }
11196:   }
11197:   return out;
11198: }
