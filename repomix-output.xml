 7631:     const a = pts[pts.length - 1], b = pts[0];
 7632:     const inv = vincentyInverse(a.lat, a.lon, b.lat, b.lon);
 7633:     sum += inv.distance || 0;
 7634:   }
 7635:   return sum;
 7636: }
