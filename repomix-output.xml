14741: function doPasteDetect(){
14742:   clearError();
14743:   const st = document.getElementById("pasteStatus");
14744:   st.textContent = ""; st.className = "";
14745:   const s = document.getElementById("pasteInput").value;
14746:   if (!s.trim()){ setBadge(null); return; }
14747:   try {
14748:     const det = autoDetect(s);
14749:     let lbl = "paste.detectedLL";
14750:     if (det.type === "UTM")  lbl = "paste.detectedUTM";
14751:     if (det.type === "MGRS") lbl = "paste.detectedMGRS";
14752:     if (det.type === "OLC")  lbl = "paste.detectedOLC";
14753:     if (det.type === "BNG")  lbl = "paste.detectedBNG";
14754:     if (det.type === "SK42GK") lbl = "paste.detectedSK42GK";
14755:     st.textContent = t(lbl);
14756:     st.className = "ok";
14757:     setBadge(det.type, fmtDD(det.lat, det.lon).cardinal);
14758:     renderResults(det.lat, det.lon, det);
14759:   } catch(e){
14760:     // Nothing recognized as a coordinate. If the input looks like free text
14761:     // (has letters, no coord-ish digit clusters), offer geocoding as a last
14762:     // resort. We keep this explicit (user confirmation) to avoid silently
14763:     // sending pasted content to a 3rd-party server.
14764:     const input = s.trim();
14765:     const looksLikeFreeText = /[A-Za-z]/.test(input) && input.length <= 200;
14766:     if (looksLikeFreeText && geocodingAllowed() && isEffectivelyOnline()){
14767:       const q = input.replace(/\s+/g, " ").slice(0, 150);
14768:       const prompt = (t("geo.confirmSearch") || "Cercare '{0}' come indirizzo?").replace("{0}", q);
14769:       if (window.confirm(prompt)){
14770:         st.textContent = t("geo.searching") || "Ricerca in corso…";
14771:         st.className = "";
14772:         setBadge("GEO", q);
14773:         geocodeSearch(input).then(hits => {
14774:           if (!hits.length){
14775:             st.textContent = t("geo.noResults") || "Nessun risultato";
14776:             st.className = "err";
14777:             setBadge("ERR", q);
14778:             return;
14779:           }
14780:           const h = hits[0];
14781:           st.textContent = (t("geo.foundAs") || "Trovato: {0}").replace("{0}", h.display_name);
14782:           st.className = "ok";
14783:           setBadge("GEO", h.display_name);
14784:           state.lastLocality = { lat: h.lat, lon: h.lon, display_name: h.display_name, address: h.address || {} };
14785:           renderResults(h.lat, h.lon, {
14786:             type: "LatLon",
14787:             raw:  h.display_name,
14788:             source: "geo",
14789:             _locality: state.lastLocality
14790:           });
14791:           // Also open the full geocoding card so extra hits remain visible.
14792:           const card = document.getElementById("geocodeCard");
14793:           if (card && !card.open) card.open = true;
14794:           const inp = document.getElementById("geoInput");
14795:           if (inp){ inp.value = input; inp.dispatchEvent(new Event("input")); }
14796:         }).catch((er) => {
14797:           st.textContent = translateError(er);
14798:           st.className = "err";
14799:           setBadge("ERR", q);
14800:         });
14801:         return;
14802:       }
14803:     }
14804:     st.textContent = translateError(e);
14805:     st.className = "err";
14806:     setBadge("ERR", state.lang === "en" ? "Not recognized" : state.lang === "fr" ? "Non reconnu" : "Non riconosciuto");
14807:   }
14808: }
