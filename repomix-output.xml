14455:         utm: u ? fmtUTM(u) : "—",
14456:         mgrs: m || "—",
14457:         loc: ""
14458:       });
14459:     } catch(e){
14460:       rows.push({ input: line, ok: false, err: translateError(e) });
14461:     }
14462:   }
14463:   state.batchInputText = text;
14464:   state.lastBatchRows = rows;
14465:   if (state.persist) saveStore();
14466:   renderBatch(rows);
14467:   // Kick off the optional locality enrichment in the background.
14468:   if (state.geocodeBatchLoc && geocodingAllowed() && isEffectivelyOnline()){
14469:     batchFillLocalities(rows).catch(() => {});
14470:   }
14471: }
