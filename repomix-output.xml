12156: /* ============== TRACK BUILDER (multi-point track) ==============
12157:  *
12158:  * Data model:
12159:  *   state.track = {
12160:  *     points: [{ id, lat, lon, name?, meta? }, ...],
12161:  *     closed: bool,        // render as polygon + compute area
12162:  *     pickMode: bool       // transient: click-on-map-to-add is active
12163:  *   }
12164:  *
12165:  * Rendering:
12166:  *   - A DOM list of points with per-row drag-to-reorder, inline name
12167:  *     edit, remove button, and per-leg distance/bearing.
12168:  *   - A summary bar with: number of points, total distance, area (if
12169:  *     closed and ≥3 points), ETA on foot / by car.
12170:  *   - An SVG overlay on the mini-map with the polyline and numbered
12171:  *     vertex circles. Drawn inside .tile-layer so it pans with tiles.
12172:  */
12173: 
12174: /** Ensure state.track is a well-formed object (defensive). */
12175: function ensureTrackState(){
12176:   if (!state.track || typeof state.track !== "object") state.track = { points: [], closed: false, pickMode: false };
12177:   if (!Array.isArray(state.track.points)) state.track.points = [];
12178:   if (typeof state.track.closed !== "boolean") state.track.closed = false;
12179: }
12180: 
12181: /** Add a point to the track. Deduplicates consecutive duplicates. */
12182: function trackAddPoint(lat, lon, name, meta){
12183:   ensureTrackState();
12184:   if (!Number.isFinite(lat) || !Number.isFinite(lon)) return false;
12185:   if (lat < -90 || lat > 90 || lon < -180 || lon > 180) return false;
12186:   const pts = state.track.points;
12187:   // Collapse consecutive duplicates within ~1 m (same rounded DD key)
12188:   const last = pts[pts.length - 1];
12189:   if (last && Math.abs(last.lat - lat) < 1e-5 && Math.abs(last.lon - lon) < 1e-5) return false;
12190:   pts.push({
12191:     id: uidNamed(),
12192:     lat: lat,
12193:     lon: lon,
12194:     name: (typeof name === "string" ? name : "").slice(0, 60),
12195:     meta: meta || null
12196:   });
12197:   if (pts.length > 500) pts.splice(0, pts.length - 500);
12198:   saveStore();
12199:   renderTrackAll();
12200:   return true;
12201: }
12202: 
12203: function trackRemovePoint(id){
12204:   ensureTrackState();
12205:   state.track.points = state.track.points.filter(p => p.id !== id);
12206:   saveStore();
12207:   renderTrackAll();
12208: }
12209: 
12210: function trackClear(){
12211:   ensureTrackState();
12212:   if (!state.track.points.length) return;
12213:   if (typeof window.confirm === "function" && !window.confirm(t("track.clearConfirm"))) return;
12214:   state.track.points = [];
12215:   state.track.closed = false;
12216:   const chk = document.getElementById("trackClosed");
12217:   if (chk) chk.checked = false;
12218:   saveStore();
12219:   renderTrackAll();
12220: }
