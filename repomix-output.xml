11480: /** Convert a screen pixel (relative to the .tile-map viewport) into lat/lon,
11481:  * using the current map origin and zoom. Mirrors the math in renderTileMap. */
11482: function tileMapPxToLatLon(root, px, py){
11483:   const zoom = state.mapZoom || 11;
11484:   const vc   = state.viewCenter || state.lastPoint || { lat: 0, lon: 0 };
11485:   const W    = root.clientWidth  || 400;
11486:   const H    = (state.mapSize === "small") ? W : (root.clientHeight || W);
11487:   const vtx  = lonToTileX(normalizeLon(vc.lon), zoom);
11488:   const vty  = latToTileY(Math.max(-85.05, Math.min(85.05, vc.lat)), zoom);
11489:   const ctrPx = vtx * 256, ctrPy = vty * 256;
11490:   const originX = ctrPx - W / 2;
11491:   const originY = ctrPy - H / 2;
11492:   const lon = tileX2Lon((originX + px) / 256, zoom);
11493:   const lat = tileY2Lat((originY + py) / 256, zoom);
11494:   return { lat, lon };
11495: }
11496: 
11497: /** Reverse of tileMapPxToLatLon: project lat/lon onto the viewport in px. */
11498: function tileMapLatLonToPx(root, lat, lon){
11499:   const zoom = state.mapZoom || 11;
11500:   const vc   = state.viewCenter || state.lastPoint || { lat: 0, lon: 0 };
11501:   const W    = root.clientWidth  || 400;
11502:   const H    = (state.mapSize === "small") ? W : (root.clientHeight || W);
11503:   const vtx  = lonToTileX(normalizeLon(vc.lon), zoom);
11504:   const vty  = latToTileY(Math.max(-85.05, Math.min(85.05, vc.lat)), zoom);
11505:   const ctrPx = vtx * 256, ctrPy = vty * 256;
11506:   const originX = ctrPx - W / 2;
11507:   const originY = ctrPy - H / 2;
11508:   const pX = lonToTileX(normalizeLon(lon), zoom) * 256 - originX;
11509:   const pY = latToTileY(Math.max(-85.05, Math.min(85.05, lat)), zoom) * 256 - originY;
11510:   return { x: pX, y: pY };
11511: }
