 8208:   const fname = `point_${round(p.lat,4)}_${round(p.lon,4)}_${stamp}`;
 8209:   if (kind === "gpx")          downloadBlob(buildGPX([p]),     fname + ".gpx",     "application/gpx+xml;charset=utf-8");
 8210:   else if (kind === "kml")     downloadBlob(buildKML([p]),     fname + ".kml",     "application/vnd.google-earth.kml+xml;charset=utf-8");
 8211:   else if (kind === "geojson") downloadBlob(buildGeoJSON([p]), fname + ".geojson", "application/geo+json;charset=utf-8");
