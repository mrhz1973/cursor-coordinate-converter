 7020:       lonPrec /= OLC_GRID_COLS;
 7021:       const row = Math.floor(idx / OLC_GRID_COLS);
 7022:       const col = idx % OLC_GRID_COLS;
 7023:       latVal += row * latPrec;
 7024:       lonVal += col * lonPrec;
 7025:     }
 7026:   }
 7027: 
 7028:   return {
 7029:     lat: latVal + latPrec / 2,
 7030:     lon: lonVal + lonPrec / 2,
 7031:     latPrec, lonPrec,
 7032:     codeLen: digits.length
 7033:   };
 7034: }
