11541: /** Compute a live-feedback tip for the given bbox + current zoom range. */
11542: function computeBboxTip(b){
11543:   if (!b) return null;
11544:   const i = id => document.getElementById(id);
11545:   const z0 = parseInt(i("pcZ0")?.value, 10) || 6;
11546:   const z1 = parseInt(i("pcZ1")?.value, 10) || 12;
11547:   const { widthKm, heightKm } = bboxSizeKm(b);
11548:   const tiles = countTilesInBbox(b, Math.min(z0, z1), Math.max(z0, z1));
11549:   // ~22 KB average tile (PNG) → rough MB estimate
11550:   const mb = (tiles * 22) / 1024;
11551:   let cls = "tip-ok";
11552:   if (mb > 200 || tiles > MAX_PRECACHE_TILES) cls = "tip-err";
11553:   else if (mb > 80)  cls = "tip-caut";
11554:   else if (mb > 30)  cls = "tip-warn";
11555:   // Build a short label with rounded numbers
11556:   const w = widthKm  >= 10 ? Math.round(widthKm)  : widthKm.toFixed(1);
11557:   const h = heightKm >= 10 ? Math.round(heightKm) : heightKm.toFixed(1);
11558:   const tilesStr = tiles.toLocaleString();
11559:   const mbStr = mb >= 10 ? Math.round(mb) : mb.toFixed(1);
11560:   return {
11561:     cls,
11562:     line1: `~${w} × ${h} ${t("offcache.tipKm")}`,
11563:     line2: `${tilesStr} ${t("offcache.tipTiles")} · ~${mbStr} ${t("offcache.tipMb")}`,
11564:     tooBig: tiles > MAX_PRECACHE_TILES,
11565:     tooSmall: widthKm < 0.1 || heightKm < 0.1
11566:   };
11567: }
