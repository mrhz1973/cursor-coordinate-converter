10273: /**
10274:  * Human-readable delta: "3 days ago", "in 2 h 14 min", "now".
10275:  * Uses absolute rounded ms → adjusts unit from minutes up to years.
10276:  */
10277: function dtgDeltaHuman(ms){
10278:   const abs = Math.abs(ms);
10279:   if (abs < 30 * 1000) return t("dtg.delta.now") || "adesso";
10280:   const past = ms < 0;
10281:   const mins = Math.round(abs / 60000);
10282:   let label;
10283:   if (mins < 60){
10284:     label = mins + " " + (t("dtg.unit.min") || "min");
10285:   } else if (mins < 60 * 24){
10286:     const h = Math.floor(mins / 60), m = mins % 60;
10287:     label = h + " h" + (m ? " " + m + " min" : "");
10288:   } else if (mins < 60 * 24 * 30){
10289:     const d = Math.floor(mins / (60 * 24));
10290:     label = d + " " + (d === 1 ? (t("dtg.unit.day") || "giorno") : (t("dtg.unit.days") || "giorni"));
10291:   } else if (mins < 60 * 24 * 365){
10292:     const mo = Math.floor(mins / (60 * 24 * 30));
10293:     label = mo + " " + (mo === 1 ? (t("dtg.unit.month") || "mese") : (t("dtg.unit.months") || "mesi"));
10294:   } else {
10295:     const y = (mins / (60 * 24 * 365)).toFixed(1);
10296:     label = y + " " + (t("dtg.unit.years") || "anni");
10297:   }
10298:   return past
10299:     ? ((t("dtg.delta.ago") || "{0} fa").replace("{0}", label))
