 8461: /* ========================= SECTION 14G: BADGE (detected format chip) ========================= */
 8462: function setBadge(type, extra){
 8463:   const root = document.getElementById("pasteBadges");
 8464:   if (!root) return;
 8465:   root.innerHTML = "";
 8466:   if (!type) return;
 8467:   const raw = String(type);
 8468:   const up = raw.toUpperCase();
 8469:   // Back-compat: some call sites use setBadge("error"/"success"/"info", msg)
 8470:   // as a lightweight status chip. Normalize them here.
 8471:   const norm = (up === "ERROR") ? "ERR" : (up === "SUCCESS") ? "OK" : (up === "INFO") ? "INFO" : raw;
 8472:   const clsMap = {
 8473:     "LatLon":"chip chip-dd",
 8474:     "UTM":"chip chip-utm",
 8475:     "MGRS":"chip chip-mgrs",
 8476:     "OLC":"chip chip-olc",
 8477:     "BNG":"chip chip-info",
 8478:     "SK42GK":"chip chip-info",
 8479:     "OK":"chip chip-ok",
 8480:     "INFO":"chip chip-info",
 8481:     "ERR":"chip chip-err"
 8482:   };
 8483:   const label = norm === "LatLon" ? t("paste.chip.ll")
 8484:               : norm === "UTM"    ? t("paste.chip.utm")
 8485:               : norm === "MGRS"   ? t("paste.chip.mgrs")
 8486:               : norm === "OLC"    ? t("paste.chip.olc")
 8487:               : norm === "BNG"    ? (t("paste.chip.bng") || "BNG")
 8488:               : norm === "SK42GK" ? (t("paste.chip.sk42gk") || "SK42 GK")
 8489:               : (norm === "OK" || norm === "INFO" || norm === "ERR") ? (extra || "—")
 8490:               : norm;
 8491:   const chip = document.createElement("span");
 8492:   chip.className = clsMap[norm] || "chip";
 8493:   chip.textContent = label + (extra && (norm === "LatLon" || norm === "UTM" || norm === "MGRS" || norm === "OLC") ? " · " + extra : "");
 8494:   root.appendChild(chip);
 8495: }
