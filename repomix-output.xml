 6310: function latLonToAllMGRS(lat, lon){
 6311:   const utm = latLonToUTM(lat, lon);
 6312:   return {
 6313:     band: latitudeBand(lat),
 6314:     "1m":   utmToMGRS(utm, lat, 5),
 6315:     "10m":  utmToMGRS(utm, lat, 4),
 6316:     "100m": utmToMGRS(utm, lat, 3),
 6317:     "1km":  utmToMGRS(utm, lat, 2),
 6318:     "10km": utmToMGRS(utm, lat, 1)
 6319:   };
 6320: }
