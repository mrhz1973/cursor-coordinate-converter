12476: /** Draw the polyline overlay on the mini-map .tile-layer. Called from
12477:  *  renderTileMap() and from renderTrackAll() to refresh independently. */
12478: function renderTrackOverlay(tileMap){
12479:   if (!tileMap) return;
12480:   // Remove stale overlay
12481:   const old = tileMap.querySelector(".track-overlay");
12482:   if (old) old.remove();
12483:   ensureTrackState();
12484:   const pts = state.track.points;
12485:   if (pts.length < 1) return;
12486:   const root = document.getElementById("miniMap");
12487:   if (!root) return;
12488:   const tileLayer = tileMap.querySelector(".tile-layer");
12489:   if (!tileLayer) return;
12490: 
12491:   // Undo current .tile-layer transform so overlay coords match the viewport
12492:   const style = tileLayer.style.transform || "";
12493:   let tx = 0, ty = 0;
12494:   const m = style.match(/translate\(\s*(-?\d+(?:\.\d+)?)px\s*,\s*(-?\d+(?:\.\d+)?)px\s*\)/);
12495:   if (m){ tx = parseFloat(m[1]); ty = parseFloat(m[2]); }
12496:   const tr3 = style.match(/translate3d\(\s*(-?\d+(?:\.\d+)?)px\s*,\s*(-?\d+(?:\.\d+)?)px/);
12497:   if (tr3){ tx = parseFloat(tr3[1]); ty = parseFloat(tr3[2]); }
12498: 
12499:   // Project each point to px
12500:   const coords = pts.map(p => tileMapLatLonToPx(root, p.lat, p.lon));
12501: 
12502:   // Build SVG polyline
12503:   const W = root.clientWidth || 400;
12504:   const H = (state.mapSize === "small") ? W : (root.clientHeight || W);
12505:   const closed = !!state.track.closed && pts.length >= 3;
12506:   const ptStr = coords.map(c => (c.x - tx).toFixed(1) + "," + (c.y - ty).toFixed(1)).join(" ");
12507:   const lineClass = "track-line" + (closed ? " track-line-closed" : "");
12508:   const elem = (closed && coords.length >= 3)
12509:     ? `<polygon class="${lineClass}" points="${ptStr}" />`
12510:     : `<polyline class="${lineClass}" points="${ptStr}" />`;
12511: 
12512:   const vertices = coords.map((c, i) => {
12513:     const cx = (c.x - tx).toFixed(1), cy = (c.y - ty).toFixed(1);
12514:     return `<circle class="track-vertex" cx="${cx}" cy="${cy}" r="10" />` +
12515:            `<text class="track-vertex-label" x="${cx}" y="${cy}">${i+1}</text>`;
12516:   }).join("");
12517: 
12518:   const overlay = document.createElement("div");
12519:   overlay.className = "track-overlay";
12520:   overlay.innerHTML =
12521:     `<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${H}" viewBox="0 0 ${W} ${H}">` +
12522:     (pts.length >= 2 ? elem : "") +
12523:     vertices +
12524:     `</svg>`;
12525:   tileLayer.appendChild(overlay);
12526: }
