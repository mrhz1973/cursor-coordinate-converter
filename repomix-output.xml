10832: /**
10833:  * Build the scale bar HTML (positioned bottom-left of the tile map).
10834:  * Shows both a metric scale bar (e.g. "500 m") AND the cartographic ratio
10835:  * (e.g. "1:25k"). The ratio is computed assuming a standard 96-DPI display,
10836:  * i.e. ~0.28 mm per screen pixel — this is the same convention used by most
10837:  * web mapping libraries (Leaflet, OpenLayers) when rendering 1:N scales.
10838:  */
10839: function buildScaleBar(zoom, lat, size, mapW){
10840:   // Meters per pixel at this zoom and latitude (Web Mercator scale factor).
10841:   const mpp = 156543.03392 * Math.cos(lat * DEG) / Math.pow(2, zoom);
10842:   // Small map hides the scale completely; half/full get a longer scale for readability.
10843:   const desiredPx = (size === "half" || size === "full") ? 540 : 270;
10844:   // Keep the bar inside the viewport: cap by a fraction of the map width.
10845:   const cap = (typeof mapW === "number" && mapW > 0) ? Math.floor(mapW * 0.42) : desiredPx;
10846:   const targetPx = Math.max(160, Math.min(desiredPx, cap));
10847:   const targetM  = mpp * targetPx;
10848:   // Snap to 1, 2, 5 × 10^n meters.
10849:   const candidates = [1,2,5,10,20,50,100,200,500,1000,2000,5000,10000,20000,
10850:                       50000,100000,200000,500000,1000000,2000000,5000000];
10851:   let pickM = candidates[0];
10852:   for (const c of candidates) if (c <= targetM) pickM = c;
10853:   const pickPx = pickM / mpp;
10854:   const label  = (pickM >= 1000) ? (pickM/1000) + " km" : pickM + " m";
10855: 
10856:   // Cartographic ratio: meters-per-pixel ÷ meters-per-screen-pixel.
10857:   // 0.00028 m/px ≈ 96 DPI reference used across GIS tooling.
10858:   const ratio = mpp / 0.00028;
10859:   const ratioLabel = (ratio >= 1_000_000)
10860:     ? "1:" + (Math.round(ratio/1e6 * 10)/10) + "M"
10861:     : (ratio >= 10_000)
10862:       ? "1:" + Math.round(ratio/1000) + "k"
10863:       : "1:" + Math.round(ratio);
10864: 
10865:   return `<div class="tile-scale" aria-hidden="true">
10866:     <div class="tile-scale-bar" style="width:${pickPx.toFixed(1)}px"></div>
10867:     <div class="tile-scale-labels"><span class="tile-scale-label">${label}</span><span class="tile-scale-ratio">${ratioLabel}</span></div>
10868:   </div>`;
10869: }
