 5875: function parseDMSInput(o){
 5876:   const ld=parseFloatStrict(o.latD), lm=parseFloatStrict(o.latM), ls=parseFloatStrict(o.latS);
 5877:   const od=parseFloatStrict(o.lonD), om=parseFloatStrict(o.lonM), os=parseFloatStrict(o.lonS);
 5878:   validateDMSParts(ld, lm, ls, 90, false);
 5879:   validateDMSParts(od, om, os, 180, true);
 5880:   const lat = applyHem(ld + lm/60 + ls/3600, o.latHem);
 5881:   const lon = applyHem(od + om/60 + os/3600, o.lonHem);
 5882:   validateLatLon(lat, lon);
 5883:   return { lat, lon };
 5884: }
