10882: function fmtISODateUTC(d){
10883:   const y = d.getUTCFullYear();
10884:   const m = pad(d.getUTCMonth() + 1, 2);
10885:   const day = pad(d.getUTCDate(), 2);
10886:   return `${y}-${m}-${day}`;
