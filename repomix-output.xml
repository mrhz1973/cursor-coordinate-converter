 5824: function validateLatLon(lat, lon){
 5825:   if (!Number.isFinite(lat) || lat < -90 || lat > 90)  throw new ErrI18n("err.latRange");
 5826:   if (!Number.isFinite(lon) || lon < -180 || lon > 180) throw new ErrI18n("err.lonRange");
