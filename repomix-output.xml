 1232:   content:""; position:absolute;
 1233:   left:50%; bottom:0;
 1234:   width:20px; height:20px;
 1235:   margin-left:-10px; margin-bottom:-10px;
 1236:   border-radius:50%;
 1237:   border:2px solid #fbbf24;
 1238:   box-shadow:0 0 0 1px rgba(0,0,0,.45) inset;
