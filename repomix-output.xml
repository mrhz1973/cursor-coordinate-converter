 6196: /**
 6197:  * Forward Krüger projection constrained to a specific UTM zone.
 6198:  *
 6199:  * Unlike latLonToUTM (which auto-selects the zone based on longitude and
 6200:  * handles the Norway/Svalbard exceptions), this helper projects a point
 6201:  * onto the given zone's central meridian — even if the point lies outside
 6202:  * that zone's natural 6° range. That's exactly what we need when drawing
 6203:  * an MGRS grid overlay: we want easting/northing values that are
 6204:  * consistent with the zone of the map center so grid lines stay aligned
 6205:  * within the current view.
 6206:  *
 6207:  * Accuracy degrades gradually as Δλ grows (tens of meters at ±6°, several
 6208:  * hundred meters at ±12°), but that's more than enough for a visual grid.
 6209:  */
 6210: function latLonToUTMForceZone(lat, lon, zone){
 6211:   const cm = (zone - 1) * 6 - 180 + 3;
 6212:   // Normalize Δλ to [-180°, 180°] so antimeridian-crossing views work.
 6213:   let dLamDeg = lon - cm;
 6214:   while (dLamDeg >  180) dLamDeg -= 360;
 6215:   while (dLamDeg < -180) dLamDeg += 360;
 6216: 
 6217:   const phi  = lat * DEG;
 6218:   const dlam = dLamDeg * DEG;
 6219:   const e = WGS84.e, A = WGS84.A, k0 = WGS84.k0;
 6220:   const t = Math.tan(phi);
 6221:   const sigma = Math.sinh(e * Math.atanh(e * t / Math.sqrt(1 + t*t)));
 6222:   const tp = t * Math.sqrt(1 + sigma*sigma) - sigma * Math.sqrt(1 + t*t);
 6223: 
 6224:   const xiP  = Math.atan2(tp, Math.cos(dlam));
 6225:   const etaP = Math.asinh(Math.sin(dlam) / Math.sqrt(tp*tp + Math.cos(dlam)*Math.cos(dlam)));
 6226:   let xi = xiP, eta = etaP;
 6227:   for (let j = 1; j <= 6; j++){
 6228:     const aj = WGS84.alpha[j-1];
 6229:     xi  += aj * Math.sin(2*j*xiP) * Math.cosh(2*j*etaP);
 6230:     eta += aj * Math.cos(2*j*xiP) * Math.sinh(2*j*etaP);
 6231:   }
 6232:   const easting  = 500000 + k0 * A * eta;
 6233:   const hem = lat >= 0 ? "N" : "S";
 6234:   let northing = k0 * A * xi;
 6235:   if (hem === "S") northing += 10000000;
 6236:   return { easting, northing, hem, zone };
 6237: }
