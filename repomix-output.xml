11600: /** End the selection session; if `commit` and there's a valid rectangle,
11601:  *  it's already been written by the drag handlers. */
11602: function endBboxSelection(){
11603:   const root = document.getElementById("miniMap");
11604:   const tileMap = root && root.querySelector(".tile-map");
11605:   if (tileMap){
11606:     // If a drag was in progress, make sure window-level listeners are removed.
11607:     if (typeof tileMap._bboxCleanup === "function"){
11608:       try { tileMap._bboxCleanup(); } catch(_){}
11609:       tileMap._bboxCleanup = null;
11610:     }
11611:     tileMap.classList.remove("bbox-selecting");
11612:     const b = tileMap.querySelector(".bbox-mode-banner");
11613:     if (b) b.remove();
11614:     const d = tileMap.querySelector(".bbox-draft");
11615:     if (d) d.remove();
11616:   }
11617:   const tip = document.querySelector(".bbox-live-tip");
11618:   if (tip) tip.remove();
11619:   state._bboxSelecting = false;
11620: }
