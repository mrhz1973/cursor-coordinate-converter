 6399: /** Transverse Mercator forward on an arbitrary ellipsoid (Krüger 6-term series).
 6400:  *  Central meridian cmDeg, scale factor k0, false easting/northing (fe, fn). */
 6401: function tmForwardGeneric(latDeg, lonDeg, ell, k0, cmDeg, fe, fn){
 6402:   const f = ell.f;
 6403:   const n  = f/(2-f);
 6404:   const n2 = n*n, n3 = n*n2, n4 = n2*n2, n5 = n2*n3, n6 = n3*n3;
 6405:   const A  = ell.a/(1+n) * (1 + n2/4 + n4/64 + n6/256);
 6406:   const alpha = [
 6407:     (1/2)*n  - (2/3)*n2    + (5/16)*n3     + (41/180)*n4   - (127/288)*n5        + (7891/37800)*n6,
 6408:     (13/48)*n2 - (3/5)*n3  + (557/1440)*n4 + (281/630)*n5  - (1983433/1935360)*n6,
 6409:     (61/240)*n3 - (103/140)*n4 + (15061/26880)*n5 + (167603/181440)*n6,
 6410:     (49561/161280)*n4 - (179/168)*n5 + (6601661/7257600)*n6,
 6411:     (34729/80640)*n5 - (3418889/1995840)*n6,
 6412:     (212378941/319334400)*n6
 6413:   ];
 6414:   const e = ell.e;
 6415:   const phi = latDeg * DEG;
 6416:   const dlam = (lonDeg - cmDeg) * DEG;
 6417:   const tp0 = Math.tan(phi);
 6418:   const sigma = Math.sinh(e * Math.atanh(e * tp0 / Math.sqrt(1 + tp0*tp0)));
 6419:   const tp = tp0 * Math.sqrt(1 + sigma*sigma) - sigma * Math.sqrt(1 + tp0*tp0);
 6420:   const xiP = Math.atan2(tp, Math.cos(dlam));
 6421:   const etaP = Math.asinh(Math.sin(dlam) / Math.sqrt(tp*tp + Math.cos(dlam)*Math.cos(dlam)));
 6422:   let xi = xiP, eta = etaP;
 6423:   for (let j = 1; j <= 6; j++){
 6424:     xi  += alpha[j-1] * Math.sin(2*j*xiP) * Math.cosh(2*j*etaP);
 6425:     eta += alpha[j-1] * Math.cos(2*j*xiP) * Math.sinh(2*j*etaP);
 6426:   }
 6427:   return {
 6428:     easting:  fe + k0 * A * eta,
 6429:     northing: fn + k0 * A * xi
 6430:   };
 6431: }
