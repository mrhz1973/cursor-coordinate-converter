 6964:  * cell. Follows the Google OLC reference algorithm:
 6965:  *   1. Strip the "+" separator.
 6966:  *   2. For each of the 5 pair digits (lat, lon), refine the bounding box by
 6967:  *      a factor of 20 per axis.
 6968:  *   3. For each grid digit (optional, up to 5), refine further by 5 rows × 4
 6969:  *      columns (the 20-letter alphabet split into a 5×4 subgrid).
 6970:  * Returns { lat, lon, latPrec, lonPrec, codeLen } where latPrec/lonPrec are
 6971:  * the cell dimensions at the decoded precision (useful to show the decoding
 6972:  * accuracy to the user).
 6973:  */
 6974: function decodePlusCode(code){
 6975:   if (!code) throw new ErrI18n("err.plusInvalid");
 6976:   const s = String(code).toUpperCase().replace(/\s+/g, "");
 6977:   const plusIdx = s.indexOf(OLC_SEPARATOR);
 6978:   if (plusIdx === -1) throw new ErrI18n("err.plusInvalid");
 6979:   // Only full codes are supported — short codes need a reference location.
 6980:   if (plusIdx !== OLC_SEPARATOR_POS) throw new ErrI18n("err.plusShort");
 6981:   if (s.indexOf(OLC_SEPARATOR, plusIdx + 1) !== -1) throw new ErrI18n("err.plusInvalid");
 6982:   const noSep = s.slice(0, OLC_SEPARATOR_POS) + s.slice(OLC_SEPARATOR_POS + 1);
 6983:   // Character validation + padding rules
 6984:   for (let i = 0; i < noSep.length; i++){
 6985:     const ch = noSep[i];
 6986:     if (ch === "0" && i < OLC_SEPARATOR_POS) continue;
 6987:     if (OLC_ALPHABET.indexOf(ch) === -1) throw new ErrI18n("err.plusInvalid");
 6988:   }
 6989:   // Padded codes truncate at the first "0" (padding is trailing-only within pair section).
 6990:   const padStart = noSep.indexOf("0");
 6991:   const effective = (padStart !== -1 && padStart < OLC_SEPARATOR_POS)
 6992:     ? noSep.slice(0, padStart) : noSep;
 6993:   if (effective.length < 2 || effective.length % 2 !== 0 && effective.length <= OLC_PAIR_LEN){
 6994:     throw new ErrI18n("err.plusInvalid");
 6995:   }
 6996:   const digits = effective.slice(0, OLC_PAIR_LEN + OLC_GRID_LEN);
 6997: 
 6998:   // Each pair contributes a 1/20 refinement in lat AND lon (initial box = 180°×360°,
 6999:   // represented by latPrec/lonPrec starting at 20² so the first division yields 20°).
 7000:   let latVal = -OLC_LAT_MAX;
 7001:   let lonVal = -OLC_LON_MAX;
 7002:   let latPrec = 20 * 20;
 7003:   let lonPrec = 20 * 20;
 7004: 
 7005:   const pairEnd = Math.min(digits.length, OLC_PAIR_LEN);
 7006:   for (let i = 0; i < pairEnd; i += 2){
 7007:     latPrec /= 20;
 7008:     lonPrec /= 20;
 7009:     latVal += OLC_ALPHABET.indexOf(digits[i]) * latPrec;
 7010:     if (i + 1 < digits.length){
 7011:       lonVal += OLC_ALPHABET.indexOf(digits[i + 1]) * lonPrec;
 7012:     }
 7013:   }
 7014: 
 7015:   // Grid refinement: each character subdivides the cell into 5 rows × 4 cols.
 7016:   if (digits.length > OLC_PAIR_LEN){
 7017:     for (let j = OLC_PAIR_LEN; j < digits.length; j++){
 7018:       const idx = OLC_ALPHABET.indexOf(digits[j]);
